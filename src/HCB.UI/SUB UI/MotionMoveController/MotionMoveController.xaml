<UserControl x:Class="HCB.UI.MotionMoveController"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
             xmlns:local="clr-namespace:HCB.UI"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             mc:Ignorable="d">

    <UserControl.Resources>

        <!-- 탭 버튼 -->
        <Style x:Key="MoveTabButton" TargetType="RadioButton">
            <Setter Property="Foreground" Value="#5E8BAA"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="20,0"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Bd"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="0,0,0,2"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#2A5A8C"/>
                                <Setter Property="Foreground" Value="#ECF0F1"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#3498DB"/>
                                <Setter Property="Foreground" Value="#ECF0F1"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 이동 버튼 (절대/상대) -->
        <Style x:Key="MoveButton" TargetType="Button">
            <Setter Property="Height" Value="38"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#ECF0F1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="#0F3460"
                                BorderBrush="#2A5A8C"
                                BorderThickness="1"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1A4A7A"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#3498DB"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#0A2040"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Background" Value="#0A1628"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#1C3A52"/>
                                <Setter Property="Foreground" Value="#3A5A7A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- JOG 버튼 (+/-) -->
        <Style x:Key="JogButton" TargetType="Button">
            <Setter Property="Width" Value="110"/>
            <Setter Property="Height" Value="110"/>
            <Setter Property="FontSize" Value="44"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#ECF0F1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="#0F3460"
                                BorderBrush="#2A5A8C"
                                BorderThickness="1"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1A4A7A"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#3498DB"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#234E7A"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#3498DB"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Min/Max 레이블 -->
        <Style x:Key="LimitLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#5E8BAA"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="TextAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Padding" Value="0,8"/>
        </Style>

        <!-- Min/Max 값 표시 -->
        <Style x:Key="LimitValue" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#ECF0F1"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="TextAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- 입력 TextBox -->
        <Style x:Key="InputBox" TargetType="TextBox">
            <Setter Property="Background" Value="#0A1628"/>
            <Setter Property="Foreground" Value="#ECF0F1"/>
            <Setter Property="BorderBrush" Value="#2A5A8C"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="TextAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="CaretBrush" Value="#ECF0F1"/>
        </Style>

    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <!-- ══ 좌측: 탭 컨텐츠 ══ -->
        <Border Grid.Column="0"
                Background="#0D1B2A" BorderBrush="#1C3A52" BorderThickness="1"
                CornerRadius="8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="1"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- 탭 헤더 -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="8,4">
                    <RadioButton Style="{StaticResource MoveTabButton}"
                                 Content="위치 이동"
                                 GroupName="MoveTabs"
                                 IsChecked="True"
                                 Checked="Tab_Checked"/>
                    <RadioButton Style="{StaticResource MoveTabButton}"
                                 Content="조그 이동"
                                 GroupName="MoveTabs"
                                 Checked="Tab_Checked"/>
                </StackPanel>

                <Rectangle Grid.Row="1" Fill="#1C3A52" Margin="8,0"/>

                <!-- ── 위치 이동 패널 ── -->
                <Grid x:Name="TabPosition" Grid.Row="2" Margin="12,10,12,12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Min / Max -->
                    <Grid Grid.Row="0" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>

                        <!-- Min -->
                        <Border Grid.Column="0"
                                Background="#0A1628" BorderBrush="#1C3A52"
                                BorderThickness="1" CornerRadius="6">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Background="#1C3A52" CornerRadius="5,0,0,5" Padding="10,8">
                                    <TextBlock Style="{StaticResource LimitLabel}" Text="Min"/>
                                </Border>
                                <TextBlock Grid.Column="1"
                                           Style="{StaticResource LimitValue}"
                                           Text="{Binding Axis.LimitMinPosition}"/>
                            </Grid>
                        </Border>

                        <!-- Max -->
                        <Border Grid.Column="2"
                                Background="#0A1628" BorderBrush="#1C3A52"
                                BorderThickness="1" CornerRadius="6">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Background="#1C3A52" CornerRadius="5,0,0,5" Padding="10,8">
                                    <TextBlock Style="{StaticResource LimitLabel}" Text="Max"/>
                                </Border>
                                <TextBlock Grid.Column="1"
                                           Style="{StaticResource LimitValue}"
                                           Text="{Binding Axis.LimitMaxPosition}"/>
                            </Grid>
                        </Border>
                    </Grid>

                    <!-- Position 입력 -->
                    <StackPanel Grid.Row="1"
                                Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" Margin="0,0,10,0">
                            <TextBlock Text="Position (" Foreground="#5E8BAA" FontSize="13" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding Axis.Unit}" Foreground="#ECF0F1" FontSize="13" VerticalAlignment="Center"/>
                            <TextBlock Text=")" Foreground="#5E8BAA" FontSize="13" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBox Style="{StaticResource InputBox}"
                                 Text="{Binding Pitch}"
                                 Width="130" Height="36"/>
                    </StackPanel>

                    <!-- 이동 버튼 -->
                    <Grid Grid.Row="2" Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Content="절대 이동"
                                Style="{StaticResource MoveButton}"
                                Command="{Binding AbsoluteMoveCommand}"/>
                        <Button Grid.Column="2" Content="상대 이동"
                                Style="{StaticResource MoveButton}"
                                Command="{Binding RelativeMoveCommand}"/>
                    </Grid>
                </Grid>

                <!-- ── 조그 이동 패널 ── -->
                <Grid x:Name="TabJog" Grid.Row="2" Visibility="Collapsed"
                      HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Button Grid.Row="0" Content="+"
                            Style="{StaticResource JogButton}">
                        <i:Interaction.Triggers>
                            <i:EventTrigger EventName="PreviewMouseLeftButtonDown">
                                <i:InvokeCommandAction Command="{Binding JogPlusCommand}"/>
                            </i:EventTrigger>
                            <i:EventTrigger EventName="PreviewMouseLeftButtonUp">
                                <i:InvokeCommandAction Command="{Binding JogStopCommand}"/>
                            </i:EventTrigger>
                            <i:EventTrigger EventName="LostMouseCapture">
                                <i:InvokeCommandAction Command="{Binding JogStopCommand}"/>
                            </i:EventTrigger>
                        </i:Interaction.Triggers>
                    </Button>

                    <Button Grid.Row="2" Content="-"
                            Style="{StaticResource JogButton}">
                        <i:Interaction.Triggers>
                            <i:EventTrigger EventName="PreviewMouseLeftButtonDown">
                                <i:InvokeCommandAction Command="{Binding JogMinusCommand}"/>
                            </i:EventTrigger>
                            <i:EventTrigger EventName="PreviewMouseLeftButtonUp">
                                <i:InvokeCommandAction Command="{Binding JogStopCommand}"/>
                            </i:EventTrigger>
                            <i:EventTrigger EventName="LostMouseCapture">
                                <i:InvokeCommandAction Command="{Binding JogStopCommand}"/>
                            </i:EventTrigger>
                        </i:Interaction.Triggers>
                    </Button>
                </Grid>

            </Grid>
        </Border>

        <!-- ══ 우측: 속도 슬라이더 ══ -->
        <Border Grid.Column="1"
                Background="#0D1B2A" BorderBrush="#1C3A52" BorderThickness="1"
                CornerRadius="8" Margin="6,0,0,0" Width="64">
            <Grid Margin="8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="속도"
                           Foreground="#5E8BAA"
                           FontSize="12"
                           FontWeight="SemiBold"
                           TextAlignment="Center"
                           Margin="0,0,0,6"/>

                <telerik:RadSlider
                    Grid.Row="1"
                    Orientation="Vertical"
                    HorizontalAlignment="Center"
                    Minimum="{Binding Axis.LimitMinSpeed}"
                    Maximum="{Binding Axis.LimitMaxSpeed}"
                    SmallChange="0.1"
                    LargeChange="0.5"
                    TickFrequency="0.1"
                    IsSnapToTickEnabled="True"
                    Value="{Binding Axis.SetSpeed}"
                    TickPlacement="BottomRight"
                    StepAction="ChangeRange"
                    SelectionStart="{Binding Axis.LimitMinSpeed}"
                    SelectionEnd="{Binding Axis.LimitMaxSpeed}"/>

                <TextBox Grid.Row="2"
                         Style="{StaticResource InputBox}"
                         Width="48"
                         Height="32"
                         Margin="0,6,0,0"
                         HorizontalAlignment="Center">
                    <TextBox.Text>
                        <Binding Path="Axis.SetSpeed"
                                 UpdateSourceTrigger="PropertyChanged"
                                 StringFormat="N1">
                            <Binding.ValidationRules>
                                <ExceptionValidationRule/>
                            </Binding.ValidationRules>
                        </Binding>
                    </TextBox.Text>
                </TextBox>
            </Grid>
        </Border>

    </Grid>
</UserControl>
