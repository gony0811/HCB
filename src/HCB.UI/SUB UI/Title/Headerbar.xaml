<UserControl x:Class="HCB.UI.HeaderBar"
             x:Name="Root"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:HCB.UI"
             mc:Ignorable="d" >
    <Border Background="{Binding HeaderBackground, ElementName=Root}"
            CornerRadius="4"
            Padding="10,6">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- ── Left: Accent bar + Title + SubTitle badge ── -->
            <StackPanel Grid.Column="0"
                        Orientation="Horizontal"
                        VerticalAlignment="Center">

                <!-- Accent vertical bar -->
                <Rectangle Width="{Binding AccentBarWidth, ElementName=Root}"
                           Height="{Binding AccentBarHeight, ElementName=Root}"
                           Fill="{Binding AccentColor, ElementName=Root}"
                           RadiusX="1" RadiusY="1"
                           Margin="0,0,8,0"/>

                <!-- Title -->
                <TextBlock Text="{Binding Title, ElementName=Root}"
                           FontSize="{Binding TitleFontSize, ElementName=Root}"
                           FontWeight="Bold"
                           Foreground="{Binding TitleForeground, ElementName=Root}"
                           VerticalAlignment="Center"/>

                <!-- SubTitle badge (hidden when SubTitle is empty) -->
                <Border Background="{Binding BadgeBackground, ElementName=Root}"
                        CornerRadius="3"
                        Padding="6,1"
                        Margin="8,0,0,0"
                        VerticalAlignment="Center"
                        Visibility="{Binding BadgeVisibility, ElementName=Root}">
                    <TextBlock Text="{Binding SubTitle, ElementName=Root}"
                               FontSize="{Binding SubTitleFontSize, ElementName=Root}"
                               Foreground="{Binding SubTitleForeground, ElementName=Root}"
                               FontWeight="SemiBold"/>
                </Border>
            </StackPanel>

            <!-- ── Right: Status dot + Status text ── -->
            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        VerticalAlignment="Center"
                        Visibility="{Binding StatusVisibility, ElementName=Root}">

                <Ellipse Width="{Binding StatusDotSize, ElementName=Root}"
                         Height="{Binding StatusDotSize, ElementName=Root}"
                         Fill="{Binding StatusColor, ElementName=Root}"
                         Margin="0,0,5,0"/>

                <TextBlock Text="{Binding StatusText, ElementName=Root}"
                           FontSize="{Binding StatusFontSize, ElementName=Root}"
                           Foreground="{Binding StatusColor, ElementName=Root}"
                           FontWeight="Bold"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
