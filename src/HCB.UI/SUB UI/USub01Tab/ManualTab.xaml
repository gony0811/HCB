<UserControl x:Class="HCB.UI.ManualTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:HCB.UI"
             mc:Ignorable="d">

    <UserControl.Resources>
        <local:TupleConverter x:Key="TupleConverter"/>
        <local:BoolToColorConverter x:Key="BoolToColor"/>

        <!-- ── 탭 버튼 스타일 ── -->
        <Style x:Key="ManualTabButton" TargetType="RadioButton">
            <Setter Property="Foreground" Value="#5E8BAA"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="20,0"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Bd"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="0,0,0,2"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#2A5A8C"/>
                                <Setter Property="Foreground" Value="#ECF0F1"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#3498DB"/>
                                <Setter Property="Foreground" Value="#ECF0F1"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── DataGrid 공통 스타일 ── -->
        <Style x:Key="ManualDataGrid" TargetType="DataGrid">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="RowBackground" Value="Transparent"/>
            <Setter Property="AlternatingRowBackground" Value="#0A1628"/>
            <Setter Property="Foreground" Value="#ECF0F1"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="CanUserResizeRows" Value="False"/>
            <Setter Property="SelectionMode" Value="Single"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#1C3A52"/>
            <Setter Property="RowHeaderWidth" Value="0"/>
            <Setter Property="MinHeight" Value="250"/>
        </Style>

        <Style x:Key="ManualColumnHeader" TargetType="DataGridColumnHeader"
               BasedOn="{StaticResource {x:Type DataGridColumnHeader}}">
            <Setter Property="Background" Value="#0A1628"/>
            <Setter Property="Foreground" Value="#5E8BAA"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderBrush" Value="#1C3A52"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Padding" Value="10,8"/>
        </Style>

        <Style x:Key="ManualCell" TargetType="DataGridCell"
               BasedOn="{StaticResource {x:Type DataGridCell}}">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- ── 그리드 내 이동/정지 버튼 ── -->
        <Style x:Key="MoveButton" TargetType="Button">
            <Setter Property="Width" Value="72"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Margin" Value="3,0"/>
            <Setter Property="Foreground" Value="#ECF0F1"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="#0F3460"
                                BorderBrush="#2A5A8C"
                                BorderThickness="1"
                                CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1A4A7A"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#3498DB"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#0A2040"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Background" Value="#0A1628"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#1C3A52"/>
                                <Setter Property="Foreground" Value="#3A5A7A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="StopButton" TargetType="Button">
            <Setter Property="Width" Value="72"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Margin" Value="3,0"/>
            <Setter Property="Foreground" Value="#ECF0F1"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="#3D0F0F"
                                BorderBrush="#E74C3C"
                                BorderThickness="1"
                                CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#5A1818"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#FF6B6B"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#200808"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Background" Value="#0A1628"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#1C3A52"/>
                                <Setter Property="Foreground" Value="#3A5A7A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── 하단 토글 버튼 (VAC / SERVO) ── -->
        <Style x:Key="BottomActionButton" TargetType="Button">
            <Setter Property="Width" Value="120"/>
            <Setter Property="Height" Value="72"/>
            <Setter Property="Margin" Value="4,0"/>
            <Setter Property="Foreground" Value="#ECF0F1"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.65"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </UserControl.Resources>

    <!-- ══ 루트 레이아웃: 탭 영역 + 하단 버튼 바 ══ -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ── 커스텀 탭 컨테이너 ── -->
        <Border Background="#0D1B2A" BorderBrush="#1C3A52" BorderThickness="1" CornerRadius="8" Margin="6">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="1"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- 탭 헤더 바 -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="12,4,12,0">
                    <RadioButton Style="{StaticResource ManualTabButton}"
                                 Content="D-TABLE"
                                 GroupName="ManualTabs"
                                 IsChecked="True"
                                 Checked="Tab_Checked"/>
                    <RadioButton Style="{StaticResource ManualTabButton}"
                                 Content="P-TABLE"
                                 GroupName="ManualTabs"
                                 Checked="Tab_Checked"/>
                    <RadioButton Style="{StaticResource ManualTabButton}"
                                 Content="B-HEAD"
                                 GroupName="ManualTabs"
                                 Checked="Tab_Checked"/>
                    <RadioButton Style="{StaticResource ManualTabButton}"
                                 Content="W-TABLE"
                                 GroupName="ManualTabs"
                                 Checked="Tab_Checked"/>
                </StackPanel>

                <!-- 탭 헤더 하단 구분선 -->
                <Rectangle Grid.Row="1" Fill="#1C3A52" Margin="12,0"/>

                <!-- ══ 탭 컨텐츠 ══ -->

                <!-- D-TABLE -->
                <Grid x:Name="TabDTable" Grid.Row="2"
                      local:GridHelper.Columns="1*, 1*"
                      local:GridHelper.Rows="*, Auto">

                    <!-- D-Y -->
                    <Border Background="#0A1628" CornerRadius="6" Margin="8"
                            BorderBrush="#1C3A52" BorderThickness="1">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <local:HeaderBar Margin="12,10,12,0" Title="D-Y"/>
                            <Rectangle Grid.Row="0" Height="1" Fill="#1C3A52"
                                       VerticalAlignment="Bottom" Margin="12,32,12,0"/>

                            <DataGrid Grid.Row="1"
                                      Style="{StaticResource ManualDataGrid}"
                                      ColumnHeaderStyle="{StaticResource ManualColumnHeader}"
                                      CellStyle="{StaticResource ManualCell}"
                                      ItemsSource="{Binding DyAxis.PositionList}"
                                      Margin="8,6,8,4">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="이름"
                                                        Binding="{Binding Name}"
                                                        Width="*"/>
                                    <DataGridTextColumn Header="위치"
                                                        Binding="{Binding Position, StringFormat=F3}"
                                                        Width="90"/>
                                    <DataGridTextColumn Header="속도"
                                                        Binding="{Binding Speed, StringFormat=F2}"
                                                        Width="80"/>
                                    <DataGridTemplateColumn Header="동작" Width="170">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="4,4">
                                                    <Button Style="{StaticResource MoveButton}" Content="이동"
                                                            Command="{Binding DataContext.MovePositionCommand, RelativeSource={RelativeSource AncestorType=UserControl}}">
                                                        <Button.CommandParameter>
                                                            <MultiBinding Converter="{StaticResource TupleConverter}">
                                                                <Binding Path="DataContext.DyAxis" RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                                                                <Binding/>
                                                            </MultiBinding>
                                                        </Button.CommandParameter>
                                                    </Button>
                                                    <Button Style="{StaticResource StopButton}" Content="정지"
                                                            Command="{Binding DataContext.MoveStopCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding DataContext.DyAxis, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>

                            <local:MotorStateControl DataContext="{Binding DyAxis}"
                                                     Grid.Row="2" Margin="8,0,8,8"/>
                        </Grid>
                    </Border>
                </Grid>

                <!-- P-TABLE -->
                <Grid x:Name="TabPTable" Grid.Row="2" Visibility="Collapsed"
                      local:GridHelper.Columns="1*, 1*"
                      local:GridHelper.Rows="*, Auto">

                    <!-- P-Y -->
                    <Border Background="#0A1628" CornerRadius="6" Margin="8"
                            BorderBrush="#1C3A52" BorderThickness="1">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <local:HeaderBar Margin="12,10,12,0" Title="P-Y"/>
                            <Rectangle Grid.Row="0" Height="1" Fill="#1C3A52"
                                       VerticalAlignment="Bottom" Margin="12,32,12,0"/>

                            <DataGrid Grid.Row="1"
                                      Style="{StaticResource ManualDataGrid}"
                                      ColumnHeaderStyle="{StaticResource ManualColumnHeader}"
                                      CellStyle="{StaticResource ManualCell}"
                                      ItemsSource="{Binding PyAxis.PositionList}"
                                      Margin="8,6,8,4">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="이름"   Binding="{Binding Name}"                     Width="*"/>
                                    <DataGridTextColumn Header="위치"   Binding="{Binding Position, StringFormat=F3}" Width="90"/>
                                    <DataGridTextColumn Header="속도"   Binding="{Binding Speed, StringFormat=F2}"    Width="80"/>
                                    <DataGridTemplateColumn Header="동작" Width="170">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="4,4">
                                                    <Button Style="{StaticResource MoveButton}" Content="이동"
                                                            Command="{Binding AbsoluteMoveCommand}"/>
                                                    <Button Style="{StaticResource StopButton}" Content="정지"
                                                            Command="{Binding StopCommand}"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>

                            <local:MotorStateControl DataContext="{Binding PyAxis}"
                                                     Grid.Row="2" Margin="8,0,8,8"/>
                        </Grid>
                    </Border>
                </Grid>

                <!-- B-HEAD -->
                <Grid x:Name="TabBHead" Grid.Row="2" Visibility="Collapsed"
                      local:GridHelper.Columns="1*, 1*, 1*">

                    <!-- H-X -->
                    <Border Background="#0A1628" CornerRadius="6" Margin="8"
                            BorderBrush="#1C3A52" BorderThickness="1">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <local:HeaderBar Margin="12,10,12,0" Title="H-X"/>
                            <Rectangle Grid.Row="0" Height="1" Fill="#1C3A52"
                                       VerticalAlignment="Bottom" Margin="12,32,12,0"/>
                            <DataGrid Grid.Row="1"
                                      Style="{StaticResource ManualDataGrid}"
                                      ColumnHeaderStyle="{StaticResource ManualColumnHeader}"
                                      CellStyle="{StaticResource ManualCell}"
                                      ItemsSource="{Binding BxAxis.PositionList}"
                                      Margin="8,6,8,4">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="이름"   Binding="{Binding Name}"                     Width="*"/>
                                    <DataGridTextColumn Header="위치"   Binding="{Binding Position, StringFormat=F3}" Width="90"/>
                                    <DataGridTextColumn Header="속도"   Binding="{Binding Speed, StringFormat=F2}"    Width="80"/>
                                    <DataGridTemplateColumn Header="동작" Width="170">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="4,4">
                                                    <Button Style="{StaticResource MoveButton}" Content="이동"
                                                            Command="{Binding DataContext.MovePositionCommand, RelativeSource={RelativeSource AncestorType=UserControl}}">
                                                        <Button.CommandParameter>
                                                            <MultiBinding Converter="{StaticResource TupleConverter}">
                                                                <Binding Path="DataContext.BxAxis" RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                                                                <Binding/>
                                                            </MultiBinding>
                                                        </Button.CommandParameter>
                                                    </Button>
                                                    <Button Style="{StaticResource StopButton}" Content="정지"
                                                            Command="{Binding DataContext.MoveStopCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding DataContext.BxAxis, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                            <local:MotorStateControl DataContext="{Binding BxAxis}"
                                                     Grid.Row="2" Margin="8,0,8,8"/>
                        </Grid>
                    </Border>

                    <!-- H-Z (Bz1) -->
                    <Border Grid.Column="1" Background="#0A1628" CornerRadius="6" Margin="8"
                            BorderBrush="#1C3A52" BorderThickness="1">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <local:HeaderBar Margin="12,10,12,0" Title="H-Z"/>
                            <Rectangle Grid.Row="0" Height="1" Fill="#1C3A52"
                                       VerticalAlignment="Bottom" Margin="12,32,12,0"/>
                            <DataGrid Grid.Row="1"
                                      Style="{StaticResource ManualDataGrid}"
                                      ColumnHeaderStyle="{StaticResource ManualColumnHeader}"
                                      CellStyle="{StaticResource ManualCell}"
                                      ItemsSource="{Binding Bz1Axis.PositionList}"
                                      Margin="8,6,8,4">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="이름"   Binding="{Binding Name}"                     Width="*"/>
                                    <DataGridTextColumn Header="위치"   Binding="{Binding Position, StringFormat=F3}" Width="90"/>
                                    <DataGridTextColumn Header="속도"   Binding="{Binding Speed, StringFormat=F2}"    Width="80"/>
                                    <DataGridTemplateColumn Header="동작" Width="170">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="4,4">
                                                    <Button Style="{StaticResource MoveButton}" Content="이동"
                                                            Command="{Binding DataContext.MovePositionCommand, RelativeSource={RelativeSource AncestorType=UserControl}}">
                                                        <Button.CommandParameter>
                                                            <MultiBinding Converter="{StaticResource TupleConverter}">
                                                                <Binding Path="DataContext.Bz1Axis" RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                                                                <Binding/>
                                                            </MultiBinding>
                                                        </Button.CommandParameter>
                                                    </Button>
                                                    <Button Style="{StaticResource StopButton}" Content="정지"
                                                            Command="{Binding DataContext.MoveStopCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding DataContext.Bz1Axis, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                            <local:MotorStateControl DataContext="{Binding Bz1Axis}"
                                                     Grid.Row="2" Margin="8,0,8,8"/>
                        </Grid>
                    </Border>

                    <!-- h-z (Bz2) -->
                    <Border Grid.Column="2" Background="#0A1628" CornerRadius="6" Margin="8"
                            BorderBrush="#1C3A52" BorderThickness="1">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <local:HeaderBar Margin="12,10,12,0" Title="h-z"/>
                            <Rectangle Grid.Row="0" Height="1" Fill="#1C3A52"
                                       VerticalAlignment="Bottom" Margin="12,32,12,0"/>
                            <DataGrid Grid.Row="1"
                                      Style="{StaticResource ManualDataGrid}"
                                      ColumnHeaderStyle="{StaticResource ManualColumnHeader}"
                                      CellStyle="{StaticResource ManualCell}"
                                      ItemsSource="{Binding Bz2Axis.PositionList}"
                                      Margin="8,6,8,4">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="이름"   Binding="{Binding Name}"                     Width="*"/>
                                    <DataGridTextColumn Header="위치"   Binding="{Binding Position, StringFormat=F3}" Width="90"/>
                                    <DataGridTextColumn Header="속도"   Binding="{Binding Speed, StringFormat=F2}"    Width="80"/>
                                    <DataGridTemplateColumn Header="동작" Width="170">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="4,4">
                                                    <Button Style="{StaticResource MoveButton}" Content="이동"
                                                            Command="{Binding DataContext.MovePositionCommand, RelativeSource={RelativeSource AncestorType=UserControl}}">
                                                        <Button.CommandParameter>
                                                            <MultiBinding Converter="{StaticResource TupleConverter}">
                                                                <Binding Path="DataContext.Bz2Axis" RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                                                                <Binding/>
                                                            </MultiBinding>
                                                        </Button.CommandParameter>
                                                    </Button>
                                                    <Button Style="{StaticResource StopButton}" Content="정지"
                                                            Command="{Binding DataContext.MoveStopCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding DataContext.Bz2Axis, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                            <local:MotorStateControl DataContext="{Binding Bz2Axis}"
                                                     Grid.Row="2" Margin="8,0,8,8"
                                                     HzHomeCommand="{Binding DataContext.HzHomeCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                        </Grid>
                    </Border>
                </Grid>

                <!-- W-TABLE -->
                <Grid x:Name="TabWTable" Grid.Row="2" Visibility="Collapsed"
                      local:GridHelper.Columns="1*, 1*">

                    <!-- W-Y -->
                    <Border Background="#0A1628" CornerRadius="6" Margin="8"
                            BorderBrush="#1C3A52" BorderThickness="1">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <local:HeaderBar Margin="12,10,12,0" Title="W-Y"/>
                            <Rectangle Grid.Row="0" Height="1" Fill="#1C3A52"
                                       VerticalAlignment="Bottom" Margin="12,32,12,0"/>
                            <DataGrid Grid.Row="1"
                                      Style="{StaticResource ManualDataGrid}"
                                      ColumnHeaderStyle="{StaticResource ManualColumnHeader}"
                                      CellStyle="{StaticResource ManualCell}"
                                      ItemsSource="{Binding WyAxis.PositionList}"
                                      Margin="8,6,8,4">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="이름"   Binding="{Binding Name}"                     Width="*"/>
                                    <DataGridTextColumn Header="위치"   Binding="{Binding Position, StringFormat=F3}" Width="90"/>
                                    <DataGridTextColumn Header="속도"   Binding="{Binding Speed, StringFormat=F2}"    Width="80"/>
                                    <DataGridTemplateColumn Header="동작" Width="170">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="4,4">
                                                    <Button Style="{StaticResource MoveButton}" Content="이동"
                                                            Command="{Binding DataContext.MovePositionCommand, RelativeSource={RelativeSource AncestorType=UserControl}}">
                                                        <Button.CommandParameter>
                                                            <MultiBinding Converter="{StaticResource TupleConverter}">
                                                                <Binding Path="DataContext.WyAxis" RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                                                                <Binding/>
                                                            </MultiBinding>
                                                        </Button.CommandParameter>
                                                    </Button>
                                                    <Button Style="{StaticResource StopButton}" Content="정지"
                                                            Command="{Binding DataContext.MoveStopCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding DataContext.WyAxis, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                            <local:MotorStateControl DataContext="{Binding WyAxis}"
                                                     Grid.Row="2" Margin="8,0,8,8"/>
                        </Grid>
                    </Border>

                    <!-- W-T -->
                    <Border Grid.Column="1" Background="#0A1628" CornerRadius="6" Margin="8"
                            BorderBrush="#1C3A52" BorderThickness="1">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <local:HeaderBar Margin="12,10,12,0" Title="W-T"/>
                            <Rectangle Grid.Row="0" Height="1" Fill="#1C3A52"
                                       VerticalAlignment="Bottom" Margin="12,32,12,0"/>
                            <DataGrid Grid.Row="1"
                                      Style="{StaticResource ManualDataGrid}"
                                      ColumnHeaderStyle="{StaticResource ManualColumnHeader}"
                                      CellStyle="{StaticResource ManualCell}"
                                      ItemsSource="{Binding WtAxis.PositionList}"
                                      Margin="8,6,8,4">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="이름"   Binding="{Binding Name}"                     Width="*"/>
                                    <DataGridTextColumn Header="위치"   Binding="{Binding Position, StringFormat=F3}" Width="90"/>
                                    <DataGridTextColumn Header="속도"   Binding="{Binding Speed, StringFormat=F2}"    Width="80"/>
                                    <DataGridTemplateColumn Header="동작" Width="170">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="4,4">
                                                    <Button Style="{StaticResource MoveButton}" Content="이동"
                                                            Command="{Binding DataContext.MovePositionCommand, RelativeSource={RelativeSource AncestorType=UserControl}}">
                                                        <Button.CommandParameter>
                                                            <MultiBinding Converter="{StaticResource TupleConverter}">
                                                                <Binding Path="DataContext.WtAxis" RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                                                                <Binding/>
                                                            </MultiBinding>
                                                        </Button.CommandParameter>
                                                    </Button>
                                                    <Button Style="{StaticResource StopButton}" Content="정지"
                                                            Command="{Binding DataContext.MoveStopCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding DataContext.WtAxis, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                            <local:MotorStateControl DataContext="{Binding WtAxis}"
                                                     Grid.Row="2" Margin="8,0,8,8"/>
                        </Grid>
                    </Border>
                </Grid>

            </Grid>
        </Border>

        <!-- ══ 하단 버튼 바 ══ -->
        <Border Grid.Row="1" Background="#0D1B2A" BorderBrush="#1C3A52" BorderThickness="1"
                CornerRadius="8" Margin="6,0,6,6">
            <StackPanel Orientation="Horizontal" Margin="12,10" VerticalAlignment="Center">

                <!-- 전체 JOG -->
                <Button Content="전체 JOG"
                        Command="{Binding JogOpenCommand}"
                        Style="{StaticResource BottomActionButton}"
                        Background="#0F3460"
                        BorderBrush="#2A5A8C"/>

                <!-- SERVO : BoolToColor 바인딩 유지 -->
                <Button Content="SERVO"
                        Command="{Binding ServoAllOnOffCommand}"
                        Style="{StaticResource BottomActionButton}"
                        Background="{Binding IsServoOn, Converter={StaticResource BoolToColor}}"
                        BorderBrush="#2A5A8C"/>

                <!-- D-VAC -->
                <Button Content="D-VAC"
                        Command="{Binding DVacAllOnOffCommand}"
                        Style="{StaticResource BottomActionButton}"
                        Background="{Binding IsDVacOn, Converter={StaticResource BoolToColor}}"
                        BorderBrush="#2A5A8C"/>

                <!-- W-VAC -->
                <Button Content="W-VAC"
                        Command="{Binding WVacAllOnOffCommand}"
                        Style="{StaticResource BottomActionButton}"
                        Background="{Binding IsWVacOn, Converter={StaticResource BoolToColor}}"
                        BorderBrush="#2A5A8C"/>

                <!-- H-VAC -->
                <Button Content="H-VAC"
                        Command="{Binding HVacOnOffCommand}"
                        Style="{StaticResource BottomActionButton}"
                        Background="{Binding IsHVacOn, Converter={StaticResource BoolToColor}}"
                        BorderBrush="#2A5A8C"/>

            </StackPanel>
        </Border>

    </Grid>
</UserControl>
