<UserControl x:Class="HCB.UI.CalibrationTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
             xmlns:local="clr-namespace:HCB.UI"
             mc:Ignorable="d">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/SYSTEM/COMMON/Styles/DefaultResource.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- 캘리브레이션 실행 버튼 -->
            <Style x:Key="CalibBtnStyle" TargetType="Button">
                <Setter Property="Background" Value="#1A3A5C"/>
                <Setter Property="Foreground" Value="#ECF0F1"/>
                <Setter Property="FontSize" Value="16"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="BorderBrush" Value="#2A5A8C"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Height" Value="52"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="6">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#234E7A"/>
                                    <Setter Property="BorderBrush" Value="#3498DB"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter Property="Background" Value="#0F2A45"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Opacity" Value="0.4"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Margin="6" local:GridHelper.Columns="1*, 1*"
          IsEnabled="{Binding IsNotBusy}">

        <!-- ══════════════════════════════════════════════
             좌측 : 파라미터 설정 + 캘리브레이션 실행
        ══════════════════════════════════════════════ -->
        <Border Background="#0D1B2A" CornerRadius="8" Margin="6"
                BorderBrush="#1C3A52" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <local:HeaderBar Margin="12,10,12,0" Title="캘리브레이션 실행"/>
                <Rectangle Grid.Row="0" Height="1" Fill="#1C3A52"
                           VerticalAlignment="Bottom" Margin="12,32,12,0"/>

                <StackPanel Grid.Row="1" Margin="16,16,16,16">

                    <!-- ① 파라미터 설정 -->
                    <TextBlock Text="파라미터" Foreground="#5E8BAA"
                               FontSize="13" FontWeight="SemiBold" Margin="0,0,0,10"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="36"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="이동량 A"
                                   Foreground="#5E8BAA" FontSize="18"
                                   VerticalAlignment="Center"/>
                        <TextBox Grid.Column="1"
                                 Text="{Binding AMove, UpdateSourceTrigger=LostFocus, StringFormat=G}"
                                 Background="#0A1628" Foreground="#ECF0F1"
                                 BorderBrush="#2A5A8C" BorderThickness="1"
                                 FontSize="18" Height="40"
                                 TextAlignment="Right" Padding="8,4"
                                 VerticalContentAlignment="Center"/>
                        <TextBlock Grid.Column="2" Text="mm"
                                   Foreground="#5E8BAA" FontSize="16"
                                   VerticalAlignment="Center" Margin="8,0,0,0"/>
                    </Grid>

                    <!-- H_T 회전량 -->
                    <Grid Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="36"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="H_T 회전량"
                                   Foreground="#5E8BAA" FontSize="18"
                                   VerticalAlignment="Center"/>
                        <TextBox Grid.Column="1"
                                 Text="{Binding RotationDeg, UpdateSourceTrigger=LostFocus, StringFormat=G}"
                                 Background="#0A1628" Foreground="#ECF0F1"
                                 BorderBrush="#2A5A8C" BorderThickness="1"
                                 FontSize="18" Height="40"
                                 TextAlignment="Right" Padding="8,4"
                                 VerticalContentAlignment="Center"/>
                        <TextBlock Grid.Column="2" Text="°"
                                   Foreground="#5E8BAA" FontSize="16"
                                   VerticalAlignment="Center" Margin="8,0,0,0"/>
                    </Grid>

                    <Rectangle Height="1" Fill="#1C3A52" Margin="0,20,0,20"/>

                    <!-- ② HC 카메라 각도 -->
                    <TextBlock Text="HC 카메라 각도" Foreground="#5E8BAA"
                               FontSize="13" FontWeight="SemiBold" Margin="0,0,0,6"/>
                    <TextBlock Foreground="#3D5A72" FontSize="12" TextWrapping="Wrap"
                               Margin="0,0,0,12">
                        HC1 / HC2 카메라 FoV 안에 Fiducial Mark가 보이는 위치로
                        Stage를 이동한 뒤 실행하세요.
                    </TextBlock>

                    <Button Style="{StaticResource CalibBtnStyle}"
                            Content="Hc1 각도 캘리브레이션"
                            Command="{Binding Hc1AngleCommand}"
                            Margin="0,0,0,10"
                            ToolTip="HC1_HIGH: ① AF → ② 마크 센터링 → ③ (A,A) 이동 → ④ 재촬영 → ⑤ Θ1 계산"/>

                    <Button Style="{StaticResource CalibBtnStyle}"
                            Content="Hc2 각도 캘리브레이션"
                            Command="{Binding Hc2AngleCommand}"
                            Margin="0,0,0,0"
                            ToolTip="HC2_HIGH: ① AF → ② 마크 센터링 → ③ (A,A) 이동 → ④ 재촬영 → ⑤ Θ2 계산"/>

                    <Rectangle Height="1" Fill="#1C3A52" Margin="0,20,0,20"/>

                    <!-- ③ Pc 카메라 각도 -->
                    <TextBlock Text="Pc 카메라 각도" Foreground="#5E8BAA"
                               FontSize="13" FontWeight="SemiBold" Margin="0,0,0,6"/>
                    <TextBlock Foreground="#3D5A72" FontSize="12" TextWrapping="Wrap"
                               Margin="0,0,0,12">
                        P_LEFT_FIDUCIAL 위치로 Stage를 이동한 뒤 실행하세요.
                        (PY 축 기반 이동 — W_Y 대신 P_Y 사용)
                    </TextBlock>

                    <Button Style="{StaticResource CalibBtnStyle}"
                            Content="Pc 각도 캘리브레이션"
                            Command="{Binding PcAngleCommand}"
                            ToolTip="PC_HIGH: ① AF → ② 마크 센터링(PY) → ③ (A,A) 이동 → ④ 재촬영 → ⑤ Θp 계산"/>

                    <Rectangle Height="1" Fill="#1C3A52" Margin="0,20,0,20"/>

                    <!-- ④ HcRO 회전 중심 -->
                    <TextBlock Text="HcRO 회전 중심" Foreground="#5E8BAA"
                               FontSize="13" FontWeight="SemiBold" Margin="0,0,0,6"/>
                    <TextBlock Foreground="#3D5A72" FontSize="12" TextWrapping="Wrap"
                               Margin="0,0,0,12">
                        Hc1 / Hc2 마크가 보이는 위치로 이동한 뒤 실행하세요.
                        H_T를 회전량만큼 회전하며 두 마크의 호(Chord)로 중심을 역산합니다.
                    </TextBlock>

                    <Button Style="{StaticResource CalibBtnStyle}"
                            Content="HcRO 회전 중심 계산"
                            Command="{Binding CreateHcRoCommand}"
                            ToolTip="① Hc1 센터링 → ② H_T 회전 → ③ Hc1 재센터링 → ④ H_T 복귀 → ⑤ Hc2 동일 반복 → ⑥ ComputeHcRO"/>

                </StackPanel>
            </Grid>
        </Border>

        <!-- ══════════════════════════════════════════════
             우측 : 캘리브레이션 결과
        ══════════════════════════════════════════════ -->
        <Border Grid.Column="1" Background="#0D1B2A" CornerRadius="8" Margin="6"
                BorderBrush="#1C3A52" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <local:HeaderBar Margin="12,10,12,0" Title="캘리브레이션 결과"/>
                <Rectangle Grid.Row="0" Height="1" Fill="#1C3A52"
                           VerticalAlignment="Bottom" Margin="12,32,12,0"/>

                <StackPanel Grid.Row="1" Margin="0,4,0,0">

                    <!-- Hc1 결과 -->
                    <TextBlock Text="Hc1 카메라  (HC1_HIGH)"
                               Foreground="#5E8BAA" FontSize="13" FontWeight="SemiBold"
                               Margin="16,12,16,8"/>

                    <Grid Margin="16,6,16,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Θ1" Foreground="#5E8BAA" FontSize="20" VerticalAlignment="Center"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="{Binding Theta1Rad, StringFormat=F6}"
                                       Foreground="#ECF0F1" FontSize="20" FontWeight="SemiBold"/>
                            <TextBlock Text=" rad" Foreground="#5E8BAA" FontSize="16"
                                       VerticalAlignment="Bottom" Margin="2,0,0,2"/>
                        </StackPanel>
                    </Grid>
                    <Rectangle Height="1" Fill="#1C3A52" Margin="16,0"/>

                    <Grid Margin="16,6,16,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Θ1" Foreground="#5E8BAA" FontSize="20" VerticalAlignment="Center"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="{Binding Theta1Deg, StringFormat=F4}"
                                       Foreground="#2ECC71" FontSize="20" FontWeight="SemiBold"/>
                            <TextBlock Text=" °" Foreground="#5E8BAA" FontSize="16"
                                       VerticalAlignment="Bottom" Margin="2,0,0,2"/>
                        </StackPanel>
                    </Grid>
                    <Rectangle Height="1" Fill="#1C3A52" Margin="16,0"/>

                    <!-- Hc2 결과 -->
                    <TextBlock Text="Hc2 카메라  (HC2_HIGH)"
                               Foreground="#5E8BAA" FontSize="13" FontWeight="SemiBold"
                               Margin="16,16,16,8"/>

                    <Grid Margin="16,6,16,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Θ2" Foreground="#5E8BAA" FontSize="20" VerticalAlignment="Center"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="{Binding Theta2Rad, StringFormat=F6}"
                                       Foreground="#ECF0F1" FontSize="20" FontWeight="SemiBold"/>
                            <TextBlock Text=" rad" Foreground="#5E8BAA" FontSize="16"
                                       VerticalAlignment="Bottom" Margin="2,0,0,2"/>
                        </StackPanel>
                    </Grid>
                    <Rectangle Height="1" Fill="#1C3A52" Margin="16,0"/>

                    <Grid Margin="16,6,16,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Θ2" Foreground="#5E8BAA" FontSize="20" VerticalAlignment="Center"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="{Binding Theta2Deg, StringFormat=F4}"
                                       Foreground="#2ECC71" FontSize="20" FontWeight="SemiBold"/>
                            <TextBlock Text=" °" Foreground="#5E8BAA" FontSize="16"
                                       VerticalAlignment="Bottom" Margin="2,0,0,2"/>
                        </StackPanel>
                    </Grid>
                    <Rectangle Height="1" Fill="#1C3A52" Margin="16,0"/>

                    <!-- Pc 결과 -->
                    <TextBlock Text="Pc 카메라  (PC_HIGH)"
                               Foreground="#5E8BAA" FontSize="13" FontWeight="SemiBold"
                               Margin="16,16,16,8"/>

                    <Grid Margin="16,6,16,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Θp" Foreground="#5E8BAA" FontSize="20" VerticalAlignment="Center"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="{Binding ThetaPRad, StringFormat=F6}"
                                       Foreground="#ECF0F1" FontSize="20" FontWeight="SemiBold"/>
                            <TextBlock Text=" rad" Foreground="#5E8BAA" FontSize="16"
                                       VerticalAlignment="Bottom" Margin="2,0,0,2"/>
                        </StackPanel>
                    </Grid>
                    <Rectangle Height="1" Fill="#1C3A52" Margin="16,0"/>

                    <Grid Margin="16,6,16,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Θp" Foreground="#5E8BAA" FontSize="20" VerticalAlignment="Center"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="{Binding ThetaPDeg, StringFormat=F4}"
                                       Foreground="#2ECC71" FontSize="20" FontWeight="SemiBold"/>
                            <TextBlock Text=" °" Foreground="#5E8BAA" FontSize="16"
                                       VerticalAlignment="Bottom" Margin="2,0,0,2"/>
                        </StackPanel>
                    </Grid>
                    <Rectangle Height="1" Fill="#1C3A52" Margin="16,0"/>

                    <!-- HcRO 결과 -->
                    <TextBlock Text="HcRO 회전 중심  [HX(C), WY(C)]"
                               Foreground="#5E8BAA" FontSize="13" FontWeight="SemiBold"
                               Margin="16,16,16,8"/>

                    <Grid Margin="16,6,16,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="HX(C)" Foreground="#5E8BAA" FontSize="20" VerticalAlignment="Center"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="{Binding HcROX, StringFormat=F4}"
                                       Foreground="#ECF0F1" FontSize="20" FontWeight="SemiBold"/>
                            <TextBlock Text=" mm" Foreground="#5E8BAA" FontSize="16"
                                       VerticalAlignment="Bottom" Margin="2,0,0,2"/>
                        </StackPanel>
                    </Grid>
                    <Rectangle Height="1" Fill="#1C3A52" Margin="16,0"/>

                    <Grid Margin="16,6,16,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="WY(C)" Foreground="#5E8BAA" FontSize="20" VerticalAlignment="Center"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="{Binding HcROY, StringFormat=F4}"
                                       Foreground="#ECF0F1" FontSize="20" FontWeight="SemiBold"/>
                            <TextBlock Text=" mm" Foreground="#5E8BAA" FontSize="16"
                                       VerticalAlignment="Bottom" Margin="2,0,0,2"/>
                        </StackPanel>
                    </Grid>
                    <Rectangle Height="1" Fill="#1C3A52" Margin="16,0"/>

                </StackPanel>

                <!-- 진행 상태 -->
                <Border Grid.Row="2"
                        Background="#0A1628" BorderBrush="#2A5A8C" BorderThickness="1"
                        CornerRadius="6" Margin="12,8,12,12" Padding="14,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="상태 " Foreground="#5E8BAA" FontSize="14"
                                   VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1"
                                   Text="{Binding CalibStatus}"
                                   Foreground="#3498DB" FontSize="14"
                                   TextWrapping="Wrap" VerticalAlignment="Center"/>
                    </Grid>
                </Border>

            </Grid>
        </Border>

    </Grid>
</UserControl>
