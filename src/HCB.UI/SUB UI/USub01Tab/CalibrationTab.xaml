<UserControl x:Class="HCB.UI.CalibrationTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
             xmlns:local="clr-namespace:HCB.UI"
             mc:Ignorable="d">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/SYSTEM/COMMON/Styles/DefaultResource.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <local:InverseBoolConverter x:Key="InverseBoolConverter"/>

            <!-- 캘리브레이션 실행 버튼 -->
            <Style x:Key="CalibBtnStyle" TargetType="Button">
                <Setter Property="Background" Value="#1A3A5C"/>
                <Setter Property="Foreground" Value="#ECF0F1"/>
                <Setter Property="FontSize" Value="16"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="BorderBrush" Value="#2A5A8C"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Height" Value="52"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="6">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#234E7A"/>
                                    <Setter Property="BorderBrush" Value="#3498DB"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter Property="Background" Value="#0F2A45"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Opacity" Value="0.4"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- CalibComboStyle -->
            <Style x:Key="CalibComboStyle" TargetType="ComboBox">
                <Setter Property="Foreground" Value="#ECF0F1"/>
                <Setter Property="FontSize" Value="16"/>
                <Setter Property="Height" Value="40"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ComboBox">
                            <Grid>
                                <ToggleButton x:Name="ToggleButton"
                                  IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                  Focusable="False" ClickMode="Press">
                                    <ToggleButton.Template>
                                        <ControlTemplate TargetType="ToggleButton">
                                            <Border Background="#0A1628" BorderBrush="#2A5A8C"
                                        BorderThickness="1" CornerRadius="4">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="32"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Path Grid.Column="1" Data="M 0 0 L 4 4 L 8 0 Z"
                                              Fill="#5E8BAA" HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                                                </Grid>
                                            </Border>
                                        </ControlTemplate>
                                    </ToggleButton.Template>
                                </ToggleButton>
                                <ContentPresenter Margin="10,0,32,0"
                                      Content="{TemplateBinding SelectionBoxItem}"
                                      ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                      VerticalAlignment="Center" IsHitTestVisible="False"/>
                                <Popup IsOpen="{TemplateBinding IsDropDownOpen}" Placement="Bottom"
                           Focusable="False" AllowsTransparency="True">
                                    <Border Background="#0A1628" BorderBrush="#2A5A8C"
                                BorderThickness="1" CornerRadius="4"
                                MaxHeight="300" MinWidth="{TemplateBinding ActualWidth}">
                                        <ScrollViewer>
                                            <ItemsPresenter/>
                                        </ScrollViewer>
                                    </Border>
                                </Popup>
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
                <Setter Property="ItemContainerStyle">
                    <Setter.Value>
                        <Style TargetType="ComboBoxItem">
                            <Setter Property="Foreground" Value="#ECF0F1"/>
                            <Setter Property="Background" Value="#0A1628"/>
                            <Setter Property="Padding" Value="10,6"/>
                            <Setter Property="FontSize" Value="16"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ComboBoxItem">
                                        <Border Background="{TemplateBinding Background}"
                                    Padding="{TemplateBinding Padding}">
                                            <ContentPresenter/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsHighlighted" Value="True">
                                                <Setter Property="Background" Value="#1A3A5C"/>
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="#234E7A"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="CalibTextBoxStyle" TargetType="TextBox">
                <Setter Property="Background" Value="#0A1628"/>
                <Setter Property="Foreground" Value="#ECF0F1"/>
                <Setter Property="CaretBrush" Value="#ECF0F1"/>
                <Setter Property="BorderBrush" Value="#2A5A8C"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="FontSize" Value="18"/>
                <Setter Property="Height" Value="40"/>
                <Setter Property="Padding" Value="8,4"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
                <Setter Property="TextAlignment" Value="Right"/>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Margin="6" local:GridHelper.Columns="1*, 1*"
          IsEnabled="{Binding IsNotBusy}">

        <!-- ══════════════════════════════════════════════
             좌측 : 캘리브레이션 실행
        ══════════════════════════════════════════════ -->
        <Border Background="#0D1B2A" CornerRadius="8" Margin="6"
                BorderBrush="#1C3A52" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <local:HeaderBar Margin="12,10,12,0" Title="캘리브레이션 실행"/>
                <Rectangle Grid.Row="0" Height="1" Fill="#1C3A52"
                           VerticalAlignment="Bottom" Margin="12,32,12,0"/>

                <!-- ★ ScrollViewer로 감싸서 넘침 방지 -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="16,16,16,16">

                        <!-- ① HC 카메라 각도 -->
                        <TextBlock Text="HC 카메라 각도" Foreground="#5E8BAA"
                                   FontSize="13" FontWeight="SemiBold" Margin="0,0,0,6"/>
                        <TextBlock Foreground="#3D5A72" FontSize="12" TextWrapping="Wrap"
                                   Margin="0,0,0,12">
                            HC1 / HC2 카메라 FoV 안에 Fiducial Mark가 보이는 위치로
                            Stage를 이동한 뒤 실행하세요.
                        </TextBlock>

                        <Button Style="{StaticResource CalibBtnStyle}"
                                Content="Hc1 각도 캘리브레이션"
                                Command="{Binding Hc1AngleCommand}"
                                Margin="0,0,0,10"/>

                        <Button Style="{StaticResource CalibBtnStyle}"
                                Content="Hc2 각도 캘리브레이션"
                                Command="{Binding Hc2AngleCommand}"
                                Margin="0,0,0,10"/>

                        <Button Style="{StaticResource CalibBtnStyle}"
                                Content="카메라 Hc1/Hc2 거리 계산"
                                Command="{Binding CameraDistanceCommand}"/>

                        <Rectangle Height="1" Fill="#1C3A52" Margin="0,20,0,20"/>

                        <!-- ② Pc 카메라 각도 -->
                        <TextBlock Text="Pc 카메라 각도" Foreground="#5E8BAA"
                                   FontSize="13" FontWeight="SemiBold" Margin="0,0,0,6"/>
                        <TextBlock Foreground="#3D5A72" FontSize="12" TextWrapping="Wrap"
                                   Margin="0,0,0,12">
                            P_LEFT_FIDUCIAL 위치로 Stage를 이동한 뒤 실행하세요.
                        </TextBlock>

                        <Button Style="{StaticResource CalibBtnStyle}"
                                Content="Pc 각도 캘리브레이션"
                                Command="{Binding PcAngleCommand}"/>

                        <Rectangle Height="1" Fill="#1C3A52" Margin="0,20,0,20"/>

                        <!-- ③ HcRO 회전 중심 -->
                        <TextBlock Text="HcRO 회전 중심" Foreground="#5E8BAA"
                                   FontSize="13" FontWeight="SemiBold" Margin="0,0,0,6"/>
                        <TextBlock Foreground="#3D5A72" FontSize="12" TextWrapping="Wrap"
                                   Margin="0,0,0,12">
                            Hc1 / Hc2 마크가 보이는 위치로 이동한 뒤 실행하세요.
                        </TextBlock>

                        <Button Style="{StaticResource CalibBtnStyle}"
                                Content="HcRO 회전 중심 계산"
                                Command="{Binding CreateHcRoCommand}"/>
                        <Rectangle Height="1" Fill="#1C3A52" Margin="0,20,0,20"/>

                        <!-- ④ 전체 캘리브레이션 -->
                        <TextBlock Text="전체 캘리브레이션" Foreground="#5E8BAA"
                                   FontSize="13" FontWeight="SemiBold" Margin="0,0,0,6"/>
                        <TextBlock Foreground="#3D5A72" FontSize="12" TextWrapping="Wrap"
                                   Margin="0,0,0,12">
                            HC1→HC2→거리→PC→HcRO 순서로 자동 실행합니다.
                        </TextBlock>

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="36"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="반복 횟수" Foreground="#5E8BAA" FontSize="18"
                                       VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1" Style="{StaticResource CalibTextBoxStyle}"
                                     Text="{Binding CalibRepeatCount, UpdateSourceTrigger=LostFocus}"/>
                            <TextBlock Grid.Column="2" Text="회"
                                       Foreground="#5E8BAA" FontSize="16"
                                       VerticalAlignment="Center" Margin="8,0,0,0"/>
                        </Grid>

                        <Button Style="{StaticResource CalibBtnStyle}"
                                Content="전체 캘리브레이션 실행"
                                Command="{Binding RunFullCalibrationCommand}"
                                Margin="0,0,0,10"/>

                        <Button Content="중지" Height="42" FontSize="15" FontWeight="SemiBold"
                                Cursor="Hand" Foreground="#ECF0F1"
                                Command="{Binding StopCalibrationCommand}"
                                Margin="0,0,0,10"
                                IsEnabled="{Binding IsNotBusy, Converter={StaticResource InverseBoolConverter}}">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="#8B1A1A" BorderBrush="#C0392B" BorderThickness="1"
                                            CornerRadius="6">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <Border Background="#0A1628" BorderBrush="#2A5A8C" BorderThickness="1"
                                CornerRadius="6" Padding="10,8">
                            <TextBlock Text="{Binding CalibProgress}"
                                       Foreground="#E67E22" FontSize="14" TextWrapping="Wrap"/>
                        </Border>

                        <!-- ══════════════════════════════════════════════
     ⑤ 2D Mapping — 좌측 StackPanel 맨 아래에 추가
     (전체 캘리브레이션 중지 버튼 + CalibProgress Border 아래)
══════════════════════════════════════════════ -->

                        <Rectangle Height="1" Fill="#1C3A52" Margin="0,20,0,20"/>

                        <TextBlock Text="2D Mapping" Foreground="#5E8BAA"
           FontSize="13" FontWeight="SemiBold" Margin="0,0,0,6"/>
                        <TextBlock Foreground="#3D5A72" FontSize="12" TextWrapping="Wrap"
           Margin="0,0,0,12">
    MasterGlass 원점(0,0)에서 시작하여 8×8 그리드를 2mm 간격으로 측정합니다.
    결과는 Desktop/HCB/2D Mapping 에 CSV로 저장됩니다.
                        </TextBlock>

                        <!-- 카메라 선택 -->
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="카메라" Foreground="#5E8BAA" FontSize="16"
               VerticalAlignment="Center"/>
                            <ComboBox Grid.Column="1" Style="{StaticResource CalibComboStyle}"
              ItemsSource="{Binding Source={local:EnumValues {x:Type local:CameraType}}}"
              SelectedItem="{Binding MappingCamera}"/>
                        </Grid>

                        <!-- 마크 선택 -->
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="마크" Foreground="#5E8BAA" FontSize="16"
               VerticalAlignment="Center"/>
                            <ComboBox Grid.Column="1" Style="{StaticResource CalibComboStyle}"
              ItemsSource="{Binding Source={local:EnumValues {x:Type local:MarkType}}}"
              SelectedItem="{Binding MappingMark}"/>
                        </Grid>

                        <!-- 방향 선택 -->
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="방향" Foreground="#5E8BAA" FontSize="16"
               VerticalAlignment="Center"/>
                            <ComboBox Grid.Column="1" Style="{StaticResource CalibComboStyle}"
              ItemsSource="{Binding Source={local:EnumValues {x:Type local:DirectType}}}"
              SelectedItem="{Binding MappingDirect}"/>
                        </Grid>

                        <!-- Step / Grid 설정 -->
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="36"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="이동 간격" Foreground="#5E8BAA" FontSize="16"
               VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1" Style="{StaticResource CalibTextBoxStyle}"
             Text="{Binding MappingStepMm, UpdateSourceTrigger=LostFocus}"/>
                            <TextBlock Grid.Column="2" Text="mm" Foreground="#5E8BAA" FontSize="16"
               VerticalAlignment="Center" Margin="8,0,0,0"/>
                        </Grid>

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="36"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="그리드" Foreground="#5E8BAA" FontSize="16"
               VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1" Style="{StaticResource CalibTextBoxStyle}"
             Text="{Binding MappingGridSize, UpdateSourceTrigger=LostFocus}"/>
                            <TextBlock Grid.Column="2" Text="×N" Foreground="#5E8BAA" FontSize="16"
               VerticalAlignment="Center" Margin="8,0,0,0"/>
                        </Grid>

                        <!-- 실행 버튼 -->
                        <Button Style="{StaticResource CalibBtnStyle}"
        Content="2D Mapping 실행"
        Command="{Binding RunMapping2DCommand}"
        Margin="0,0,0,10"/>

                        <!-- 진행률 -->
                        <Border Background="#0A1628" BorderBrush="#2A5A8C" BorderThickness="1"
        CornerRadius="6" Padding="10,8">
                            <TextBlock Text="{Binding MappingProgress}"
               Foreground="#E67E22" FontSize="14" TextWrapping="Wrap"/>
                        </Border>


                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- ══════════════════════════════════════════════
             우측 : 캘리브레이션 결과 + 정밀도 검증
        ══════════════════════════════════════════════ -->
        <Border Grid.Column="1" Background="#0D1B2A" CornerRadius="8" Margin="6"
                BorderBrush="#1C3A52" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <local:HeaderBar Margin="12,10,12,0" Title="캘리브레이션 결과"/>
                <Rectangle Grid.Row="0" Height="1" Fill="#1C3A52"
                           VerticalAlignment="Bottom" Margin="12,32,12,0"/>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="0,4,0,0">

                        <!-- Hc1 결과 -->
                        <TextBlock Text="Hc1 카메라  (HC1_HIGH)"
                                   Foreground="#5E8BAA" FontSize="13" FontWeight="SemiBold"
                                   Margin="16,12,16,8"/>

                        <Grid Margin="16,6,16,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Θ1" Foreground="#5E8BAA" FontSize="20" VerticalAlignment="Center"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="{Binding Theta1Deg, StringFormat=F4}"
                                           Foreground="#2ECC71" FontSize="20" FontWeight="SemiBold"/>
                                <TextBlock Text=" °" Foreground="#5E8BAA" FontSize="16"
                                           VerticalAlignment="Bottom" Margin="2,0,0,2"/>
                            </StackPanel>
                        </Grid>
                        <Rectangle Height="1" Fill="#1C3A52" Margin="16,0"/>

                        <!-- Hc2 결과 -->
                        <TextBlock Text="Hc2 카메라  (HC2_HIGH)"
                                   Foreground="#5E8BAA" FontSize="13" FontWeight="SemiBold"
                                   Margin="16,16,16,8"/>

                        <Grid Margin="16,6,16,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Θ2" Foreground="#5E8BAA" FontSize="20" VerticalAlignment="Center"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="{Binding Theta2Deg, StringFormat=F4}"
                                           Foreground="#2ECC71" FontSize="20" FontWeight="SemiBold"/>
                                <TextBlock Text=" °" Foreground="#5E8BAA" FontSize="16"
                                           VerticalAlignment="Bottom" Margin="2,0,0,2"/>
                            </StackPanel>
                        </Grid>
                        <Rectangle Height="1" Fill="#1C3A52" Margin="16,0"/>

                        <!-- Pc 결과 -->
                        <TextBlock Text="Pc 카메라  (PC_HIGH)"
                                   Foreground="#5E8BAA" FontSize="13" FontWeight="SemiBold"
                                   Margin="16,16,16,8"/>

                        <Grid Margin="16,6,16,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Θp" Foreground="#5E8BAA" FontSize="20" VerticalAlignment="Center"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="{Binding ThetaPDeg, StringFormat=F4}"
                                           Foreground="#2ECC71" FontSize="20" FontWeight="SemiBold"/>
                                <TextBlock Text=" °" Foreground="#5E8BAA" FontSize="16"
                                           VerticalAlignment="Bottom" Margin="2,0,0,2"/>
                            </StackPanel>
                        </Grid>
                        <Rectangle Height="1" Fill="#1C3A52" Margin="16,0"/>

                        <!-- HcRO 결과 -->
                        <TextBlock Text="HcRO 회전 중심"
                                   Foreground="#5E8BAA" FontSize="13" FontWeight="SemiBold"
                                   Margin="16,16,16,8"/>

                        <Grid Margin="16,6,16,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="HX(C)" Foreground="#5E8BAA" FontSize="20" VerticalAlignment="Center"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="{Binding HcROX, StringFormat=F4}"
                                           Foreground="#ECF0F1" FontSize="20" FontWeight="SemiBold"/>
                                <TextBlock Text=" mm" Foreground="#5E8BAA" FontSize="16"
                                           VerticalAlignment="Bottom" Margin="2,0,0,2"/>
                            </StackPanel>
                        </Grid>
                        <Rectangle Height="1" Fill="#1C3A52" Margin="16,0"/>

                        <Grid Margin="16,6,16,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="WY(C)" Foreground="#5E8BAA" FontSize="20" VerticalAlignment="Center"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="{Binding HcROY, StringFormat=F4}"
                                           Foreground="#ECF0F1" FontSize="20" FontWeight="SemiBold"/>
                                <TextBlock Text=" mm" Foreground="#5E8BAA" FontSize="16"
                                           VerticalAlignment="Bottom" Margin="2,0,0,2"/>
                            </StackPanel>
                        </Grid>

                        <Rectangle Height="1" Fill="#1C3A52" Margin="16,12"/>

                        <!-- ═══ 정밀도 검증 ═══ -->
                        <TextBlock Text="정밀도 검증" Foreground="#5E8BAA"
                                   FontSize="13" FontWeight="SemiBold"
                                   Margin="16,4,16,6"/>
                        <TextBlock Foreground="#3D5A72" FontSize="12" TextWrapping="Wrap"
                                   Margin="16,0,16,12">
                            카메라를 선택하고 임의 위치에서 실행하면, 비전 측정→이동→재측정으로 잔차를 확인합니다.
                        </TextBlock>

                        <!-- 카메라 선택 -->
                        <ComboBox Style="{StaticResource CalibComboStyle}" Margin="16,0,16,8"
                                  ItemsSource="{Binding Source={local:EnumValues {x:Type local:CameraType}}}"
                                  SelectedItem="{Binding SelectedCamera}"/>

                        <!-- 마크 선택 -->
                        <ComboBox Style="{StaticResource CalibComboStyle}" Margin="16,0,16,8"
                                  ItemsSource="{Binding Source={local:EnumValues {x:Type local:MarkType}}}"
                                  SelectedItem="{Binding SelectedMark}"/>

                        <!-- 방향 선택 -->
                        <ComboBox Style="{StaticResource CalibComboStyle}" Margin="16,0,16,12"
                                  ItemsSource="{Binding Source={local:EnumValues {x:Type local:DirectType}}}"
                                  SelectedItem="{Binding SelectedDirect}"/>

                        <!-- 검증 실행 버튼 -->
                        <Button Style="{StaticResource CalibBtnStyle}"
                                Content="정밀도 검증 실행"
                                Command="{Binding VerifyAlignmentAccuracyCommand}"
                                Margin="16,0,16,8"/>

                        <!-- 검증 결과 -->
                        <Border Background="#0A1628" BorderBrush="#2A5A8C" BorderThickness="1"
                                CornerRadius="6" Margin="16,0,16,16" Padding="14,10">
                            <TextBlock Text="{Binding VerifyResult}"
                                       Foreground="#E67E22" FontSize="14"
                                       TextWrapping="Wrap"/>
                        </Border>

                    </StackPanel>
                </ScrollViewer>

                <!-- 진행 상태 -->
                <Border Grid.Row="2"
                        Background="#0A1628" BorderBrush="#2A5A8C" BorderThickness="1"
                        CornerRadius="6" Margin="12,8,12,12" Padding="14,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="상태 " Foreground="#5E8BAA" FontSize="14"
                                   VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1"
                                   Text="{Binding CalibStatus}"
                                   Foreground="#3498DB" FontSize="14"
                                   TextWrapping="Wrap" VerticalAlignment="Center"/>
                    </Grid>
                </Border>

            </Grid>
        </Border>

    </Grid>
</UserControl>
