<telerik:RadWindow x:Class="HCB.UI.TopHighAlignInfoWindow"
                   xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                   xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                   xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
                   Style="{StaticResource RadWindowStyle}"
                   WindowStartupLocation="CenterOwner"
                   Width="900" Height="540"
                   ResizeMode="NoResize">

    <telerik:RadWindow.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/SYSTEM/COMMON/Styles/DefaultResource.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </telerik:RadWindow.Resources>

    <Grid Margin="12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="310"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ── 좌측: 좌표 정보 패널 ── -->
        <StackPanel Grid.Column="0" Margin="0,0,12,0">

            <TextBlock Text="마크 좌표 정보" FontSize="15" FontWeight="Bold"
                       Foreground="White" Margin="0,0,0,8"/>

            <!-- 테이블 헤더 -->
            <Border Background="#1E3A5F" CornerRadius="4,4,0,0" Padding="8,6">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="90"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="마크"    Foreground="#88CCFF" FontWeight="Bold" FontSize="12"/>
                    <TextBlock Grid.Column="1" Text="CenterX" Foreground="#88CCFF" FontWeight="Bold" FontSize="12"/>
                    <TextBlock Grid.Column="2" Text="CenterY" Foreground="#88CCFF" FontWeight="Bold" FontSize="12"/>
                </Grid>
            </Border>

            <!-- Right Fid -->
            <Border BorderBrush="#2A4A6A" BorderThickness="1,0,1,1" Padding="8,7">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="90"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <Ellipse Width="9" Height="9" Fill="Yellow" Margin="0,0,5,0" VerticalAlignment="Center"/>
                        <TextBlock Text="R. Fid" Foreground="White" FontSize="12"/>
                    </StackPanel>
                    <TextBlock x:Name="RightFidX" Grid.Column="1" Foreground="#AADDFF" FontFamily="Consolas" FontSize="12"/>
                    <TextBlock x:Name="RightFidY" Grid.Column="2" Foreground="#AADDFF" FontFamily="Consolas" FontSize="12"/>
                </Grid>
            </Border>

            <!-- Right Align -->
            <Border BorderBrush="#2A4A6A" BorderThickness="1,0,1,1" Padding="8,7">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="90"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <Ellipse Width="9" Height="9" Fill="Cyan" Margin="0,0,5,0" VerticalAlignment="Center"/>
                        <TextBlock Text="R. Align" Foreground="White" FontSize="12"/>
                    </StackPanel>
                    <TextBlock x:Name="RightAlignX" Grid.Column="1" Foreground="#AADDFF" FontFamily="Consolas" FontSize="12"/>
                    <TextBlock x:Name="RightAlignY" Grid.Column="2" Foreground="#AADDFF" FontFamily="Consolas" FontSize="12"/>
                </Grid>
            </Border>

            <!-- Left Fid -->
            <Border BorderBrush="#2A4A6A" BorderThickness="1,0,1,1" Padding="8,7">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="90"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <Ellipse Width="9" Height="9" Fill="Orange" Margin="0,0,5,0" VerticalAlignment="Center"/>
                        <TextBlock Text="L. Fid" Foreground="White" FontSize="12"/>
                    </StackPanel>
                    <TextBlock x:Name="LeftFidX" Grid.Column="1" Foreground="#AADDFF" FontFamily="Consolas" FontSize="12"/>
                    <TextBlock x:Name="LeftFidY" Grid.Column="2" Foreground="#AADDFF" FontFamily="Consolas" FontSize="12"/>
                </Grid>
            </Border>

            <!-- Left Align -->
            <Border BorderBrush="#2A4A6A" BorderThickness="1,0,1,1" Padding="8,7" CornerRadius="0,0,4,4">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="90"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <Ellipse Width="9" Height="9" Fill="LimeGreen" Margin="0,0,5,0" VerticalAlignment="Center"/>
                        <TextBlock Text="L. Align" Foreground="White" FontSize="12"/>
                    </StackPanel>
                    <TextBlock x:Name="LeftAlignX" Grid.Column="1" Foreground="#AADDFF" FontFamily="Consolas" FontSize="12"/>
                    <TextBlock x:Name="LeftAlignY" Grid.Column="2" Foreground="#AADDFF" FontFamily="Consolas" FontSize="12"/>
                </Grid>
            </Border>

            <!-- Align Theta -->
            <Border Background="#112030" CornerRadius="4" Margin="0,14,0,0" Padding="10,10">
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="θ  Align : " Foreground="#88CCFF" FontWeight="Bold" FontSize="16"/>
                        <TextBlock x:Name="ThetaValue" Foreground="White" FontWeight="Bold" FontSize="16" FontFamily="Consolas"/>
                    </StackPanel>
                    <TextBlock Text="= atan2 ( ΔY, ΔX )  [ L.Align → R.Align ]"
                               Foreground="#557799" FontSize="10" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <!-- Fiducial Theta -->
            <Border Background="#112030" CornerRadius="4" Margin="0,6,0,0" Padding="10,10">
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="θ  Fid    : " Foreground="#FFCC66" FontWeight="Bold" FontSize="16"/>
                        <TextBlock x:Name="ThetaFidValue" Foreground="White" FontWeight="Bold" FontSize="16" FontFamily="Consolas"/>
                    </StackPanel>
                    <TextBlock Text="= atan2 ( ΔY, ΔX )  [ L.Fid → R.Fid ]"
                               Foreground="#776644" FontSize="10" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <!-- 범례 -->
            <Border Background="#0D1E30" CornerRadius="4" Margin="0,8,0,0" Padding="8,8">
                <StackPanel>
                    <TextBlock Text="범례" Foreground="#88CCFF" FontSize="11" Margin="0,0,0,5"/>
                    <StackPanel Orientation="Horizontal" Margin="0,2">
                        <Ellipse Width="8" Height="8" Fill="Yellow"    Margin="0,0,5,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Right Fiducial" Foreground="#AAAAAA" FontSize="11"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,2">
                        <Ellipse Width="8" Height="8" Fill="Cyan"      Margin="0,0,5,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Right Align"    Foreground="#AAAAAA" FontSize="11"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,2">
                        <Ellipse Width="8" Height="8" Fill="Orange"    Margin="0,0,5,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Left Fiducial"  Foreground="#AAAAAA" FontSize="11"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,2">
                        <Ellipse Width="8" Height="8" Fill="LimeGreen" Margin="0,0,5,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Left Align"     Foreground="#AAAAAA" FontSize="11"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,6">
                        <Line X1="0" Y1="4" X2="20" Y2="4"
                              Stroke="#6488AA" StrokeThickness="1.5" StrokeDashArray="4 3"
                              Margin="0,0,5,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Fid → Align 연결선" Foreground="#AAAAAA" FontSize="11"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,2">
                        <Line X1="0" Y1="4" X2="20" Y2="4"
                              Stroke="DeepSkyBlue" StrokeThickness="2"
                              Margin="0,0,5,0" VerticalAlignment="Center"/>
                        <TextBlock Text="정렬 기준선 (L.Align→R.Align)" Foreground="#AAAAAA" FontSize="11"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>

        <!-- ── 우측: 그래프 캔버스 ── -->
        <Border Grid.Column="1" Background="#0D1E30" CornerRadius="6" ClipToBounds="True">
            <Canvas x:Name="GraphCanvas" SizeChanged="GraphCanvas_SizeChanged"/>
        </Border>
    </Grid>
</telerik:RadWindow>
