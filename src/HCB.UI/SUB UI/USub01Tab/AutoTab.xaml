<UserControl x:Class="HCB.UI.AutoTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
             xmlns:local="clr-namespace:HCB.UI"
             mc:Ignorable="d">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/SYSTEM/COMMON/Styles/DefaultResource.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <BooleanToVisibilityConverter x:Key="BoolToVis"/>
            <local:InverseBoolConverter x:Key="InverseBoolConverter"/>

            <!-- Dark ComboBoxItem Style -->
            <Style x:Key="DarkComboBoxItem" TargetType="ComboBoxItem">
                <Setter Property="Foreground" Value="#ECF0F1"/>
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Padding" Value="0"/>
                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ComboBoxItem">
                            <Border x:Name="Bg"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="4"
                                    Margin="4,2">
                                <ContentPresenter Margin="8,4"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bg" Property="Background" Value="#1C3A52"/>
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter TargetName="Bg" Property="Background" Value="#1E4A6A"/>
                                    <Setter TargetName="Bg" Property="BorderBrush" Value="#3498DB"/>
                                    <Setter TargetName="Bg" Property="BorderThickness" Value="1"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Dark ComboBox Style -->
            <Style x:Key="DarkComboBox" TargetType="ComboBox">
                <Setter Property="ItemContainerStyle" Value="{StaticResource DarkComboBoxItem}"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ComboBox">
                            <Grid>
                                <!-- 메인 버튼 영역 -->
                                <Border x:Name="MainBorder"
                                        Background="#0A1628"
                                        BorderBrush="#2A5A8C"
                                        BorderThickness="1"
                                        CornerRadius="6">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="36"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- 선택된 항목 표시 -->
                                        <ContentPresenter Grid.Column="0"
                                                          x:Name="ContentSite"
                                                          Content="{TemplateBinding SelectionBoxItem}"
                                                          ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                          IsHitTestVisible="False"
                                                          Margin="12,0,0,0"
                                                          VerticalAlignment="Center"/>

                                        <!-- 드롭다운 화살표 -->
                                        <ToggleButton Grid.Column="0" Grid.ColumnSpan="2"
                                                      IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                                      Background="Transparent"
                                                      BorderThickness="0"
                                                      Focusable="False"
                                                      ClickMode="Press">
                                            <ToggleButton.Template>
                                                <ControlTemplate TargetType="ToggleButton">
                                                    <Border Background="Transparent"/>
                                                </ControlTemplate>
                                            </ToggleButton.Template>
                                        </ToggleButton>

                                        <Path Grid.Column="1"
                                              x:Name="Arrow"
                                              Data="M 0 0 L 5 5 L 10 0"
                                              Stroke="#5E8BAA"
                                              StrokeThickness="1.5"
                                              StrokeLineJoin="Round"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              IsHitTestVisible="False"/>
                                    </Grid>
                                </Border>

                                <!-- 드롭다운 팝업 -->
                                <Popup x:Name="PART_Popup"
                                       IsOpen="{TemplateBinding IsDropDownOpen}"
                                       Placement="Bottom"
                                       Focusable="False"
                                       AllowsTransparency="True"
                                       PopupAnimation="Fade">
                                    <Border Background="#0A1628"
                                            BorderBrush="#2A5A8C"
                                            BorderThickness="1"
                                            CornerRadius="6"
                                            Margin="0,2,0,0"
                                            MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                            MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                        <ScrollViewer Margin="4">
                                            <ItemsPresenter/>
                                        </ScrollViewer>
                                    </Border>
                                </Popup>
                            </Grid>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="MainBorder" Property="BorderBrush" Value="#3498DB"/>
                                </Trigger>
                                <Trigger Property="IsDropDownOpen" Value="True">
                                    <Setter TargetName="MainBorder" Property="BorderBrush" Value="#3498DB"/>
                                    <Setter TargetName="Arrow" Property="Data" Value="M 0 5 L 5 0 L 10 5"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Margin="6" local:GridHelper.Columns="1*, 1*" local:GridHelper.Rows="1*, 1*">
        <!-- 1. Information -->
        <Border Background="#0D1B2A" CornerRadius="8" Margin="6"
                BorderBrush="#1C3A52" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <local:HeaderBar Margin="12,10,12,0" Title="Run Information"/>

                <!-- 구분선 -->
                <Rectangle Grid.Row="0" Height="1" Fill="#1C3A52"
                           VerticalAlignment="Bottom" Margin="12,32,12,0"/>

                <ItemsControl Grid.Row="1" ItemsSource="{Binding RunInfo}" Margin="0,4,0,8">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid Margin="16,10,16,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding Label}"
                                               Foreground="#5E8BAA"
                                               FontSize="20"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding Value}"
                                               Foreground="#ECF0F1"
                                               FontSize="20"
                                               FontWeight="SemiBold"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Grid>
                                <Rectangle Grid.Row="1" Height="1"
                                           Fill="#1C3A52" Margin="16,0"/>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>
        </Border>

        <Border Background="#0D1B2A" CornerRadius="8" Margin="6"
                BorderBrush="#1C3A52" BorderThickness="1" Grid.Column="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <local:HeaderBar Margin="12,10,12,0" Title="Running Status"/>
                <Rectangle Grid.Row="0" Height="1" Fill="#1C3A52"
                           VerticalAlignment="Bottom" Margin="12,32,12,0"/>

                <!-- 상태 항목들 -->
                <StackPanel Grid.Row="1" Margin="0,4,0,4">

                    <!-- Tact Time -->
                    <Grid Margin="16,10,16,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Tact Time"
                                   Foreground="#5E8BAA" FontSize="20"
                                   VerticalAlignment="Center"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="{Binding RunningStatus.TactTime}"
                                       Foreground="#ECF0F1" FontSize="20" FontWeight="SemiBold"/>
                            <TextBlock Text=" s" Foreground="#5E8BAA" FontSize="20" VerticalAlignment="Bottom" Margin="2,0,0,2"/>
                        </StackPanel>
                    </Grid>
                    <Rectangle Height="1" Fill="#1C3A52" Margin="16,0"/>

                    <!-- Bonding Accuracy -->
                    <Grid Margin="16,10,16,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Bonding Accuracy"
                                   Foreground="#5E8BAA" FontSize="20"
                                   VerticalAlignment="Center"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="{Binding RunningStatus.BondingAccuracy}"
                                       Foreground="#2ECC71" FontSize="20" FontWeight="SemiBold"/>
                            <TextBlock Text=" %" Foreground="#5E8BAA" FontSize="20" VerticalAlignment="Bottom" Margin="2,0,0,2"/>
                        </StackPanel>
                    </Grid>
                    <Rectangle Height="1" Fill="#1C3A52" Margin="16,0"/>

                    <!-- 총 소요시간 -->
                    <Grid Margin="16,10,16,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="총 소요시간"
                                   Foreground="#5E8BAA" FontSize="20"
                                   VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1"
                                   Text="{Binding RunningStatus.RunningTimeRange.ElapsedTime}"
                                   Foreground="#ECF0F1" FontSize="18" FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                    </Grid>
                    <Rectangle Height="1" Fill="#1C3A52" Margin="16,0"/>

                </StackPanel>

                <!-- 실시간 Accuracy Data 보기 버튼 -->
                <Button Grid.Row="2"
                        Margin="16,8,16,16"
                        Height="40"
                        Command="{Binding ShowAccuracyDataCommand}">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="#1A3A5C"/>
                            <Setter Property="Foreground" Value="#ECF0F1"/>
                            <Setter Property="FontSize" Value="22"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="BorderBrush" Value="#2A5A8C"/>
                            <Setter Property="BorderThickness" Value="1"/>
                            <Setter Property="Cursor" Value="Hand"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="6">
                                            <StackPanel Orientation="Horizontal"
                                                        HorizontalAlignment="Center"
                                                        VerticalAlignment="Center">
                                                <TextBlock Text="&#x1F4CA;" FontSize="14" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                                <TextBlock Text="실시간 Accuracy Data 보기"
                                                           Foreground="{TemplateBinding Foreground}"
                                                           FontSize="{TemplateBinding FontSize}"
                                                           FontWeight="{TemplateBinding FontWeight}"
                                                           VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#234E7A"/>
                                                <Setter Property="BorderBrush" Value="#3498DB"/>
                                            </Trigger>
                                            <Trigger Property="IsPressed" Value="True">
                                                <Setter Property="Background" Value="#0F2A45"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>

            </Grid>
        </Border>

        <!-- 3. Recipe -->
        <Border Background="#0D1B2A" CornerRadius="8" Margin="6"
                BorderBrush="#1C3A52" BorderThickness="1"
                Grid.Column="0" Grid.Row="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="1"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <local:HeaderBar Grid.Row="0" Margin="12,10,12,0" Title="Recipe"/>
                <Rectangle Grid.Row="0" Height="1" Fill="#1C3A52"
                           VerticalAlignment="Bottom" Margin="12,32,12,0"/>

                <!-- Recipe 선택 ComboBox -->
                <ComboBox Grid.Row="1"
                          Style="{StaticResource DarkComboBox}"
                          Margin="12,10,12,10"
                          Height="38"
                          FontSize="14"
                          Foreground="#ECF0F1"
                          MaxDropDownHeight="200"
                          ItemsSource="{Binding RecipeService.RecipeList}"
                          SelectedItem="{Binding SelectedRecipe, Mode=TwoWay}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="4,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding Name}"
                                           Foreground="#ECF0F1"
                                           FontSize="14"
                                           VerticalAlignment="Center"/>
                                <Border Grid.Column="1"
                                        CornerRadius="4" Padding="6,2"
                                        Background="#14452A"
                                        BorderBrush="#2ECC71" BorderThickness="1"
                                        VerticalAlignment="Center"
                                        Visibility="{Binding IsActive, Converter={StaticResource BoolToVis}}">
                                    <TextBlock Text="USE"
                                               Foreground="#2ECC71"
                                               FontSize="10" FontWeight="Bold"/>
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <!-- 구분선 -->
                <Rectangle Grid.Row="2" Fill="#1C3A52" Margin="12,0">
                    <Rectangle.Style>
                        <Style TargetType="Rectangle">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedRecipe}" Value="{x:Null}">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Rectangle.Style>
                </Rectangle>

                <!-- 파라미터 테이블 -->
                <Grid Grid.Row="3">
                    <Grid.Style>
                        <Style TargetType="Grid">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedRecipe}" Value="{x:Null}">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Style>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Margin="16,8,16,4"
                               Text="Parameters"
                               Foreground="#5E8BAA"
                               FontSize="12" FontWeight="SemiBold"/>

                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding SelectedRecipe.ParamList}"
                              Background="Transparent"
                              BorderThickness="0"
                              RowBackground="Transparent"
                              AlternatingRowBackground="#0A1628"
                              Foreground="#ECF0F1"
                              FontSize="18"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              CanUserResizeRows="False"
                              CanUserAddRows="False"
                              GridLinesVisibility="Horizontal"
                              HorizontalGridLinesBrush="#1C3A52"
                              RowHeaderWidth="0"
                              Margin="8,0,8,8">
                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader"
                                   BasedOn="{StaticResource {x:Type DataGridColumnHeader}}">
                                <Setter Property="Background" Value="#0A1628"/>
                                <Setter Property="Foreground" Value="#5E8BAA"/>
                                <Setter Property="FontSize" Value="14"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="BorderBrush" Value="#1C3A52"/>
                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                <Setter Property="Padding" Value="8,6"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>
                        <DataGrid.CellStyle>
                            <Style TargetType="DataGridCell"
                                   BasedOn="{StaticResource {x:Type DataGridCell}}">
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Padding" Value="8,4"/>
                            </Style>
                        </DataGrid.CellStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Name"  Binding="{Binding Name}"     Width="*"/>
                            <DataGridTextColumn Header="Value" Binding="{Binding Value}"    Width="0.6*"/>
                            <DataGridTextColumn Header="Unit"  Binding="{Binding UnitType}" Width="0.5*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>

            </Grid>
        </Border>

        <Border Background="#0D1B2A" CornerRadius="8" Margin="6"
                BorderBrush="#1C3A52" BorderThickness="1" Grid.Column="1" Grid.Row="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="1.6*"/>
                    <RowDefinition Height="1*"/>
                </Grid.RowDefinitions>

                <!-- Running Step -->
                <Grid Grid.Row="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <local:HeaderBar Margin="12,10,12,0" Title="Running Step"/>
                    <Rectangle Grid.Row="0" Height="1" Fill="#1C3A52"
                               VerticalAlignment="Bottom" Margin="12,32,12,0"/>

                    <!-- 5 Step 수평 인디케이터 -->
                    <Grid Grid.Row="1" Margin="12,0,12,0" VerticalAlignment="Center">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Step 1: Die wafer 얼라인 -->
                        <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                            <Border Width="32" Height="32" CornerRadius="16" HorizontalAlignment="Center" Margin="0,0,0,6">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="#1C3A52"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SequenceServiceVM.CurrentAutoStep}" Value="1">
                                                <Setter Property="Background" Value="#3498DB"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock Text="1" Foreground="White" FontSize="14" FontWeight="Bold"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Die wafer" TextAlignment="Center" FontSize="12" HorizontalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#5E8BAA"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SequenceServiceVM.CurrentAutoStep}" Value="1">
                                                <Setter Property="Foreground" Value="#ECF0F1"/>
                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <TextBlock Text="얼라인" TextAlignment="Center" FontSize="12" HorizontalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#5E8BAA"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SequenceServiceVM.CurrentAutoStep}" Value="1">
                                                <Setter Property="Foreground" Value="#ECF0F1"/>
                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>

                        <!-- Arrow 1→2 -->
                        <Path Grid.Column="1" Data="M 0 0 L 10 7 L 0 14"
                              Stroke="#2A5A8C" StrokeThickness="1.5" StrokeLineJoin="Round"
                              HorizontalAlignment="Center" VerticalAlignment="Top" Margin="4,9,4,0"
                              IsHitTestVisible="False"/>

                        <!-- Step 2: 픽업 -->
                        <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                            <Border Width="32" Height="32" CornerRadius="16" HorizontalAlignment="Center" Margin="0,0,0,6">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="#1C3A52"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SequenceServiceVM.CurrentAutoStep}" Value="2">
                                                <Setter Property="Background" Value="#3498DB"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock Text="2" Foreground="White" FontSize="14" FontWeight="Bold"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="픽업" TextAlignment="Center" FontSize="12" HorizontalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#5E8BAA"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SequenceServiceVM.CurrentAutoStep}" Value="2">
                                                <Setter Property="Foreground" Value="#ECF0F1"/>
                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>

                        <!-- Arrow 2→3 -->
                        <Path Grid.Column="3" Data="M 0 0 L 10 7 L 0 14"
                              Stroke="#2A5A8C" StrokeThickness="1.5" StrokeLineJoin="Round"
                              HorizontalAlignment="Center" VerticalAlignment="Top" Margin="4,9,4,0"
                              IsHitTestVisible="False"/>

                        <!-- Step 3: 픽업 다이 얼라인 -->
                        <StackPanel Grid.Column="4" HorizontalAlignment="Center">
                            <Border Width="32" Height="32" CornerRadius="16" HorizontalAlignment="Center" Margin="0,0,0,6">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="#1C3A52"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SequenceServiceVM.CurrentAutoStep}" Value="3">
                                                <Setter Property="Background" Value="#3498DB"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock Text="3" Foreground="White" FontSize="14" FontWeight="Bold"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="픽업 다이" TextAlignment="Center" FontSize="12" HorizontalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#5E8BAA"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SequenceServiceVM.CurrentAutoStep}" Value="3">
                                                <Setter Property="Foreground" Value="#ECF0F1"/>
                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <TextBlock Text="얼라인" TextAlignment="Center" FontSize="12" HorizontalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#5E8BAA"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SequenceServiceVM.CurrentAutoStep}" Value="3">
                                                <Setter Property="Foreground" Value="#ECF0F1"/>
                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>

                        <!-- Arrow 3→4 -->
                        <Path Grid.Column="5" Data="M 0 0 L 10 7 L 0 14"
                              Stroke="#2A5A8C" StrokeThickness="1.5" StrokeLineJoin="Round"
                              HorizontalAlignment="Center" VerticalAlignment="Top" Margin="4,9,4,0"
                              IsHitTestVisible="False"/>

                        <!-- Step 4: 웨이퍼 다이 얼라인 -->
                        <StackPanel Grid.Column="6" HorizontalAlignment="Center">
                            <Border Width="32" Height="32" CornerRadius="16" HorizontalAlignment="Center" Margin="0,0,0,6">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="#1C3A52"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SequenceServiceVM.CurrentAutoStep}" Value="4">
                                                <Setter Property="Background" Value="#3498DB"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock Text="4" Foreground="White" FontSize="14" FontWeight="Bold"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="웨이퍼 다이" TextAlignment="Center" FontSize="12" HorizontalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#5E8BAA"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SequenceServiceVM.CurrentAutoStep}" Value="4">
                                                <Setter Property="Foreground" Value="#ECF0F1"/>
                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <TextBlock Text="얼라인" TextAlignment="Center" FontSize="12" HorizontalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#5E8BAA"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SequenceServiceVM.CurrentAutoStep}" Value="4">
                                                <Setter Property="Foreground" Value="#ECF0F1"/>
                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>

                        <!-- Arrow 4→5 -->
                        <Path Grid.Column="7" Data="M 0 0 L 10 7 L 0 14"
                              Stroke="#2A5A8C" StrokeThickness="1.5" StrokeLineJoin="Round"
                              HorizontalAlignment="Center" VerticalAlignment="Top" Margin="4,9,4,0"
                              IsHitTestVisible="False"/>

                        <!-- Step 5: 본딩 -->
                        <StackPanel Grid.Column="8" HorizontalAlignment="Center">
                            <Border Width="32" Height="32" CornerRadius="16" HorizontalAlignment="Center" Margin="0,0,0,6">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="#1C3A52"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SequenceServiceVM.CurrentAutoStep}" Value="5">
                                                <Setter Property="Background" Value="#3498DB"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock Text="5" Foreground="White" FontSize="14" FontWeight="Bold"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="본딩" TextAlignment="Center" FontSize="12" HorizontalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#5E8BAA"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SequenceServiceVM.CurrentAutoStep}" Value="5">
                                                <Setter Property="Foreground" Value="#ECF0F1"/>
                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>

                    </Grid>
                </Grid>

                <!-- Buttons: Init / Start / Reset / Stop -->
                <Grid Grid.Row="1" Margin="12,8,12,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Init -->
                    <Button Grid.Column="0" Command="{Binding MachineInitCommand}"
                            IsEnabled="{Binding IsInitializing, Converter={StaticResource InverseBoolConverter}}">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="#0F3460"/>
                                <Setter Property="BorderBrush" Value="#2A5A8C"/>
                                <Setter Property="BorderThickness" Value="1"/>
                                <Setter Property="Foreground" Value="#ECF0F1"/>
                                <Setter Property="FontSize" Value="18"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="Cursor" Value="Hand"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    CornerRadius="6">
                                                <TextBlock Text="Init"
                                                           Foreground="{TemplateBinding Foreground}"
                                                           FontSize="{TemplateBinding FontSize}"
                                                           FontWeight="{TemplateBinding FontWeight}"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#1A4A7A"/>
                                                    <Setter Property="BorderBrush" Value="#3498DB"/>
                                                </Trigger>
                                                <Trigger Property="IsPressed" Value="True">
                                                    <Setter Property="Background" Value="#0A2040"/>
                                                </Trigger>
                                                <Trigger Property="IsEnabled" Value="False">
                                                    <Setter Property="Background" Value="#0A1628"/>
                                                    <Setter Property="BorderBrush" Value="#1C3A52"/>
                                                    <Setter Property="Foreground" Value="#3A5A7A"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>

                    <!-- Start -->
                    <Button Grid.Column="2" Command="{Binding MachineRunCommand}"
                            IsEnabled="{Binding IsRunning, Converter={StaticResource InverseBoolConverter}}">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="#0F3D20"/>
                                <Setter Property="BorderBrush" Value="#27AE60"/>
                                <Setter Property="BorderThickness" Value="1"/>
                                <Setter Property="Foreground" Value="#ECF0F1"/>
                                <Setter Property="FontSize" Value="18"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="Cursor" Value="Hand"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    CornerRadius="6">
                                                <TextBlock Text="Start"
                                                           Foreground="{TemplateBinding Foreground}"
                                                           FontSize="{TemplateBinding FontSize}"
                                                           FontWeight="{TemplateBinding FontWeight}"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#1A5A30"/>
                                                    <Setter Property="BorderBrush" Value="#2ECC71"/>
                                                </Trigger>
                                                <Trigger Property="IsPressed" Value="True">
                                                    <Setter Property="Background" Value="#082010"/>
                                                </Trigger>
                                                <Trigger Property="IsEnabled" Value="False">
                                                    <Setter Property="Background" Value="#0A1628"/>
                                                    <Setter Property="BorderBrush" Value="#1C3A52"/>
                                                    <Setter Property="Foreground" Value="#3A5A7A"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>

                    <!-- Reset -->
                    <Button Grid.Column="4" Command="{Binding MachineResetCommand}">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="#3D2A0F"/>
                                <Setter Property="BorderBrush" Value="#E67E22"/>
                                <Setter Property="BorderThickness" Value="1"/>
                                <Setter Property="Foreground" Value="#ECF0F1"/>
                                <Setter Property="FontSize" Value="18"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="Cursor" Value="Hand"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    CornerRadius="6">
                                                <TextBlock Text="Reset"
                                                           Foreground="{TemplateBinding Foreground}"
                                                           FontSize="{TemplateBinding FontSize}"
                                                           FontWeight="{TemplateBinding FontWeight}"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#5A3D18"/>
                                                    <Setter Property="BorderBrush" Value="#F39C12"/>
                                                </Trigger>
                                                <Trigger Property="IsPressed" Value="True">
                                                    <Setter Property="Background" Value="#201508"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>

                    <!-- Stop -->
                    <Button Grid.Column="6" Command="{Binding MachineStopCommand}"
                            IsEnabled="{Binding IsRunning}">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="#3D0F0F"/>
                                <Setter Property="BorderBrush" Value="#E74C3C"/>
                                <Setter Property="BorderThickness" Value="1"/>
                                <Setter Property="Foreground" Value="#ECF0F1"/>
                                <Setter Property="FontSize" Value="18"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="Cursor" Value="Hand"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    CornerRadius="6">
                                                <TextBlock Text="Stop"
                                                           Foreground="{TemplateBinding Foreground}"
                                                           FontSize="{TemplateBinding FontSize}"
                                                           FontWeight="{TemplateBinding FontWeight}"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#5A1818"/>
                                                    <Setter Property="BorderBrush" Value="#FF6B6B"/>
                                                </Trigger>
                                                <Trigger Property="IsPressed" Value="True">
                                                    <Setter Property="Background" Value="#200808"/>
                                                </Trigger>
                                                <Trigger Property="IsEnabled" Value="False">
                                                    <Setter Property="Background" Value="#0A1628"/>
                                                    <Setter Property="BorderBrush" Value="#1C3A52"/>
                                                    <Setter Property="Foreground" Value="#3A5A7A"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>

                </Grid>

            </Grid>
        </Border>
        
    </Grid>


</UserControl>
