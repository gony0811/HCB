<UserControl x:Class="HCB.UI.LoadingTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
             xmlns:local="clr-namespace:HCB.UI"
             mc:Ignorable="d"
             Background="#FF1A1A2E">

    <UserControl.Resources>

        <!-- ── 탭 버튼 스타일 (ManualTab 동일) ── -->
        <Style x:Key="LoadingTabButton" TargetType="RadioButton">
            <Setter Property="Foreground" Value="#5E8BAA"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="20,0"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Bd"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="0,0,0,2"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#2A5A8C"/>
                                <Setter Property="Foreground" Value="#ECF0F1"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#3498DB"/>
                                <Setter Property="Foreground" Value="#ECF0F1"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── 메인 버튼 스타일 ── -->
        <Style x:Key="LoadingButtonStyle" TargetType="telerik:RadButton">
            <Setter Property="Margin"          Value="8,6"/>
            <Setter Property="FontSize"        Value="28"/>
            <Setter Property="FontWeight"      Value="Bold"/>
            <Setter Property="FontFamily"      Value="Segoe UI"/>
            <Setter Property="Foreground"      Value="#FFE0E0E0"/>
            <Setter Property="Background"      Value="#FF16213E"/>
            <Setter Property="BorderBrush"     Value="#FF0F3460"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="telerik:RadButton">
                        <Border x:Name="PART_Border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="14">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="PART_Border" Property="Background"  Value="#FF0F3460"/>
                                <Setter TargetName="PART_Border" Property="BorderBrush" Value="#FF533483"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="PART_Border" Property="Background"  Value="#FF533483"/>
                                <Setter TargetName="PART_Border" Property="BorderBrush" Value="#FFE94560"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── 전체 Off 강조 스타일 ── -->
        <Style x:Key="DangerButtonStyle" TargetType="telerik:RadButton" BasedOn="{StaticResource LoadingButtonStyle}">
            <Setter Property="Background"  Value="#FF2A0A14"/>
            <Setter Property="BorderBrush" Value="#FFE94560"/>
            <Setter Property="Foreground"  Value="#FFE94560"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="telerik:RadButton">
                        <Border x:Name="PART_Border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="14">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="PART_Border" Property="Background"  Value="#FF4A0A20"/>
                                <Setter TargetName="PART_Border" Property="BorderBrush" Value="#FFFF6080"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="PART_Border" Property="Background"  Value="#FFE94560"/>
                                <Setter TargetName="PART_Border" Property="BorderBrush" Value="#FFFFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </UserControl.Resources>

    <!-- ══ 루트 컨테이너 ══ -->
    <Border Background="#0D1B2A" BorderBrush="#1C3A52" BorderThickness="1" CornerRadius="8" Margin="6">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>  <!-- 탭 헤더 -->
                <RowDefinition Height="1"/>     <!-- 구분선 -->
                <RowDefinition Height="*"/>     <!-- 탭 컨텐츠 -->
            </Grid.RowDefinitions>

            <!-- 구분선 -->
            <Rectangle Grid.Row="1" Fill="#1C3A52" Margin="12,0"/>

            <!-- ══ D-TABLE 컨텐츠 ══ -->
            <Grid x:Name="TabDTable" Grid.Row="2" Margin="20,10,20,20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>  <!-- D Load / D Ready -->
                    <RowDefinition Height="Auto"/>  <!-- Top / Btm 헤더 -->
                    <RowDefinition Height="*"/>     <!-- 1번 -->
                    <RowDefinition Height="*"/>     <!-- 2번 -->
                    <RowDefinition Height="*"/>     <!-- 3번 -->
                    <RowDefinition Height="*"/>     <!-- 4번 -->
                    <RowDefinition Height="Auto"/>  <!-- 전체 On / Off -->
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>   <!-- Top -->
                    <ColumnDefinition Width="*"/>   <!-- Btm -->
                </Grid.ColumnDefinitions>
                <Grid Grid.Row="0" Margin="16,14,16,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Background="#1A3A5C" CornerRadius="4" Padding="10,4"
                            VerticalAlignment="Center" Margin="0,0,12,0">
                        <TextBlock Text="D TABLE" Foreground="#3498DB" FontSize="13" FontWeight="Bold"/>
                    </Border>
                    <TextBlock Grid.Column="1" Text="Die Loading"
                                Foreground="#ECF0F1" FontSize="20" FontWeight="Bold" VerticalAlignment="Center"/>
                </Grid>
                <!-- D Load / D Ready -->
                <telerik:RadButton Grid.Row="1" Grid.Column="0"
                                   Content="D Load"
                                   Command="{Binding DTableLoadingCommand}"
                                   local:BlinkBehavior.IsBlinking="{Binding IsDTableLoading}"
                                   Style="{StaticResource LoadingButtonStyle}"
                                   FontSize="20" Height="60"/>
                <telerik:RadButton Grid.Row="1" Grid.Column="1"
                                   Content="D Ready"
                                   Command="{Binding DTableReadyCommand}"
                                   local:BlinkBehavior.IsBlinking="{Binding IsDTableStandby}"
                                   Style="{StaticResource LoadingButtonStyle}"
                                   FontSize="20" Height="60"/>

                <!-- 1번 -->
                <telerik:RadButton x:Name="DTopBtn1" Grid.Row="2" Grid.Column="0" Content="Top #1" Tag="1" Click="DTopButton_Click" Style="{StaticResource LoadingButtonStyle}"/>
                <telerik:RadButton x:Name="DBtmBtn1" Grid.Row="2" Grid.Column="1" Content="Btm #1" Tag="1" Click="DBtmButton_Click" Style="{StaticResource LoadingButtonStyle}"/>
                <!-- 2번 -->
                <telerik:RadButton x:Name="DTopBtn2" Grid.Row="3" Grid.Column="0" Content="Top #2" Tag="2" Click="DTopButton_Click" Style="{StaticResource LoadingButtonStyle}"/>
                <telerik:RadButton x:Name="DBtmBtn2" Grid.Row="3" Grid.Column="1" Content="Btm #2" Tag="2" Click="DBtmButton_Click" Style="{StaticResource LoadingButtonStyle}"/>
                <!-- 3번 -->
                <telerik:RadButton x:Name="DTopBtn3" Grid.Row="4" Grid.Column="0" Content="Top #3" Tag="3" Click="DTopButton_Click" Style="{StaticResource LoadingButtonStyle}"/>
                <telerik:RadButton x:Name="DBtmBtn3" Grid.Row="4" Grid.Column="1" Content="Btm #3" Tag="3" Click="DBtmButton_Click" Style="{StaticResource LoadingButtonStyle}"/>
                <!-- 4번 -->
                <telerik:RadButton x:Name="DTopBtn4" Grid.Row="5" Grid.Column="0" Content="Top #4" Tag="4" Click="DTopButton_Click" Style="{StaticResource LoadingButtonStyle}"/>
                <telerik:RadButton x:Name="DBtmBtn4" Grid.Row="5" Grid.Column="1" Content="Btm #4" Tag="4" Click="DBtmButton_Click" Style="{StaticResource LoadingButtonStyle}"/>

                <!-- 전체 On / Off -->
                <telerik:RadButton Grid.Row="6" Grid.Column="0"
                                   Content="전체 On"
                                   Command="{Binding DieAllOnCommand}"
                                   Style="{StaticResource LoadingButtonStyle}"
                                   FontSize="20" Height="60"/>
                <telerik:RadButton Grid.Row="6" Grid.Column="1"
                                   Content="전체 Off"
                                   Command="{Binding DieAllOffCommand}"
                                   Style="{StaticResource DangerButtonStyle}"
                                   FontSize="20" Height="60"/>
            </Grid>

            <!-- ══ W-TABLE 컨텐츠 ══ -->
            <Grid x:Name="TabWTable" Grid.Row="2" Visibility="Collapsed" Margin="20,10,20,20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>  <!-- W Load / W Working -->
                    <RowDefinition Height="Auto"/>  <!-- Top / Btm 헤더 -->
                    <RowDefinition Height="*"/>     <!-- 1번 -->
                    <RowDefinition Height="*"/>     <!-- 2번 -->
                    <RowDefinition Height="*"/>     <!-- 3번 -->
                    <RowDefinition Height="*"/>     <!-- 4번 -->
                    <RowDefinition Height="Auto"/>  <!-- 전체 On / Off -->
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>   <!-- Top -->
                    <ColumnDefinition Width="*"/>   <!-- Btm -->
                </Grid.ColumnDefinitions>

                <!-- W Load / W Working -->
                <telerik:RadButton Grid.Row="0" Grid.Column="0"
                                   Content="W Load"
                                   Command="{Binding WTableLoadingCommand}"
                                   local:BlinkBehavior.IsBlinking="{Binding IsWTableLoading}"
                                   Style="{StaticResource LoadingButtonStyle}"
                                   FontSize="20" Height="60"/>
                <telerik:RadButton Grid.Row="0" Grid.Column="1"
                                   Content="W Working"
                                   Command="{Binding WTableReadyCommand}"
                                   local:BlinkBehavior.IsBlinking="{Binding IsWTableStandby}"
                                   Style="{StaticResource LoadingButtonStyle}"
                                   FontSize="20" Height="60"/>

                <!-- 컬럼 헤더 -->
                <TextBlock Grid.Row="1" Grid.Column="0" Text="Top"
                           FontFamily="Segoe UI" FontSize="18" FontWeight="SemiBold"
                           Foreground="#FF1E88E5" HorizontalAlignment="Center" Margin="0,8,0,4"/>
                <TextBlock Grid.Row="1" Grid.Column="1" Text="Btm"
                           FontFamily="Segoe UI" FontSize="18" FontWeight="SemiBold"
                           Foreground="#FFE94560" HorizontalAlignment="Center" Margin="0,8,0,4"/>

                <!-- 1번 -->
                <telerik:RadButton x:Name="WTopBtn1" Grid.Row="2" Grid.Column="0" Content="Top 1" Tag="1" Click="WTopButton_Click" Style="{StaticResource LoadingButtonStyle}"/>
                <telerik:RadButton x:Name="WBtmBtn1" Grid.Row="2" Grid.Column="1" Content="Btm 1" Tag="1" Click="WBtmButton_Click" Style="{StaticResource LoadingButtonStyle}"/>
                <!-- 2번 -->
                <telerik:RadButton x:Name="WTopBtn2" Grid.Row="3" Grid.Column="0" Content="Top 2" Tag="2" Click="WTopButton_Click" Style="{StaticResource LoadingButtonStyle}"/>
                <telerik:RadButton x:Name="WBtmBtn2" Grid.Row="3" Grid.Column="1" Content="Btm 2" Tag="2" Click="WBtmButton_Click" Style="{StaticResource LoadingButtonStyle}"/>
                <!-- 3번 -->
                <telerik:RadButton x:Name="WTopBtn3" Grid.Row="4" Grid.Column="0" Content="Top 3" Tag="3" Click="WTopButton_Click" Style="{StaticResource LoadingButtonStyle}"/>
                <telerik:RadButton x:Name="WBtmBtn3" Grid.Row="4" Grid.Column="1" Content="Btm 3" Tag="3" Click="WBtmButton_Click" Style="{StaticResource LoadingButtonStyle}"/>
                <!-- 4번 -->
                <telerik:RadButton x:Name="WTopBtn4" Grid.Row="5" Grid.Column="0" Content="Top 4" Tag="4" Click="WTopButton_Click" Style="{StaticResource LoadingButtonStyle}"/>
                <telerik:RadButton x:Name="WBtmBtn4" Grid.Row="5" Grid.Column="1" Content="Btm 4" Tag="4" Click="WBtmButton_Click" Style="{StaticResource LoadingButtonStyle}"/>

                <!-- 전체 On / Off -->
                <telerik:RadButton Grid.Row="6" Grid.Column="0"
                                   Content="전체 On"
                                   Command="{Binding WaferAllOnCommand}"
                                   Style="{StaticResource LoadingButtonStyle}"
                                   FontSize="20" Height="60"/>
                <telerik:RadButton Grid.Row="6" Grid.Column="1"
                                   Content="전체 Off"
                                   Command="{Binding WaferAllOffCommand}"
                                   Style="{StaticResource DangerButtonStyle}"
                                   FontSize="20" Height="60"/>
            </Grid>

        </Grid>
    </Border>

</UserControl>
