<telerik:RadWindow x:Class="HCB.UI.BondingInfoWindow"
                   xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                   xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                   xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
                   Style="{StaticResource RadWindowStyle}"
                   WindowStartupLocation="CenterOwner"
                   Width="940" Height="580"
                   ResizeMode="NoResize">

    <telerik:RadWindow.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/SYSTEM/COMMON/Styles/DefaultResource.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <Style x:Key="InputLabel" TargetType="TextBlock">
                <Setter Property="Foreground" Value="#88CCFF"/>
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Margin" Value="0,0,0,4"/>
            </Style>

            <Style x:Key="InputBox" TargetType="TextBox">
                <Setter Property="Background" Value="#0A1628"/>
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="BorderBrush" Value="#2A5A8C"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Padding" Value="8,6"/>
                <Setter Property="FontFamily" Value="Consolas"/>
                <Setter Property="FontSize" Value="15"/>
                <Setter Property="CaretBrush" Value="White"/>
            </Style>

            <Style x:Key="UnitLabel" TargetType="TextBlock">
                <Setter Property="Foreground" Value="#5E8BAA"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
                <Setter Property="Margin" Value="6,0,0,0"/>
            </Style>

        </ResourceDictionary>
    </telerik:RadWindow.Resources>

    <Grid Margin="12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="290"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ── 좌측: 설정 패널 ── -->
        <StackPanel Grid.Column="0" Margin="0,0,12,0">

            <TextBlock Text="공정 파라미터 설정" FontSize="14" FontWeight="Bold"
                       Foreground="White" Margin="0,0,0,12"/>

            <!-- Bonding Force -->
            <Border Background="#0A1628" CornerRadius="6" Padding="10,10" Margin="0,0,0,10">
                <StackPanel>
                    <TextBlock Style="{StaticResource InputLabel}" Text="Bonding Force"/>
                    <StackPanel Orientation="Horizontal">
                        <TextBox x:Name="ForceTextBox" Style="{StaticResource InputBox}"
                                 Width="160" TextChanged="ForceTextBox_TextChanged"/>
                        <TextBlock Style="{StaticResource UnitLabel}" Text="N"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                        <TextBlock Text="범위: " Foreground="#446688" FontSize="10"/>
                        <TextBlock x:Name="ForceRangeText" Foreground="#446688" FontSize="10"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Bonding Time -->
            <Border Background="#0A1628" CornerRadius="6" Padding="10,10" Margin="0,0,0,10">
                <StackPanel>
                    <TextBlock Style="{StaticResource InputLabel}" Text="Bonding Time"/>
                    <StackPanel Orientation="Horizontal">
                        <TextBox x:Name="TimeTextBox" Style="{StaticResource InputBox}"
                                 Width="160" TextChanged="TimeTextBox_TextChanged"/>
                        <TextBlock Style="{StaticResource UnitLabel}" Text="s"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                        <TextBlock Text="범위: " Foreground="#446688" FontSize="10"/>
                        <TextBlock x:Name="TimeRangeText" Foreground="#446688" FontSize="10"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- 종료 시점 -->
            <Border Background="#112030" CornerRadius="6" Padding="10,10" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Style="{StaticResource InputLabel}" Text="종료 시점 (End Point)"/>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="T = " Foreground="#5E8BAA" FontSize="14"/>
                        <TextBlock x:Name="EndTimeDisplay" Foreground="White"
                                   FontFamily="Consolas" FontSize="14" FontWeight="Bold"/>
                        <TextBlock Text=" s" Foreground="#5E8BAA" FontSize="14"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Rectangle Height="1" Fill="#1C3A52" Margin="0,0,0,12"/>

            <!-- Recipe 연동 -->
            <Border Background="#0D1E30" CornerRadius="6" Padding="10,10" Margin="0,0,0,10">
                <StackPanel>
                    <TextBlock Style="{StaticResource InputLabel}" Text="적용 Recipe"/>
                    <TextBlock x:Name="RecipeNameText"
                               Foreground="#2ECC71" FontSize="13" FontWeight="SemiBold"
                               Text="(없음)" TextTrimming="CharacterEllipsis"/>
                </StackPanel>
            </Border>

            <telerik:RadButton x:Name="SaveButton"
                               Content="Recipe에 저장"
                               Height="40"
                               HorizontalContentAlignment="Center"
                               VerticalContentAlignment="Center"
                               Style="{StaticResource RadButtonStyle}"
                               Click="SaveButton_Click"
                               Margin="0,0,0,8"/>

            <!-- 저장 상태 메시지 -->
            <Border x:Name="StatusBorder" CornerRadius="4" Padding="8,6"
                    Background="#112030" Visibility="Collapsed">
                <TextBlock x:Name="StatusText" FontSize="12" TextWrapping="Wrap"
                           HorizontalAlignment="Center" TextAlignment="Center"/>
            </Border>

            <!-- 범례 -->
            <Border Background="#0A1220" CornerRadius="4" Padding="8,8" Margin="0,12,0,0">
                <StackPanel>
                    <TextBlock Text="범례" Foreground="#88CCFF" FontSize="11" Margin="0,0,0,5"/>
                    <StackPanel Orientation="Horizontal" Margin="0,2">
                        <Rectangle Width="18" Height="3" Fill="#3498DB" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="설정 Force 프로파일" Foreground="#AAAAAA" FontSize="11"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,2">
                        <Rectangle Width="18" Height="3" Fill="#E74C3C" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="실제 측정 데이터" Foreground="#AAAAAA" FontSize="11"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,2">
                        <Line X1="0" Y1="3" X2="18" Y2="3" Stroke="#F1C40F"
                              StrokeThickness="1.5" StrokeDashArray="4 3"
                              Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock Text="종료 시점 (T)" Foreground="#AAAAAA" FontSize="11"/>
                    </StackPanel>
                </StackPanel>
            </Border>

        </StackPanel>

        <!-- ── 우측: 그래프 캔버스 ── -->
        <Border Grid.Column="1" Background="#0D1E30" CornerRadius="6" ClipToBounds="True">
            <Canvas x:Name="GraphCanvas" SizeChanged="GraphCanvas_SizeChanged"/>
        </Border>
    </Grid>
</telerik:RadWindow>
