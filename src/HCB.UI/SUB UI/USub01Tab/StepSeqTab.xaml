<UserControl x:Class="HCB.UI.StepSeqTab"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
      xmlns:local="clr-namespace:HCB.UI"
      mc:Ignorable="d" 
      >
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/SYSTEM/COMMON/Styles/DefaultResource.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <telerik:RadTabControl Style="{StaticResource RadTabControlStyle}">
        <telerik:RadTabItem Style="{StaticResource RadTabItemStyle}" Header="0. Setting" Margin="1">
            <StackPanel>
            
            </StackPanel>

        </telerik:RadTabItem>
                           
        <telerik:RadTabItem Style="{StaticResource RadTabItemStyle}" Header="1. INITIALIZE" Margin="1">
            <Grid local:GridHelper.Rows="Auto, *, Auto"  Margin="20" >
                <StackPanel Grid.Row="0">
                    <TextBlock Text="Initialize" FontSize="28" FontWeight="Bold" Foreground="#4A69BD"/>
                    <Rectangle Height="2" Fill="#3498DB" Margin="0,5,0,0"/>
                    <TextBlock Text="시스템 초기화" FontSize="14" Foreground="#7F8C8D" Margin="0,5,0,20"/>
                    <telerik:RadProgressBar Value="{Binding SequenceServiceVM.InitializeProgress}" 
                                            Maximum="100" 
                                            Minimum="0" Height="20" />
                </StackPanel>

                <Grid local:GridHelper.Columns="1*, 1*, 1*" Grid.Row="1">
                    <telerik:GroupBox Style="{StaticResource GroupBoxStyle}" Header="System" FontSize="18" Grid.Column="0" Margin="2">
                        <StackPanel>
                            <WrapPanel Orientation="Horizontal" Margin="{StaticResource ControlMargin}">
                                <local:StepLamp Style="{StaticResource StepLampStyle}"  State="{Binding SequenceServiceVM.SystemCheck}" Margin="{StaticResource ControlMargin}"/>
                                <telerik:HighlightTextBlock Style="{StaticResource HighlightTextBlockStyle}" Text="System Check" FontSize="16" Width="150" Margin="{StaticResource ControlMargin}"/>
                                <telerik:HighlightTextBlock Style="{StaticResource HighlightTextBlockStyle}" Text="{Binding SequenceServiceVM.StepWaferCenterMoveElapsedTime}" Width="100" Margin="{StaticResource ControlMargin}"/>
                            </WrapPanel>

                            <WrapPanel Orientation="Horizontal" Margin="{StaticResource ControlMargin}">
                                <local:StepLamp Style="{StaticResource StepLampStyle}" State="{Binding SequenceServiceVM.ServoOn}" Margin="{StaticResource ControlMargin}"/>
                                <telerik:HighlightTextBlock Style="{StaticResource HighlightTextBlockStyle}" Text="Servo On" FontSize="16" Width="150" Margin="{StaticResource ControlMargin}"/>
                                <telerik:HighlightTextBlock Style="{StaticResource HighlightTextBlockStyle}" Text="{Binding SequenceServiceVM.StepWaferCenterMoveElapsedTime}" Width="100" Margin="{StaticResource ControlMargin}"/>
                            </WrapPanel>
                            <WrapPanel Orientation="Horizontal" Margin="{StaticResource ControlMargin}">
                                <local:StepLamp Style="{StaticResource StepLampStyle}" State="{Binding SequenceServiceVM.HZBreakOff}" Margin="{StaticResource ControlMargin}"/>
                                <telerik:HighlightTextBlock Style="{StaticResource HighlightTextBlockStyle}" Text="H-Z Break Off" FontSize="16" Width="150" Margin="{StaticResource ControlMargin}"/>
                                <telerik:HighlightTextBlock Style="{StaticResource HighlightTextBlockStyle}" Text="{Binding SequenceServiceVM.StepWaferCenterMoveElapsedTime}" Width="100" Margin="{StaticResource ControlMargin}"/>
                            </WrapPanel>
                        </StackPanel>
                    </telerik:GroupBox>
                    <telerik:GroupBox Style="{StaticResource GroupBoxStyle}" Header="H-Axis Home" FontSize="18" Grid.Column="1" Margin="2">
                        <StackPanel>
                            <WrapPanel Orientation="Horizontal" Margin="{StaticResource ControlMargin}">
                                <local:StepLamp Style="{StaticResource StepLampStyle}" State="{Binding SequenceServiceVM.HZHome}" Margin="{StaticResource ControlMargin}"/>
                                <telerik:HighlightTextBlock Style="{StaticResource HighlightTextBlockStyle}" Text="H-Z Home 이동" FontSize="16"  Margin="{StaticResource ControlMargin}"/>
                                <telerik:HighlightTextBlock Style="{StaticResource HighlightTextBlockStyle}" Text="{Binding SequenceServiceVM.StepWaferCenterMoveElapsedTime}" Width="100" Margin="{StaticResource ControlMargin}"/>
                            </WrapPanel>
                            <WrapPanel Orientation="Horizontal" Margin="{StaticResource ControlMargin}">
                                <local:StepLamp Style="{StaticResource StepLampStyle}" State="{Binding SequenceServiceVM.HzHome}" Margin="{StaticResource ControlMargin}"/>
                                <telerik:HighlightTextBlock Style="{StaticResource HighlightTextBlockStyle}" Text="h-z Home 이동" FontSize="16" Margin="{StaticResource ControlMargin}"/>
                                <telerik:HighlightTextBlock Style="{StaticResource HighlightTextBlockStyle}" Text="{Binding SequenceServiceVM.StepWaferCenterMoveElapsedTime}" Width="100" Margin="{StaticResource ControlMargin}"/>
                            </WrapPanel>
                            <WrapPanel Orientation="Horizontal" Margin="{StaticResource ControlMargin}">
                                <local:StepLamp Style="{StaticResource StepLampStyle}" State="{Binding SequenceServiceVM.HXHome}" Margin="{StaticResource ControlMargin}"/>
                                <telerik:HighlightTextBlock Style="{StaticResource HighlightTextBlockStyle}" Text="H-X Home 이동" FontSize="16"  Margin="{StaticResource ControlMargin}"/>
                                <telerik:HighlightTextBlock Style="{StaticResource HighlightTextBlockStyle}" Text="{Binding SequenceServiceVM.StepWaferCenterMoveElapsedTime}" Width="100" Margin="{StaticResource ControlMargin}"/>
                            </WrapPanel>
                            <WrapPanel Orientation="Horizontal" Margin="{StaticResource ControlMargin}">
                                <local:StepLamp Style="{StaticResource StepLampStyle}" State="{Binding SequenceServiceVM.HTHome}" Margin="{StaticResource ControlMargin}"/>
                                <telerik:HighlightTextBlock Style="{StaticResource HighlightTextBlockStyle}" Text="H-T Home 이동" FontSize="16" Margin="{StaticResource ControlMargin}"/>
                                <telerik:HighlightTextBlock Style="{StaticResource HighlightTextBlockStyle}" Text="{Binding SequenceServiceVM.StepWaferCenterMoveElapsedTime}" Width="100" Margin="{StaticResource ControlMargin}"/>
                            </WrapPanel>
                        </StackPanel>
                    </telerik:GroupBox>
                    <telerik:GroupBox Style="{StaticResource GroupBoxStyle}" Header="Y-Axis Home" FontSize="18" Grid.Column="2" Margin="2">
                        <StackPanel>
                            <WrapPanel Orientation="Horizontal" Margin="{StaticResource ControlMargin}">
                                <local:StepLamp Style="{StaticResource StepLampStyle}" State="{Binding SequenceServiceVM.DYHome}" Margin="{StaticResource ControlMargin}"/>
                                <telerik:HighlightTextBlock Style="{StaticResource HighlightTextBlockStyle}" Text="D-Y Home 이동" FontSize="16"  Margin="{StaticResource ControlMargin}"/>
                                <telerik:HighlightTextBlock Style="{StaticResource HighlightTextBlockStyle}" Text="{Binding SequenceServiceVM.StepWaferCenterMoveElapsedTime}" Width="100" Margin="{StaticResource ControlMargin}"/>
                            </WrapPanel>

                            <WrapPanel Orientation="Horizontal" Margin="{StaticResource ControlMargin}">
                                <local:StepLamp Style="{StaticResource StepLampStyle}" State="{Binding SequenceServiceVM.PYHome}" Margin="{StaticResource ControlMargin}"/>
                                <telerik:HighlightTextBlock Style="{StaticResource HighlightTextBlockStyle}" Text="P-Y Home 이동" FontSize="16" Margin="{StaticResource ControlMargin}"/>
                                <telerik:HighlightTextBlock Style="{StaticResource HighlightTextBlockStyle}" Text="{Binding SequenceServiceVM.StepWaferCenterMoveElapsedTime}" Width="100" Margin="{StaticResource ControlMargin}"/>
                            </WrapPanel>
                            
                            <WrapPanel Orientation="Horizontal" Margin="{StaticResource ControlMargin}">
                                <local:StepLamp Style="{StaticResource StepLampStyle}" State="{Binding SequenceServiceVM.WYHome}" Margin="{StaticResource ControlMargin}"/>
                                <telerik:HighlightTextBlock Style="{StaticResource HighlightTextBlockStyle}" Text="W-Y Home 이동" FontSize="16" Margin="{StaticResource ControlMargin}"/>
                                <telerik:HighlightTextBlock Style="{StaticResource HighlightTextBlockStyle}" Text="{Binding SequenceServiceVM.StepWaferCenterMoveElapsedTime}" Width="100" Margin="{StaticResource ControlMargin}"/>
                            </WrapPanel>
                            <WrapPanel Orientation="Horizontal" Margin="{StaticResource ControlMargin}">
                                <local:StepLamp Style="{StaticResource StepLampStyle}" State="{Binding SequenceServiceVM.WTHome}" Margin="{StaticResource ControlMargin}"/>
                                <telerik:HighlightTextBlock Style="{StaticResource HighlightTextBlockStyle}" Text="W-T Home 이동" FontSize="16"  Margin="{StaticResource ControlMargin}"/>
                                <telerik:HighlightTextBlock Style="{StaticResource HighlightTextBlockStyle}" Text="{Binding SequenceServiceVM.StepWaferCenterMoveElapsedTime}" Width="100" Margin="{StaticResource ControlMargin}"/>
                            </WrapPanel>
                        </StackPanel>
                    </telerik:GroupBox>
                </Grid>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Grid.Row="2" Margin="{StaticResource ControlMargin}">
                    <telerik:RadButton Style="{StaticResource RadButtonStyle}" Width="100" Height="30" Margin="{StaticResource ControlMargin}" Command="{Binding InitializeCommand}">
                        <telerik:HighlightTextBlock Text="START"/>
                    </telerik:RadButton>

                    <telerik:RadButton Style="{StaticResource RadButtonStyle}" Width="100" Height="30" Margin="{StaticResource ControlMargin}" Command="{Binding StopCommand}">
                        <telerik:HighlightTextBlock Text="STOP"/>
                    </telerik:RadButton>
                </StackPanel>
            </Grid>
        </telerik:RadTabItem>

        <telerik:RadTabItem Style="{StaticResource RadTabItemStyle}" Header="2. LOADING" Margin="1">
            <Grid local:GridHelper.Rows="Auto, *"  Margin="20" >
                <StackPanel Grid.Row="0">
                    <TextBlock Text="Loading" FontSize="28" FontWeight="Bold" Foreground="#4A69BD"/>
                    <Rectangle Height="2" Fill="#3498DB" Margin="0,5,0,0"/>
                    <TextBlock Text="Die &amp; Wafer Loading" FontSize="14" Foreground="#7F8C8D" Margin="0,5,0,20"/>
                </StackPanel>

                <Grid local:GridHelper.Columns="*, *" Grid.Row="1">
                    <telerik:GroupBox Style="{StaticResource GroupBoxStyle}" Header="DIE" FontSize="18" Grid.Column="0" Margin="2">
                        <Grid  HorizontalAlignment="Center" VerticalAlignment="Center" local:GridHelper.Rows="Auto, Auto">
                            <ItemsControl ItemsSource="{Binding DTableList}" Margin="5">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <telerik:RadUniformGrid Columns="3" Margin="5" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>

                                <!-- 📌 각 셀의 디자인 -->
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type local:SensorIoItemViewModel}">
                                        <Border BorderBrush="#16233B"
                                        BorderThickness="0"
                                        CornerRadius="6">
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                <telerik:HighlightTextBlock Text="{Binding Name}"
                                                                    Margin="5"
                                                                    HorizontalAlignment="Right"
                                                                    VerticalAlignment="Center"
                                                                    Foreground="White"
                                                                    FontWeight="SemiBold"
                                                                    FontSize="18"/>
                                                <!-- 토글 -->
                                                <local:IoPillToggle
                                                    Grid.Column="1"
                                                    IsChecked="{Binding IsChecked, Mode=TwoWay}"
                                                    IsReadOnly="True"
                                                    Command="{Binding ToggleCommand}"
                                                    CommandParameter="{Binding}"/>
                                            </StackPanel>
                                            <!-- 센서 이름 -->
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Grid.Row="1" Margin="{StaticResource ControlMargin}">
                                <telerik:RadButton Style="{StaticResource RadButtonStyle}" Width="100" Height="30" Margin="{StaticResource ControlMargin}" Command="{Binding DieLoadCommand}">
                                    <telerik:HighlightTextBlock Text="Load"/>
                                </telerik:RadButton>
                                <telerik:RadButton Style="{StaticResource RadButtonStyle}" Width="100" Height="30" Margin="{StaticResource ControlMargin}" Command="{Binding DieResetCommand}">
                                    <telerik:HighlightTextBlock Text="Reset"/>
                                </telerik:RadButton>

                            </StackPanel>
                        </Grid>
                    </telerik:GroupBox>
                    <telerik:GroupBox Style="{StaticResource GroupBoxStyle}" Header="WAFER" FontSize="18" Grid.Column="1" Margin="2">
                        <Grid local:GridHelper.Rows="*, Auto">
                            <Grid>
                                <local:WaferMapControl ItemsSource="{Binding WaferData}"/>
                            </Grid>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="{StaticResource ControlMargin}" Grid.Row="1">
                                <telerik:RadComboBox 
                                    Width="100"
                                    Height="30"
                                    Margin="{StaticResource ControlMargin}"
                                    ItemsSource="{Binding WaferSizeList}"
                                    SelectedItem="{Binding SelectedWaferSize, Mode=TwoWay}"
                                    Foreground="Black"
                                    Style="{StaticResource RadComboBoxStyle}"/>
                                
                                <telerik:RadButton Style="{StaticResource RadButtonStyle}" Width="100" Height="30" Margin="{StaticResource ControlMargin}" Command="{Binding WaferLoadCommand}">
                                    <telerik:HighlightTextBlock Text="Load"/>
                                </telerik:RadButton>

                                <telerik:RadButton Style="{StaticResource RadButtonStyle}" Width="100" Height="30" Margin="{StaticResource ControlMargin}" Command="{Binding WaferCompleteCommand}">
                                    <telerik:HighlightTextBlock Text="Complete"/>
                                </telerik:RadButton>
                            </StackPanel>
                        </Grid>
                    </telerik:GroupBox>
                </Grid>
            </Grid>
        </telerik:RadTabItem>


        <telerik:RadTabItem Style="{StaticResource RadTabItemStyle}" Header="3. ALIGN" Margin="1">
            <Grid local:GridHelper.Rows="Auto, Auto" Margin="10,6">

                <!-- ══════════════════════════════════════════════════════════════ HEADER -->
                <Border Grid.Row="0" Background="#0D1B2A" CornerRadius="4" Padding="10,6" Margin="0,0,0,6">
                    <Grid local:GridHelper.Columns="*, Auto">
                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <Rectangle Width="3" Height="18" Fill="#3498DB" RadiusX="1" RadiusY="1" Margin="0,0,8,0"/>
                            <TextBlock Text="Pick &amp; Place" FontSize="16" FontWeight="Bold" Foreground="#ECF0F1" VerticalAlignment="Center"/>
                            <Border Background="#1A3A5C" CornerRadius="3" Padding="6,1" Margin="8,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="Wafer Align Sequence" FontSize="10" Foreground="#3498DB" FontWeight="SemiBold"/>
                            </Border>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <Ellipse Width="7" Height="7" Fill="#2ECC71" Margin="0,0,5,0"/>
                            <TextBlock Text="READY" FontSize="10" Foreground="#2ECC71" FontWeight="Bold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- ══════════════════════════════════════════════════════════ MAIN BODY -->
                <Grid Grid.Row="1" local:GridHelper.Rows="Auto, Auto">

                    <!-- ─────────────────────── ROW 0: DIE ALIGN / PICK UP / PLACE (compact) -->
                    <Border Grid.Row="0" Background="#0D1B2A" CornerRadius="4" Padding="8,6" Margin="0,0,0,6">
                        <Grid local:GridHelper.Columns="Auto, 1, *, 1, *">

                            <!-- DIE ALIGN -->
                            <StackPanel Grid.Column="0" Width="450">
                                <TextBlock Text="DIE ALIGN" FontSize="14" FontWeight="Bold" Foreground="#3498DB" Margin="0,0,0,4"/>
                                <!-- 저배율 -->
                                <Grid local:GridHelper.Columns="34, *, 52" Margin="0,0,0,3">
                                    <TextBlock Grid.Column="0" Text="저배율" FontSize="12" Foreground="#7F8C8D" VerticalAlignment="Center"/>
                                    <telerik:RadComboBox Grid.Column="1"
                            ItemsSource="{Binding DieTypeList}" SelectedItem="{Binding SelectedDieType}"
                            Style="{StaticResource RadComboBoxStyle}" Height="24" Margin="4,0"/>
                                    <Button Grid.Column="2" Content="보정" Command="{Binding DieLowAlignCommand}"/>
                                </Grid>
                                <!-- 고배율 -->
                                <Grid local:GridHelper.Columns="34, *, *, *, 52">
                                    <TextBlock Grid.Column="0" Text="고배율" FontSize="12" Foreground="#7F8C8D" VerticalAlignment="Center"/>
                                    <telerik:RadComboBox Grid.Column="1"
                            ItemsSource="{Binding DieTypeList}" SelectedItem="{Binding SelectedDieType}"
                            Style="{StaticResource RadComboBoxStyle}" Height="24" Margin="4,0,2,0"/>
                                    <telerik:RadComboBox Grid.Column="2"
                            ItemsSource="{Binding DirectTypeList}" SelectedItem="{Binding SelectedDirectType}"
                            Style="{StaticResource RadComboBoxStyle}" Height="24" Margin="0,0,2,0"/>
                                    <telerik:RadComboBox Grid.Column="3"
                            ItemsSource="{Binding MarkTypeList}" SelectedItem="{Binding SelectedMarkType}"
                            Style="{StaticResource RadComboBoxStyle}" Height="24" Margin="0,0,4,0"/>
                                    <Button Grid.Column="4" Content="보정"  Command="{Binding DieHighAlignCommand}"/>
                                </Grid>
                                <!-- Coord readout (RIGHT/LEFT X Y) -->
                                <Grid Margin="0,4,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="36"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="X" FontSize="9" FontWeight="Bold" Foreground="#3498DB" HorizontalAlignment="Center"/>
                                    <TextBlock Grid.Row="0" Grid.Column="2" Text="Y" FontSize="9" FontWeight="Bold" Foreground="#3498DB" HorizontalAlignment="Center"/>
                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="RIGHT" FontSize="9" Foreground="#7F8C8D" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding TopRightAlign.CenterX, StringFormat=F4}" FontSize="10" Foreground="#ECF0F1" HorizontalAlignment="Center"/>
                                    <TextBlock Grid.Row="1" Grid.Column="2" Text="{Binding TopRightAlign.CenterY, StringFormat=F4}" FontSize="10" Foreground="#ECF0F1" HorizontalAlignment="Center"/>
                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="LEFT" FontSize="9" Foreground="#7F8C8D" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding TopLeftAlign.CenterX, StringFormat=F4}" FontSize="10" Foreground="#ECF0F1" HorizontalAlignment="Center"/>
                                    <TextBlock Grid.Row="2" Grid.Column="2" Text="{Binding TopLeftAlign.CenterY, StringFormat=F4}" FontSize="10" Foreground="#ECF0F1" HorizontalAlignment="Center"/>
                                </Grid>
                            </StackPanel>

                            <Rectangle Grid.Column="1" Fill="#1A3A5C" Width="1" Margin="10,0"/>

                            <!-- PICK UP -->
                            <StackPanel Grid.Column="2" VerticalAlignment="Top" Margin="10,0">
                                <TextBlock Text="PICK UP" FontSize="14" FontWeight="Bold" Foreground="#E67E22" Margin="0,0,0,4"/>
                                <telerik:RadComboBox
                        ItemsSource="{Binding DieTypeList}" SelectedItem="{Binding SelectedDieType}"
                        Style="{StaticResource RadComboBoxStyle}" Height="24" Margin="0,0,0,5"/>
                                <Button Content="선택 실행" Height="26" Command="{Binding DiePickupCommand}"/>
                            </StackPanel>

                            <Rectangle Grid.Column="3" Fill="#1A3A5C" Width="1" Margin="10,0"/>

                            <!-- PLACE -->
                            <StackPanel Grid.Column="4" VerticalAlignment="Top" Margin="10,0">
                                <TextBlock Text="PLACE" FontSize="14" FontWeight="Bold" Foreground="#2ECC71" Margin="0,0,0,4"/>
                                <telerik:RadComboBox
                        ItemsSource="{Binding DieTypeList}" SelectedItem="{Binding SelectedDieType}"
                        Style="{StaticResource RadComboBoxStyle}" Height="24" Margin="0,0,0,5"/>
                                <Button Content="선택 실행" Height="26" Command="{Binding DiePlaceCommand}"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition></ColumnDefinition>
                                        <ColumnDefinition></ColumnDefinition>
                                        <ColumnDefinition></ColumnDefinition>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="ERROR X" FontSize="14" FontWeight="Bold" Foreground="#2ECC71" Margin="0,0,0,4"/>
                                        <TextBlock Text="{Binding ErrorX}"/>

                                    </StackPanel>

                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="ERROR Y" FontSize="14" FontWeight="Bold" Foreground="#E67E22" Margin="0,0,0,4"/>
                                        <TextBlock Text="{Binding ErrorY}"/>

                                    </StackPanel>

                                    <StackPanel Grid.Column="2"> 
                                        <TextBlock Text="ERROR T" FontSize="14" FontWeight="Bold" Foreground="BlueViolet" Margin="0,0,0,4"/>
                                        <TextBlock Text="{Binding ErrorT}"/>
                                    </StackPanel>

                                </Grid>
                            </StackPanel>

                        </Grid>
                    </Border>

                    <!-- ─────────────────────────────── ROW 1: BOTTOM DIE — compact flat table -->
                    <Border Grid.Row="1" Background="#0D1B2A" CornerRadius="4" Padding="8,6">
                        <StackPanel>

                            <!-- Section label -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                <Rectangle Width="3" Height="13" Fill="#9B59B6" RadiusX="1" RadiusY="1" Margin="0,0,6,0"/>
                                <TextBlock Text="BOTTOM DIE" FontSize="10" FontWeight="Bold" Foreground="#9B59B6" VerticalAlignment="Center"/>
                                <TextBlock Text=" — Alignment Result Data" FontSize="10" Foreground="#566573" VerticalAlignment="Center"/>
                            </StackPanel>

                            <!--
                    Flat 5-column table:
                    Col 0 (46): LEFT / RIGHT label
                    Col 1-2 (*): FID X / Y
                    Col 3-4 (*): FID ERR X / Y
                    Col 5-6 (*): ALIGN X / Y
                    Col 7-8 (*): ALIGN ERR X / Y
                    Col 9 (100): FID THETA + ALIGN THETA (rowspan)
                -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="44"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="6"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="6"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="6"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="6"/>
                                    <ColumnDefinition Width="100"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="3"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- ── HEADER ROW ── -->
                                <TextBlock Grid.Row="0" Grid.Column="0"/>
                                <!-- FID header -->
                                <TextBlock Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="2"
                               Text="FID" FontSize="9" FontWeight="Bold" Foreground="#3498DB"
                               HorizontalAlignment="Center" Margin="0,0,0,3"/>
                                <!-- FID ERR header -->
                                <TextBlock Grid.Row="0" Grid.Column="4" Grid.ColumnSpan="2"
                               Text="FID ERROR" FontSize="9" FontWeight="Bold" Foreground="#E74C3C"
                               HorizontalAlignment="Center" Margin="0,0,0,3"/>
                                <!-- ALIGN header -->
                                <TextBlock Grid.Row="0" Grid.Column="7" Grid.ColumnSpan="2"
                               Text="ALIGN" FontSize="9" FontWeight="Bold" Foreground="#2ECC71"
                               HorizontalAlignment="Center" Margin="0,0,0,3"/>
                                <!-- ALIGN ERR header -->
                                <TextBlock Grid.Row="0" Grid.Column="10" Grid.ColumnSpan="2"
                               Text="ALIGN ERROR" FontSize="9" FontWeight="Bold" Foreground="#E67E22"
                               HorizontalAlignment="Center" Margin="0,0,0,3"/>
                                <!-- THETA header -->
                                <TextBlock Grid.Row="0" Grid.Column="13"
                               Text="THETA" FontSize="14" FontWeight="Bold" Foreground="#9B59B6"
                               HorizontalAlignment="Center" Margin="0,0,0,3"/>

                                <!-- ── LEFT ROW ── -->
                                <Border Grid.Row="1" Grid.Column="0" Background="#0A1520" CornerRadius="3" Padding="3,3" Margin="0,0,3,0" VerticalAlignment="Stretch">
                                    <TextBlock Text="LEFT" FontSize="9" FontWeight="Bold" Foreground="#95A5A6" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>

                                <Border Grid.Row="1" Grid.Column="1" Background="#0A1520" CornerRadius="3,0,0,3" Padding="5,3" Margin="0,0,1,0">
                                    <StackPanel>
                                        <TextBlock Text="X" FontSize="8" Foreground="#3498DB"/>
                                        <TextBlock Text="{Binding BottomDie.LeftFid.X, StringFormat=F4}" FontSize="11" Foreground="#ECF0F1" FontWeight="SemiBold"/>
                                    </StackPanel>
                                </Border>
                                <Border Grid.Row="1" Grid.Column="2" Background="#0A1520" CornerRadius="0,3,3,0" Padding="5,3">
                                    <StackPanel>
                                        <TextBlock Text="Y" FontSize="8" Foreground="#3498DB"/>
                                        <TextBlock Text="{Binding BottomDie.LeftFid.Y, StringFormat=F4}" FontSize="11" Foreground="#ECF0F1" FontWeight="SemiBold"/>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Row="1" Grid.Column="4" Background="#0A1520" CornerRadius="3,0,0,3" Padding="5,3" Margin="0,0,1,0">
                                    <StackPanel>
                                        <TextBlock Text="X" FontSize="8" Foreground="#E74C3C"/>
                                        <TextBlock Text="{Binding BottomDie.LeftFidError.X, StringFormat=F4}" FontSize="11" Foreground="#E74C3C" FontWeight="SemiBold"/>
                                    </StackPanel>
                                </Border>
                                <Border Grid.Row="1" Grid.Column="5" Background="#0A1520" CornerRadius="0,3,3,0" Padding="5,3">
                                    <StackPanel>
