<UserControl x:Class="HCB.UI.StepSeqTab"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
      xmlns:local="clr-namespace:HCB.UI"
      mc:Ignorable="d">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/SYSTEM/COMMON/Styles/DefaultResource.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <BooleanToVisibilityConverter x:Key="BoolToVis"/>
            <local:InverseBoolConverter x:Key="InverseBoolConverter"/>

            <!-- Dark ComboBoxItem Style -->
            <Style x:Key="DarkComboBoxItem" TargetType="ComboBoxItem">
                <Setter Property="Foreground" Value="#ECF0F1"/>
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Padding" Value="0"/>
                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ComboBoxItem">
                            <Border x:Name="Bg"
                        Background="{TemplateBinding Background}"
                        CornerRadius="4"
                        Margin="4,2">
                                <ContentPresenter Margin="8,4"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bg" Property="Background" Value="#1C3A52"/>
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter TargetName="Bg" Property="Background" Value="#1E4A6A"/>
                                    <Setter TargetName="Bg" Property="BorderBrush" Value="#3498DB"/>
                                    <Setter TargetName="Bg" Property="BorderThickness" Value="1"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Dark ComboBox Style -->
            <Style x:Key="DarkComboBox" TargetType="ComboBox">
                <Setter Property="ItemContainerStyle" Value="{StaticResource DarkComboBoxItem}"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ComboBox">
                            <Grid>
                                <!-- 메인 버튼 영역 -->
                                <Border x:Name="MainBorder"
                            Background="#0A1628"
                            BorderBrush="#2A5A8C"
                            BorderThickness="1"
                            CornerRadius="6">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="36"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- 선택된 항목 표시 -->
                                        <ContentPresenter Grid.Column="0"
                                              x:Name="ContentSite"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              IsHitTestVisible="False"
                                              Margin="12,0,0,0"
                                              VerticalAlignment="Center"/>

                                        <!-- 드롭다운 화살표 -->
                                        <ToggleButton Grid.Column="0" Grid.ColumnSpan="2"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          Background="Transparent"
                                          BorderThickness="0"
                                          Focusable="False"
                                          ClickMode="Press">
                                            <ToggleButton.Template>
                                                <ControlTemplate TargetType="ToggleButton">
                                                    <Border Background="Transparent"/>
                                                </ControlTemplate>
                                            </ToggleButton.Template>
                                        </ToggleButton>

                                        <Path Grid.Column="1"
                                  x:Name="Arrow"
                                  Data="M 0 0 L 5 5 L 10 0"
                                  Stroke="#5E8BAA"
                                  StrokeThickness="1.5"
                                  StrokeLineJoin="Round"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  IsHitTestVisible="False"/>
                                    </Grid>
                                </Border>

                                <!-- 드롭다운 팝업 -->
                                <Popup x:Name="PART_Popup"
                           IsOpen="{TemplateBinding IsDropDownOpen}"
                           Placement="Bottom"
                           Focusable="False"
                           AllowsTransparency="True"
                           PopupAnimation="Fade">
                                    <Border Background="#0A1628"
                                BorderBrush="#2A5A8C"
                                BorderThickness="1"
                                CornerRadius="6"
                                Margin="0,2,0,0"
                                MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                        <ScrollViewer Margin="4">
                                            <ItemsPresenter/>
                                        </ScrollViewer>
                                    </Border>
                                </Popup>
                            </Grid>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="MainBorder" Property="BorderBrush" Value="#3498DB"/>
                                </Trigger>
                                <Trigger Property="IsDropDownOpen" Value="True">
                                    <Setter TargetName="MainBorder" Property="BorderBrush" Value="#3498DB"/>
                                    <Setter TargetName="Arrow" Property="Data" Value="M 0 5 L 5 0 L 10 5"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
            <Style x:Key="StepButtonStyle" TargetType="Button">
                <Setter Property="Height" Value="38"/>
                <Setter Property="Foreground" Value="#ECF0F1"/>
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="1" CornerRadius="6">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Opacity" Value="0.85"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter Property="Opacity" Value="0.7"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="StartButtonStyle" TargetType="Button" BasedOn="{StaticResource StepButtonStyle}">
                <Setter Property="Background" Value="#1A3A5C"/>
                <Setter Property="BorderBrush" Value="#2A5A8C"/>
                <Setter Property="Width" Value="90"/>
            </Style>

            <Style x:Key="StopButtonStyle" TargetType="Button" BasedOn="{StaticResource StepButtonStyle}">
                <Setter Property="Background" Value="#4A1A1A"/>
                <Setter Property="BorderBrush" Value="#8C2A2A"/>
                <Setter Property="Width" Value="90"/>
            </Style>

            <Style x:Key="InfoButtonStyle" TargetType="Button" BasedOn="{StaticResource StepButtonStyle}">
                <Setter Property="Background" Value="#1A2A1A"/>
                <Setter Property="BorderBrush" Value="#2A5A2A"/>
                <Setter Property="Width" Value="80"/>
            </Style>

            <Style x:Key="InfoToggleButtonStyle" TargetType="ToggleButton">
                <Setter Property="Height" Value="38"/>
                <Setter Property="Width" Value="80"/>
                <Setter Property="Foreground" Value="#ECF0F1"/>
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ToggleButton">
                            <Border x:Name="Bd" Background="#1A2A1A"
                                    BorderBrush="#2A5A2A" BorderThickness="1" CornerRadius="6">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#2A5A2A"/>
                                    <Setter TargetName="Bd" Property="BorderBrush" Value="#2ECC71"/>
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Bd" Property="Opacity" Value="0.7"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Margin="6">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════════════════════
             PREPARATION : Init / Die Load / Wafer Load
             ═══════════════════════════════════════════════════════ -->
        <Border Grid.Row="0" Background="#0D1B2A" CornerRadius="8" Margin="6,6,6,3"
                BorderBrush="#1C3A52" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <Grid Grid.Row="0" Margin="16,14,16,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Background="#2A1A4A" CornerRadius="4" Padding="10,4"
                            VerticalAlignment="Center" Margin="0,0,12,0">
                        <TextBlock Text="PREP" Foreground="#9B59B6" FontSize="13" FontWeight="Bold"/>
                    </Border>
                    <TextBlock Grid.Column="1" Text="Preparation Sequence"
                               Foreground="#ECF0F1" FontSize="20" FontWeight="Bold" VerticalAlignment="Center"/>
                </Grid>
                <Rectangle Grid.Row="0" Height="1" Fill="#1C3A52"
                           VerticalAlignment="Bottom" Margin="16,44,16,0"/>

                <!-- Step Cards -->
                <Grid Grid.Row="1" Margin="16,8,16,12" local:GridHelper.Columns="1*, 1*, 1*, 1*">

                    <!-- Step 1 : INIT -->
                    <Border Grid.Column="0" Background="#0A1628" CornerRadius="6" Margin="0,0,8,0">
                        <Grid Margin="14,10,14,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Background="#2A1A4A" CornerRadius="14"
                                    Width="28" Height="28" Margin="0,0,10,0">
                                <TextBlock Text="1" Foreground="#9B59B6" FontSize="13" FontWeight="Bold"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <local:StepLamp Grid.Column="1" Style="{StaticResource StepLampStyle}"
                                            State="{Binding InitState}" Margin="0,0,10,0"/>
                            <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                <TextBlock Text="INIT" Foreground="#ECF0F1" FontSize="17" FontWeight="SemiBold"/>
                                <TextBlock Text="System Initialize" Foreground="#5E8BAA" FontSize="12" Margin="0,2,0,0"/>
                            </StackPanel>
                            <Button Grid.Column="3" Style="{StaticResource InfoButtonStyle}" Margin="0,0,6,0"
                                    Command="{Binding InitInfoCommand}">
                                <TextBlock Text="INFO" FontSize="12" FontWeight="Bold"/>
                            </Button>
                            <Button Grid.Column="4" Style="{StaticResource StartButtonStyle}"
                                    Command="{Binding InitCommand}">
                                <TextBlock Text="START" FontSize="13" FontWeight="Bold"/>
                            </Button>
                        </Grid>
                    </Border>

                    <!-- Step 2 : DIE LOAD -->
                    <Border Grid.Column="1" Background="#0A1628" CornerRadius="6" Margin="4,0,4,0">
                        <Grid Margin="14,10,14,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Background="#2A1A4A" CornerRadius="14"
                                    Width="28" Height="28" Margin="0,0,10,0">
                                <TextBlock Text="2" Foreground="#9B59B6" FontSize="13" FontWeight="Bold"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <local:StepLamp Grid.Column="1" Style="{StaticResource StepLampStyle}"
                                            State="{Binding DieLoadState}" Margin="0,0,10,0"/>
                            <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                <TextBlock Text="DIE LOAD" Foreground="#ECF0F1" FontSize="17" FontWeight="SemiBold"/>
                                <TextBlock Text="Die Cassette Load" Foreground="#5E8BAA" FontSize="12" Margin="0,2,0,0"/>
                            </StackPanel>
                            <Button Grid.Column="3" Style="{StaticResource StartButtonStyle}"
                                    Command="{Binding DieLoadCommand}">
                                <TextBlock Text="START" FontSize="13" FontWeight="Bold"/>
                            </Button>
                        </Grid>
                    </Border>

                    <!-- Step 3 : WAFER LOAD -->
                    <Border Grid.Column="2" Background="#0A1628" CornerRadius="6" Margin="4,0,4,0">
                        <Grid Margin="14,10,14,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Background="#2A1A4A" CornerRadius="14"
                                    Width="28" Height="28" Margin="0,0,10,0">
                                <TextBlock Text="3" Foreground="#9B59B6" FontSize="13" FontWeight="Bold"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <local:StepLamp Grid.Column="1" Style="{StaticResource StepLampStyle}"
                                            State="{Binding WaferLoadState}" Margin="0,0,10,0"/>
                            <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                <TextBlock Text="WAFER LOAD" Foreground="#ECF0F1" FontSize="17" FontWeight="SemiBold"/>
                                <TextBlock Text="Wafer Cassette Load" Foreground="#5E8BAA" FontSize="12" Margin="0,2,0,0"/>
                            </StackPanel>
                            <Button Grid.Column="3" Style="{StaticResource StartButtonStyle}"
                                    Command="{Binding WaferLoadCommand}">
                                <TextBlock Text="START" FontSize="13" FontWeight="Bold"/>
                            </Button>
                        </Grid>
                    </Border>

                    <!-- Step 4 : RECIPE SELECT -->
                    <Border Grid.Column="3" Background="#0A1628" CornerRadius="6" Margin="8,0,0,0">
                        <Grid Margin="14,10,14,10">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="8"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- 헤더 행 -->
                            <Border Grid.Row="0" Grid.Column="0" Background="#2A1A4A" CornerRadius="14"
                                    Width="28" Height="28" Margin="0,0,10,0">
                                <TextBlock Text="4" Foreground="#9B59B6" FontSize="13" FontWeight="Bold"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <local:StepLamp Grid.Row="0" Grid.Column="1" Style="{StaticResource StepLampStyle}"
                                            State="{Binding RecipeSelectState}" Margin="0,0,10,0"/>
                            <StackPanel Grid.Row="0" Grid.Column="2" VerticalAlignment="Center">
                                <TextBlock Text="RECIPE SELECT" Foreground="#ECF0F1" FontSize="17" FontWeight="SemiBold"/>
                                <TextBlock Text="Recipe Selection" Foreground="#5E8BAA" FontSize="12" Margin="0,2,0,0"/>
                            </StackPanel>

                            <!-- ComboBox 행 -->
                            <ComboBox Grid.Row="0" Grid.Column="3" 
                                      Style="{StaticResource DarkComboBox}"
                                      Height="38" FontSize="14" Foreground="#ECF0F1"
                                      MaxDropDownHeight="200"
                                      ItemsSource="{Binding RecipeService.RecipeList}"
                                      SelectedItem="{Binding SelectedRecipe, Mode=TwoWay}">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="4,4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding Name}" Foreground="#ECF0F1"
                                                       FontSize="14" VerticalAlignment="Center"/>
                                            <Border Grid.Column="1" CornerRadius="4" Padding="6,2"
                                                    Background="#14452A" BorderBrush="#2ECC71" BorderThickness="1"
                                                    VerticalAlignment="Center"
                                                    Visibility="{Binding IsActive, Converter={StaticResource BoolToVis}}">
                                                <TextBlock Text="USE" Foreground="#2ECC71" FontSize="10" FontWeight="Bold"/>
                                            </Border>
                                        </Grid>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>

                            <!-- 파라미터 팝업 -->
                            <Popup Grid.Row="0" Grid.Column="3"
                                   IsOpen="{Binding IsChecked, ElementName=RecipeInfoToggle}"
                                   PlacementTarget="{Binding ElementName=RecipeInfoToggle}"
                                   Placement="Bottom" StaysOpen="False"
                                   AllowsTransparency="True">
                                <Border Background="#0D1B2A" BorderBrush="#2A5A2A" BorderThickness="1"
                                        CornerRadius="8" Width="420">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>

                                        <!-- 팝업 헤더 -->
                                        <Grid Grid.Row="0" Margin="14,12,14,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="Recipe Parameters" Foreground="#ECF0F1"
                                                       FontSize="15" FontWeight="Bold" VerticalAlignment="Center"/>
                                            <Border Grid.Column="1" Background="#1A2E1A" CornerRadius="4" Padding="8,3">
                                                <TextBlock Text="{Binding SelectedRecipe.Name, TargetNullValue='-- 선택 없음 --'}"
                                                           Foreground="#2ECC71" FontSize="11" FontWeight="Bold"/>
                                            </Border>
                                        </Grid>
                                        <Rectangle Grid.Row="0" Height="1" Fill="#2A5A2A"
                                                   VerticalAlignment="Bottom" Margin="14,34,14,0"/>

                                        <!-- 선택 없을 때 안내 -->
                                        <TextBlock Grid.Row="1" Margin="14,16,14,16"
                                                   Text="레시피를 선택하세요."
                                                   Foreground="#5E8BAA" FontSize="13"
                                                   HorizontalAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding SelectedRecipe}" Value="{x:Null}">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>

                                        <!-- 파라미터 DataGrid -->
                                        <DataGrid Grid.Row="2" Margin="8,8,8,10"
                                                  ItemsSource="{Binding SelectedRecipe.ParamList}"
                                                  Background="Transparent" BorderThickness="0"
                                                  RowBackground="Transparent"
                                                  AlternatingRowBackground="#0A1628"
                                                  Foreground="#ECF0F1" FontSize="14"
                                                  AutoGenerateColumns="False" IsReadOnly="True"
                                                  CanUserResizeRows="False" CanUserAddRows="False"
                                                  GridLinesVisibility="Horizontal"
                                                  HorizontalGridLinesBrush="#1C3A52"
                                                  RowHeaderWidth="0" MaxHeight="320">
                                            <DataGrid.Style>
                                                <Style TargetType="DataGrid">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding SelectedRecipe}" Value="{x:Null}">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </DataGrid.Style>
                                            <DataGrid.ColumnHeaderStyle>
                                                <Style TargetType="DataGridColumnHeader"
                                                       BasedOn="{StaticResource {x:Type DataGridColumnHeader}}">
                                                    <Setter Property="Background" Value="#0A1628"/>
                                                    <Setter Property="Foreground" Value="#5E8BAA"/>
                                                    <Setter Property="FontSize" Value="13"/>
                                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                                    <Setter Property="BorderBrush" Value="#1C3A52"/>
                                                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                                    <Setter Property="Padding" Value="8,6"/>
                                                </Style>
                                            </DataGrid.ColumnHeaderStyle>
                                            <DataGrid.CellStyle>
                                                <Style TargetType="DataGridCell"
                                                       BasedOn="{StaticResource {x:Type DataGridCell}}">
                                                    <Setter Property="BorderThickness" Value="0"/>
                                                    <Setter Property="Padding" Value="8,4"/>
                                                </Style>
                                            </DataGrid.CellStyle>
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="Name"  Binding="{Binding Name}"     Width="*"/>
                                                <DataGridTextColumn Header="Value" Binding="{Binding Value}"    Width="0.6*"/>
                                                <DataGridTextColumn Header="Unit"  Binding="{Binding UnitType}" Width="0.5*"/>
                                            </DataGrid.Columns>
                                        </DataGrid>
                                    </Grid>
                                </Border>
                            </Popup>

                        </Grid>
                    </Border>

                </Grid>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════════════════════
             ALIGNMENT SEQUENCES : Bottom / Top
             ═══════════════════════════════════════════════════════ -->
        <Grid Grid.Row="1" local:GridHelper.Columns="1*, 1*">

            <!-- ─── LEFT : BOTTOM ALIGN ─── -->
            <Border Background="#0D1B2A" CornerRadius="8" Margin="6,3,3,6"
                    BorderBrush="#1C3A52" BorderThickness="1" Grid.Column="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <Grid Grid.Row="0" Margin="16,14,16,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Background="#1A3A5C" CornerRadius="4" Padding="10,4"
                                VerticalAlignment="Center" Margin="0,0,12,0">
                            <TextBlock Text="BOTTOM" Foreground="#3498DB" FontSize="13" FontWeight="Bold"/>
                        </Border>
                        <TextBlock Grid.Column="1" Text="Bottom Sequence"
                                   Foreground="#ECF0F1" FontSize="20" FontWeight="Bold" VerticalAlignment="Center"/>
                    </Grid>
                    <Rectangle Grid.Row="0" Height="1" Fill="#1C3A52"
                               VerticalAlignment="Bottom" Margin="16,44,16,0"/>

                    <!-- Steps -->
                    <StackPanel Grid.Row="1" Margin="0,8,0,8">

                        <!-- Step 1 : 저배율 보정 -->
                        <Border Background="#0A1628" CornerRadius="6" Margin="16,6,16,6">
                            <Grid Margin="14,10,14,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Background="#1A3A5C" CornerRadius="14"
                                        Width="28" Height="28" Margin="0,0,10,0">
                                    <TextBlock Text="1" Foreground="#3498DB" FontSize="13" FontWeight="Bold"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <local:StepLamp Grid.Column="1" Style="{StaticResource StepLampStyle}"
                                                State="{Binding BtmLowAlignState}" Margin="0,0,10,0"/>
                                <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                    <TextBlock Text="저배율 보정" Foreground="#ECF0F1" FontSize="17" FontWeight="SemiBold"/>
                                    <TextBlock Text="Low Magnification Calibration" Foreground="#5E8BAA" FontSize="12" Margin="0,2,0,0"/>
                                </StackPanel>
                                <Button Grid.Column="3" Style="{StaticResource StartButtonStyle}"
                                        Command="{Binding BtmLowAlignCommand}">
                                    <TextBlock Text="START" FontSize="13" FontWeight="Bold"/>
                                </Button>
                            </Grid>
                        </Border>

                        <Rectangle Width="2" Height="14" Fill="#1C3A52" HorizontalAlignment="Left" Margin="42,0,0,0"/>

                        <!-- Step 2 : PICK UP -->
                        <Border Background="#0A1628" CornerRadius="6" Margin="16,0,16,6">
                            <Grid Margin="14,10,14,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Background="#1A3A5C" CornerRadius="14"
                                        Width="28" Height="28" Margin="0,0,10,0">
                                    <TextBlock Text="2" Foreground="#3498DB" FontSize="13" FontWeight="Bold"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <local:StepLamp Grid.Column="1" Style="{StaticResource StepLampStyle}"
                                                State="{Binding BtmPickupState}" Margin="0,0,10,0"/>
                                <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                    <TextBlock Text="PICK UP" Foreground="#ECF0F1" FontSize="17" FontWeight="SemiBold"/>
                                    <TextBlock Text="Die Pick Up" Foreground="#5E8BAA" FontSize="12" Margin="0,2,0,0"/>
                                </StackPanel>
                                <Button Grid.Column="3" Style="{StaticResource StartButtonStyle}"
                                        Command="{Binding BtmPickupCommand}">
                                    <TextBlock Text="START" FontSize="13" FontWeight="Bold"/>
                                </Button>
                            </Grid>
                        </Border>

                        <Rectangle Width="2" Height="14" Fill="#1C3A52" HorizontalAlignment="Left" Margin="42,0,0,0"/>

                        <!-- Step 3 : PLACE -->
                        <Border Background="#0A1628" CornerRadius="6" Margin="16,0,16,6">
                            <Grid Margin="14,10,14,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Background="#1A3A5C" CornerRadius="14"
                                        Width="28" Height="28" Margin="0,0,10,0">
                                    <TextBlock Text="3" Foreground="#3498DB" FontSize="13" FontWeight="Bold"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <local:StepLamp Grid.Column="1" Style="{StaticResource StepLampStyle}"
                                                State="{Binding BtmPlaceState}" Margin="0,0,10,0"/>
                                <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                    <TextBlock Text="PLACE" Foreground="#ECF0F1" FontSize="17" FontWeight="SemiBold"/>
                                    <TextBlock Text="Die Place on Wafer" Foreground="#5E8BAA" FontSize="12" Margin="0,2,0,0"/>
                                </StackPanel>
                                <Button Grid.Column="3" Style="{StaticResource StartButtonStyle}"
                                        Command="{Binding BtmPlaceCommand}">
                                    <TextBlock Text="START" FontSize="13" FontWeight="Bold"/>
                                </Button>
                            </Grid>
                        </Border>

                    </StackPanel>

                    <!-- Footer -->
                    <Border Grid.Row="2" BorderBrush="#1C3A52" BorderThickness="0,1,0,0"
                            Margin="16,0,16,0" Padding="0,10,0,14">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Style="{StaticResource StopButtonStyle}" Width="90"
                                    Command="{Binding StopCommand}">
                                <TextBlock Text="STOP" FontSize="13" FontWeight="Bold"/>
                            </Button>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- ─── RIGHT : TOP ALIGN ─── -->
            <Border Background="#0D1B2A" CornerRadius="8" Margin="3,3,6,6"
                    BorderBrush="#1C3A52" BorderThickness="1" Grid.Column="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <Grid Grid.Row="0" Margin="16,14,16,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Background="#14452A" CornerRadius="4" Padding="10,4"
                                VerticalAlignment="Center" Margin="0,0,12,0">
                            <TextBlock Text="TOP" Foreground="#2ECC71" FontSize="13" FontWeight="Bold"/>
                        </Border>
                        <TextBlock Grid.Column="1" Text="Top Sequence"
                                   Foreground="#ECF0F1" FontSize="20" FontWeight="Bold" VerticalAlignment="Center"/>
                    </Grid>
                    <Rectangle Grid.Row="0" Height="1" Fill="#1C3A52"
                               VerticalAlignment="Bottom" Margin="16,44,16,0"/>

                    <!-- Steps -->
                    <StackPanel Grid.Row="1" Margin="0,8,0,8">

                        <!-- Step 1 : 저배율 보정 -->
                        <Border Background="#0A1628" CornerRadius="6" Margin="16,6,16,6">
                            <Grid Margin="14,10,14,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Background="#14452A" CornerRadius="14"
                                        Width="28" Height="28" Margin="0,0,10,0">
                                    <TextBlock Text="1" Foreground="#2ECC71" FontSize="13" FontWeight="Bold"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <local:StepLamp Grid.Column="1" Style="{StaticResource StepLampStyle}"
                                                State="{Binding TopLowAlignState}" Margin="0,0,10,0"/>
                                <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                    <TextBlock Text="저배율 보정" Foreground="#ECF0F1" FontSize="17" FontWeight="SemiBold"/>
                                    <TextBlock Text="Low Magnification Calibration" Foreground="#5E8BAA" FontSize="12" Margin="0,2,0,0"/>
                                </StackPanel>
                                <Button Grid.Column="3" Style="{StaticResource StartButtonStyle}"
                                        Command="{Binding TopLowAlignCommand}">
                                    <TextBlock Text="START" FontSize="13" FontWeight="Bold"/>
                                </Button>
                            </Grid>
                        </Border>

                        <Rectangle Width="2" Height="12" Fill="#1C3A52" HorizontalAlignment="Left" Margin="42,0,0,0"/>

                        <!-- Step 2 : PICK UP -->
                        <Border Background="#0A1628" CornerRadius="6" Margin="16,0,16,6">
                            <Grid Margin="14,10,14,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Background="#14452A" CornerRadius="14"
                                        Width="28" Height="28" Margin="0,0,10,0">
                                    <TextBlock Text="2" Foreground="#2ECC71" FontSize="13" FontWeight="Bold"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <local:StepLamp Grid.Column="1" Style="{StaticResource StepLampStyle}"
                                                State="{Binding TopPickupState}" Margin="0,0,10,0"/>
                                <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                    <TextBlock Text="PICK UP" Foreground="#ECF0F1" FontSize="17" FontWeight="SemiBold"/>
                                    <TextBlock Text="Die Pick Up" Foreground="#5E8BAA" FontSize="12" Margin="0,2,0,0"/>
                                </StackPanel>
                                <Button Grid.Column="3" Style="{StaticResource StartButtonStyle}"
                                        Command="{Binding TopPickupCommand}">
                                    <TextBlock Text="START" FontSize="13" FontWeight="Bold"/>
                                </Button>
                            </Grid>
                        </Border>

                        <Rectangle Width="2" Height="12" Fill="#1C3A52" HorizontalAlignment="Left" Margin="42,0,0,0"/>

                        <!-- Step 3 : 고배율 보정 (Top die) -->
                        <Border Background="#0A1628" CornerRadius="6" Margin="16,0,16,6">
                            <Grid Margin="14,10,14,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Background="#14452A" CornerRadius="14"
                                        Width="28" Height="28" Margin="0,0,10,0">
                                    <TextBlock Text="3" Foreground="#2ECC71" FontSize="13" FontWeight="Bold"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <local:StepLamp Grid.Column="1" Style="{StaticResource StepLampStyle}"
                                                State="{Binding TopHighAlignState}" Margin="0,0,10,0"/>
                                <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                    <TextBlock Text="고배율 보정 (Top die)" Foreground="#ECF0F1" FontSize="17" FontWeight="SemiBold"/>
                                    <TextBlock Text="High Magnification Calibration - Top" Foreground="#5E8BAA" FontSize="12" Margin="0,2,0,0"/>
                                </StackPanel>
                                <Button Grid.Column="3" Style="{StaticResource InfoButtonStyle}" Margin="0,0,6,0"
                                        Command="{Binding OpenTopHighAlignInfoCommand}">
                                    <TextBlock Text="INFO" FontSize="12" FontWeight="Bold"/>
                                </Button>
                                <Button Grid.Column="4" Style="{StaticResource StartButtonStyle}"
                                        Command="{Binding TopHighAlignCommand}">
                                    <TextBlock Text="START" FontSize="13" FontWeight="Bold"/>
                                </Button>
                            </Grid>
                        </Border>

                        <Rectangle Width="2" Height="12" Fill="#1C3A52" HorizontalAlignment="Left" Margin="42,0,0,0"/>

                        <!-- Step 4 : 고배율 보정 (Bottom die) -->
                        <Border Background="#0A1628" CornerRadius="6" Margin="16,0,16,6">
                            <Grid Margin="14,10,14,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Background="#14452A" CornerRadius="14"
                                        Width="28" Height="28" Margin="0,0,10,0">
                                    <TextBlock Text="4" Foreground="#2ECC71" FontSize="13" FontWeight="Bold"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <local:StepLamp Grid.Column="1" Style="{StaticResource StepLampStyle}"
                                                State="{Binding BtmHighAlignState}" Margin="0,0,10,0"/>
                                <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                    <TextBlock Text="고배율 보정 (Bottom die)" Foreground="#ECF0F1" FontSize="17" FontWeight="SemiBold"/>
                                    <TextBlock Text="High Magnification Calibration - Bottom" Foreground="#5E8BAA" FontSize="12" Margin="0,2,0,0"/>
                                </StackPanel>
                                <Button Grid.Column="3" Style="{StaticResource InfoButtonStyle}" Margin="0,0,6,0"
                                        Command="{Binding BtmHighAlignInfoCommand}">
                                    <TextBlock Text="INFO" FontSize="12" FontWeight="Bold"/>
                                </Button>
                                <Button Grid.Column="4" Style="{StaticResource StartButtonStyle}"
                                        Command="{Binding BtmHighAlignCommand}">
                                    <TextBlock Text="START" FontSize="13" FontWeight="Bold"/>
                                </Button>
                            </Grid>
                        </Border>

                        <Rectangle Width="2" Height="12" Fill="#1C3A52" HorizontalAlignment="Left" Margin="42,0,0,0"/>

                        <!-- Step 5 : BONDING -->
                        <Border Background="#0A1628" CornerRadius="6" Margin="16,0,16,6">
                            <Grid Margin="14,10,14,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Background="#14452A" CornerRadius="14"
                                        Width="28" Height="28" Margin="0,0,10,0">
                                    <TextBlock Text="5" Foreground="#2ECC71" FontSize="13" FontWeight="Bold"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <local:StepLamp Grid.Column="1" Style="{StaticResource StepLampStyle}"
                                                State="{Binding TopBondingState}" Margin="0,0,10,0"/>
                                <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                    <TextBlock Text="BONDING" Foreground="#ECF0F1" FontSize="17" FontWeight="SemiBold"/>
                                    <TextBlock Text="Hybrid Bonding" Foreground="#5E8BAA" FontSize="12" Margin="0,2,0,0"/>
                                </StackPanel>
                                <Button Grid.Column="3" Style="{StaticResource InfoButtonStyle}" Margin="0,0,6,0"
                                        Command="{Binding TopHighAlignInfoCommand}">
                                    <TextBlock Text="INFO" FontSize="12" FontWeight="Bold"/>
                                </Button>
                                <Button Grid.Column="4" Style="{StaticResource StartButtonStyle}"
                                        Command="{Binding TopPlaceCommand}">
                                    <TextBlock Text="START" FontSize="13" FontWeight="Bold"/>
                                </Button>
                            </Grid>
                        </Border>

                    </StackPanel>

                    <!-- Footer -->
                    <Border Grid.Row="2" BorderBrush="#1C3A52" BorderThickness="0,1,0,0"
                            Margin="16,0,16,0" Padding="0,10,0,14">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Style="{StaticResource StartButtonStyle}" Width="90" Margin="2"
                                    Command="{Binding LowResultCommand}">
                                <TextBlock Text="저배율 결과" FontSize="13" FontWeight="Bold"/>
                            </Button>


                            <Button Style="{StaticResource StartButtonStyle}" Width="90" Margin="2"
                                    Command="{Binding TopRunFullSequenceCommand}">
                                <TextBlock Text="Start" FontSize="13" FontWeight="Bold"/>
                            </Button>

                            <Button Style="{StaticResource StopButtonStyle}" Width="90"
                                    Command="{Binding StopCommand}">
                                <TextBlock Text="STOP" FontSize="13" FontWeight="Bold"/>
                            </Button>
                        </StackPanel>
                    </Border>

                </Grid>
            </Border>

        </Grid>

        <!-- ═══════════════════════════════════════════════════════
             INIT INFO MODAL OVERLAY
             ═══════════════════════════════════════════════════════ -->
        <Grid Grid.RowSpan="2"
              Visibility="{Binding IsInitInfoOpen, Converter={StaticResource BoolToVis}}"
              Background="#A0000000">
            <Border MaxWidth="500"
                    Background="#0D1B2A" CornerRadius="12"
                    BorderBrush="#2A1A4A" BorderThickness="1"
                    HorizontalAlignment="Center" VerticalAlignment="Center">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <Grid Grid.Row="0" Margin="20,16,16,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Background="#2A1A4A" CornerRadius="4" Padding="10,4" Margin="0,0,10,0">
                                <TextBlock Text="INIT" Foreground="#9B59B6" FontSize="12" FontWeight="Bold"/>
                            </Border>
                            <TextBlock Text="Initialize Progress"
                                       Foreground="#ECF0F1" FontSize="18" FontWeight="Bold" VerticalAlignment="Center"/>
                        </StackPanel>
                        <Button Grid.Column="1" Margin="0,0,4,0"
                                Background="Transparent" BorderBrush="Transparent"
                                Foreground="#5E8BAA" FontSize="18" FontWeight="Bold"
                                Cursor="Hand" Width="36" Height="36"
                                Command="{Binding CloseInitInfoCommand}">
                            <TextBlock Text="✕"/>
                        </Button>
                    </Grid>
                    <Rectangle Grid.Row="0" Height="1" Fill="#2A1A4A"
                               VerticalAlignment="Bottom" Margin="20,46,20,0"/>

                    <!-- Progress Bar -->
                    <Grid Grid.Row="1" Margin="20,14,20,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Row="0" Text="Progress" Foreground="#5E8BAA" FontSize="12" Margin="0,0,0,5"/>
                        <TextBlock Grid.Row="0" Grid.Column="1"
                                   Text="{Binding SequenceServiceVM.InitializeProgress, StringFormat={}{0} %}"
                                   Foreground="#9B59B6" FontSize="12" FontWeight="Bold"/>
                        <telerik:RadProgressBar Grid.Row="1" Grid.ColumnSpan="2"
                                                Value="{Binding SequenceServiceVM.InitializeProgress}"
                                                Minimum="0" Maximum="100"
                                                Height="10"/>
                    </Grid>

                    <!-- Init Steps -->
                    <Border Grid.Row="2" Background="#060F1A" CornerRadius="8"
                            Margin="20,14,20,0" Padding="16,12">
                        <StackPanel>

                            <!-- System Check -->
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <local:StepLamp Grid.Column="0" Style="{StaticResource StepLampStyle}"
                                                State="{Binding SequenceServiceVM.SystemCheck}" Margin="0,0,12,0"/>
                                <TextBlock Grid.Column="1" Text="System Check"
                                           Foreground="#ECF0F1" FontSize="15" VerticalAlignment="Center"/>
                            </Grid>

                            <!-- Servo All On -->
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <local:StepLamp Grid.Column="0" Style="{StaticResource StepLampStyle}"
                                                State="{Binding SequenceServiceVM.ServoOn}" Margin="0,0,12,0"/>
                                <TextBlock Grid.Column="1" Text="Servo All On"
                                           Foreground="#ECF0F1" FontSize="15" VerticalAlignment="Center"/>
                            </Grid>

                            <!-- H-Z Break Off -->
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <local:StepLamp Grid.Column="0" Style="{StaticResource StepLampStyle}"
                                                State="{Binding SequenceServiceVM.HZBreakOff}" Margin="0,0,12,0"/>
                                <TextBlock Grid.Column="1" Text="H-Z Break Off"
                                           Foreground="#ECF0F1" FontSize="15" VerticalAlignment="Center"/>
                            </Grid>

                            <!-- H-Z Home -->
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <local:StepLamp Grid.Column="0" Style="{StaticResource StepLampStyle}"
                                                State="{Binding SequenceServiceVM.HZHome}" Margin="0,0,12,0"/>
                                <TextBlock Grid.Column="1" Text="H-Z Home"
                                           Foreground="#ECF0F1" FontSize="15" VerticalAlignment="Center"/>
                            </Grid>

                            <!-- H-X / H-T Home -->
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <local:StepLamp Grid.Column="0" Style="{StaticResource StepLampStyle}"
                                                State="{Binding SequenceServiceVM.HXHome}" Margin="0,0,12,0"/>
                                <TextBlock Grid.Column="1" Text="H-X / H-T Home"
                                           Foreground="#ECF0F1" FontSize="15" VerticalAlignment="Center"/>
                                <local:StepLamp Grid.Column="2" Style="{StaticResource StepLampStyle}"
                                                State="{Binding SequenceServiceVM.HTHome}" Margin="8,0,0,0"/>
                            </Grid>

                            <!-- Y-Axis Home -->
                            <Grid Margin="0,0,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <local:StepLamp Grid.Column="0" Style="{StaticResource StepLampStyle}"
                                                State="{Binding SequenceServiceVM.DYHome}" Margin="0,0,12,0"/>
                                <TextBlock Grid.Column="1" Text="D-Y / P-Y / W-Y / W-T Home"
                                           Foreground="#ECF0F1" FontSize="15" VerticalAlignment="Center"/>
                                <local:StepLamp Grid.Column="2" Style="{StaticResource StepLampStyle}"
                                                State="{Binding SequenceServiceVM.PYHome}" Margin="8,0,0,0"/>
                                <local:StepLamp Grid.Column="3" Style="{StaticResource StepLampStyle}"
                                                State="{Binding SequenceServiceVM.WYHome}" Margin="8,0,0,0"/>
                                <local:StepLamp Grid.Column="4" Style="{StaticResource StepLampStyle}"
                                                State="{Binding SequenceServiceVM.WTHome}" Margin="8,0,0,0"/>
                            </Grid>

                        </StackPanel>
                    </Border>

                    <!-- Footer -->
                    <Border Grid.Row="3" BorderBrush="#2A1A4A" BorderThickness="0,1,0,0"
                            Margin="20,14,20,0" Padding="0,10,0,16">
                        <Button Style="{StaticResource StopButtonStyle}" Width="100"
                                HorizontalAlignment="Right"
                                Command="{Binding CloseInitInfoCommand}">
                            <TextBlock Text="CLOSE" FontSize="13" FontWeight="Bold"/>
                        </Button>
                    </Border>

                </Grid>
            </Border>
        </Grid>

    </Grid>
</UserControl>
