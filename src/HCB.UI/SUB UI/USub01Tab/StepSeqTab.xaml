<UserControl x:Class="HCB.UI.StepSeqTab"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
      xmlns:local="clr-namespace:HCB.UI"
      mc:Ignorable="d" 
      >
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/SYSTEM/COMMON/Styles/DefaultResource.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <telerik:RadTabControl Style="{StaticResource RadTabControlStyle}">
        <telerik:RadTabItem Style="{StaticResource RadTabItemStyle}" Header="1. INITIALIZE" Margin="1">
            <Grid local:GridHelper.Rows="Auto, *, Auto"  Margin="20" >
                <StackPanel Grid.Row="0">
                    <TextBlock Text="Initialize" FontSize="28" FontWeight="Bold" Foreground="#4A69BD"/>
                    <Rectangle Height="2" Fill="#3498DB" Margin="0,5,0,0"/>
                    <TextBlock Text="시스템 초기화" FontSize="14" Foreground="#7F8C8D" Margin="0,5,0,20"/>
                    <telerik:RadProgressBar Value="{Binding SequenceServiceVM.InitializeProgress}" 
                                            Maximum="100" 
                                            Minimum="0" Height="20" />
                </StackPanel>

                <Grid local:GridHelper.Columns="1*, 1*, 1*" Grid.Row="1">
                    <telerik:GroupBox Style="{StaticResource GroupBoxStyle}" Header="System" FontSize="18" Grid.Column="0" Margin="2">
                        <StackPanel>
                            <WrapPanel Orientation="Horizontal" Margin="{StaticResource ControlMargin}">
                                <local:StepLamp Style="{StaticResource StepLampStyle}"  State="{Binding SequenceServiceVM.SystemCheck}" Margin="{StaticResource ControlMargin}"/>
                                <telerik:HighlightTextBlock Style="{StaticResource HighlightTextBlockStyle}" Text="System Check" FontSize="16" Width="150" Margin="{StaticResource ControlMargin}"/>
                                <telerik:HighlightTextBlock Style="{StaticResource HighlightTextBlockStyle}" Text="{Binding SequenceServiceVM.StepWaferCenterMoveElapsedTime}" Width="100" Margin="{StaticResource ControlMargin}"/>
                            </WrapPanel>

                            <WrapPanel Orientation="Horizontal" Margin="{StaticResource ControlMargin}">
                                <local:StepLamp Style="{StaticResource StepLampStyle}" State="{Binding SequenceServiceVM.ServoOn}" Margin="{StaticResource ControlMargin}"/>
                                <telerik:HighlightTextBlock Style="{StaticResource HighlightTextBlockStyle}" Text="Servo On" FontSize="16" Width="150" Margin="{StaticResource ControlMargin}"/>
                                <telerik:HighlightTextBlock Style="{StaticResource HighlightTextBlockStyle}" Text="{Binding SequenceServiceVM.StepWaferCenterMoveElapsedTime}" Width="100" Margin="{StaticResource ControlMargin}"/>
                            </WrapPanel>
                            <WrapPanel Orientation="Horizontal" Margin="{StaticResource ControlMargin}">
                                <local:StepLamp Style="{StaticResource StepLampStyle}" State="{Binding SequenceServiceVM.HZBreakOff}" Margin="{StaticResource ControlMargin}"/>
                                <telerik:HighlightTextBlock Style="{StaticResource HighlightTextBlockStyle}" Text="H-Z Break Off" FontSize="16" Width="150" Margin="{StaticResource ControlMargin}"/>
                                <telerik:HighlightTextBlock Style="{StaticResource HighlightTextBlockStyle}" Text="{Binding SequenceServiceVM.StepWaferCenterMoveElapsedTime}" Width="100" Margin="{StaticResource ControlMargin}"/>
                            </WrapPanel>
                        </StackPanel>
                    </telerik:GroupBox>
                    <telerik:GroupBox Style="{StaticResource GroupBoxStyle}" Header="H-Axis Home" FontSize="18" Grid.Column="1" Margin="2">
                        <StackPanel>
                            <WrapPanel Orientation="Horizontal" Margin="{StaticResource ControlMargin}">
                                <local:StepLamp Style="{StaticResource StepLampStyle}" State="{Binding SequenceServiceVM.HZHome}" Margin="{StaticResource ControlMargin}"/>
                                <telerik:HighlightTextBlock Style="{StaticResource HighlightTextBlockStyle}" Text="H-Z Home 이동" FontSize="16"  Margin="{StaticResource ControlMargin}"/>
                                <telerik:HighlightTextBlock Style="{StaticResource HighlightTextBlockStyle}" Text="{Binding SequenceServiceVM.StepWaferCenterMoveElapsedTime}" Width="100" Margin="{StaticResource ControlMargin}"/>
                            </WrapPanel>
                            <WrapPanel Orientation="Horizontal" Margin="{StaticResource ControlMargin}">
                                <local:StepLamp Style="{StaticResource StepLampStyle}" State="{Binding SequenceServiceVM.HzHome}" Margin="{StaticResource ControlMargin}"/>
                                <telerik:HighlightTextBlock Style="{StaticResource HighlightTextBlockStyle}" Text="h-z Home 이동" FontSize="16" Margin="{StaticResource ControlMargin}"/>
                                <telerik:HighlightTextBlock Style="{StaticResource HighlightTextBlockStyle}" Text="{Binding SequenceServiceVM.StepWaferCenterMoveElapsedTime}" Width="100" Margin="{StaticResource ControlMargin}"/>
                            </WrapPanel>
                            <WrapPanel Orientation="Horizontal" Margin="{StaticResource ControlMargin}">
                                <local:StepLamp Style="{StaticResource StepLampStyle}" State="{Binding SequenceServiceVM.HXHome}" Margin="{StaticResource ControlMargin}"/>
                                <telerik:HighlightTextBlock Style="{StaticResource HighlightTextBlockStyle}" Text="H-X Home 이동" FontSize="16"  Margin="{StaticResource ControlMargin}"/>
                                <telerik:HighlightTextBlock Style="{StaticResource HighlightTextBlockStyle}" Text="{Binding SequenceServiceVM.StepWaferCenterMoveElapsedTime}" Width="100" Margin="{StaticResource ControlMargin}"/>
                            </WrapPanel>
                            <WrapPanel Orientation="Horizontal" Margin="{StaticResource ControlMargin}">
                                <local:StepLamp Style="{StaticResource StepLampStyle}" State="{Binding SequenceServiceVM.HTHome}" Margin="{StaticResource ControlMargin}"/>
                                <telerik:HighlightTextBlock Style="{StaticResource HighlightTextBlockStyle}" Text="H-T Home 이동" FontSize="16" Margin="{StaticResource ControlMargin}"/>
                                <telerik:HighlightTextBlock Style="{StaticResource HighlightTextBlockStyle}" Text="{Binding SequenceServiceVM.StepWaferCenterMoveElapsedTime}" Width="100" Margin="{StaticResource ControlMargin}"/>
                            </WrapPanel>
                        </StackPanel>
                    </telerik:GroupBox>
                    <telerik:GroupBox Style="{StaticResource GroupBoxStyle}" Header="Y-Axis Home" FontSize="18" Grid.Column="2" Margin="2">
                        <StackPanel>
                            <WrapPanel Orientation="Horizontal" Margin="{StaticResource ControlMargin}">
                                <local:StepLamp Style="{StaticResource StepLampStyle}" State="{Binding SequenceServiceVM.DYHome}" Margin="{StaticResource ControlMargin}"/>
                                <telerik:HighlightTextBlock Style="{StaticResource HighlightTextBlockStyle}" Text="D-Y Home 이동" FontSize="16"  Margin="{StaticResource ControlMargin}"/>
                                <telerik:HighlightTextBlock Style="{StaticResource HighlightTextBlockStyle}" Text="{Binding SequenceServiceVM.StepWaferCenterMoveElapsedTime}" Width="100" Margin="{StaticResource ControlMargin}"/>
                            </WrapPanel>

                            <WrapPanel Orientation="Horizontal" Margin="{StaticResource ControlMargin}">
                                <local:StepLamp Style="{StaticResource StepLampStyle}" State="{Binding SequenceServiceVM.PYHome}" Margin="{StaticResource ControlMargin}"/>
                                <telerik:HighlightTextBlock Style="{StaticResource HighlightTextBlockStyle}" Text="P-Y Home 이동" FontSize="16" Margin="{StaticResource ControlMargin}"/>
                                <telerik:HighlightTextBlock Style="{StaticResource HighlightTextBlockStyle}" Text="{Binding SequenceServiceVM.StepWaferCenterMoveElapsedTime}" Width="100" Margin="{StaticResource ControlMargin}"/>
                            </WrapPanel>
                            
                            <WrapPanel Orientation="Horizontal" Margin="{StaticResource ControlMargin}">
                                <local:StepLamp Style="{StaticResource StepLampStyle}" State="{Binding SequenceServiceVM.WYHome}" Margin="{StaticResource ControlMargin}"/>
                                <telerik:HighlightTextBlock Style="{StaticResource HighlightTextBlockStyle}" Text="W-Y Home 이동" FontSize="16" Margin="{StaticResource ControlMargin}"/>
                                <telerik:HighlightTextBlock Style="{StaticResource HighlightTextBlockStyle}" Text="{Binding SequenceServiceVM.StepWaferCenterMoveElapsedTime}" Width="100" Margin="{StaticResource ControlMargin}"/>
                            </WrapPanel>
                            <WrapPanel Orientation="Horizontal" Margin="{StaticResource ControlMargin}">
                                <local:StepLamp Style="{StaticResource StepLampStyle}" State="{Binding SequenceServiceVM.WTHome}" Margin="{StaticResource ControlMargin}"/>
                                <telerik:HighlightTextBlock Style="{StaticResource HighlightTextBlockStyle}" Text="W-T Home 이동" FontSize="16"  Margin="{StaticResource ControlMargin}"/>
                                <telerik:HighlightTextBlock Style="{StaticResource HighlightTextBlockStyle}" Text="{Binding SequenceServiceVM.StepWaferCenterMoveElapsedTime}" Width="100" Margin="{StaticResource ControlMargin}"/>
                            </WrapPanel>
                        </StackPanel>
                    </telerik:GroupBox>
                </Grid>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Grid.Row="2" Margin="{StaticResource ControlMargin}">
                    <telerik:RadButton Style="{StaticResource RadButtonStyle}" Width="100" Height="30" Margin="{StaticResource ControlMargin}" Command="{Binding InitializeCommand}">
                        <telerik:HighlightTextBlock Text="START"/>
                    </telerik:RadButton>

                    <telerik:RadButton Style="{StaticResource RadButtonStyle}" Width="100" Height="30" Margin="{StaticResource ControlMargin}" Command="{Binding StopCommand}">
                        <telerik:HighlightTextBlock Text="STOP"/>
                    </telerik:RadButton>
                </StackPanel>
            </Grid>
        </telerik:RadTabItem>

        <telerik:RadTabItem Style="{StaticResource RadTabItemStyle}" Header="2. LOADING" Margin="1">
            <Grid local:GridHelper.Rows="Auto, *"  Margin="20" >
                <StackPanel Grid.Row="0">
                    <TextBlock Text="Loading" FontSize="28" FontWeight="Bold" Foreground="#4A69BD"/>
                    <Rectangle Height="2" Fill="#3498DB" Margin="0,5,0,0"/>
                    <TextBlock Text="Die &amp; Wafer Loading" FontSize="14" Foreground="#7F8C8D" Margin="0,5,0,20"/>
                </StackPanel>

                <Grid local:GridHelper.Columns="*, *" Grid.Row="1">
                    <telerik:GroupBox Style="{StaticResource GroupBoxStyle}" Header="DIE" FontSize="18" Grid.Column="0" Margin="2">
                        <Grid  HorizontalAlignment="Center" VerticalAlignment="Center" local:GridHelper.Rows="Auto, Auto">
                            <ItemsControl ItemsSource="{Binding DTableList}" Margin="5">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <telerik:RadUniformGrid Columns="3" Margin="5" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>

                                <!-- 📌 각 셀의 디자인 -->
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type local:SensorIoItemViewModel}">
                                        <Border BorderBrush="#16233B"
                                                BorderThickness="0"
                                                CornerRadius="6">
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                <telerik:HighlightTextBlock Text="{Binding Name}"
                                                                            Margin="5"
                                                                            HorizontalAlignment="Right"
                                                                            VerticalAlignment="Center"
                                                                            Foreground="White"
                                                                            FontWeight="SemiBold"
                                                                            FontSize="18"/>
                                                <!-- 토글 -->
                                                <local:IoPillToggle
                                                    Grid.Column="1"
                                                    IsChecked="{Binding IsChecked, Mode=TwoWay}"
                                                    IsReadOnly="True"
                                                    Command="{Binding ToggleCommand}"
                                                    CommandParameter="{Binding}"/>
                                            </StackPanel>
                                            <!-- 센서 이름 -->
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Grid.Row="1" Margin="{StaticResource ControlMargin}">
                                <telerik:RadButton Style="{StaticResource RadButtonStyle}" Width="100" Height="30" Margin="{StaticResource ControlMargin}" Command="{Binding DieLoadCommand}">
                                    <telerik:HighlightTextBlock Text="Load"/>
                                </telerik:RadButton>

                                <telerik:RadButton Style="{StaticResource RadButtonStyle}" Width="100" Height="30" Margin="{StaticResource ControlMargin}" Command="{Binding DieCompleteCommand}">
                                    <telerik:HighlightTextBlock Text="Complete"/>
                                </telerik:RadButton>
                            </StackPanel>
                        </Grid>
                    </telerik:GroupBox>
                    <telerik:GroupBox Style="{StaticResource GroupBoxStyle}" Header="WAFER" FontSize="18" Grid.Column="1" Margin="2">
                        <Grid>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Grid.Row="1" Margin="{StaticResource ControlMargin}">
                                <telerik:RadButton Style="{StaticResource RadButtonStyle}" Width="100" Height="30" Margin="{StaticResource ControlMargin}" Command="{Binding WaferLoadCommand}">
                                    <telerik:HighlightTextBlock Text="Load"/>
                                </telerik:RadButton>

                                <telerik:RadButton Style="{StaticResource RadButtonStyle}" Width="100" Height="30" Margin="{StaticResource ControlMargin}" Command="{Binding WaferCompleteCommand}">
                                    <telerik:HighlightTextBlock Text="Complete"/>
                                </telerik:RadButton>
                            </StackPanel>
                        </Grid>
                    </telerik:GroupBox>
                </Grid>
            </Grid>
        </telerik:RadTabItem>

        <telerik:RadTabItem Style="{StaticResource RadTabItemStyle}" Header="3. WAFER ALIGN" Margin="1">
            <Grid local:GridHelper.Rows="Auto, *, Auto"  Margin="20" >
                <StackPanel Grid.Row="0">
                    <TextBlock Text="Wafer Align" FontSize="28" FontWeight="Bold" Foreground="#4A69BD"/>
                    <Rectangle Height="2" Fill="#3498DB" Margin="0,5,0,0"/>
                    <TextBlock Text="Wafer Align Sequence" FontSize="14" Foreground="#7F8C8D" Margin="0,5,0,20"/>
                </StackPanel>

                <Grid HorizontalAlignment="Center" VerticalAlignment="Center" Grid.Row="1">
                    <Grid local:GridHelper.Columns="Auto, *">
                        <telerik:GroupBox Style="{StaticResource GroupBoxStyle}" Header="진행도" FontSize="18" Grid.Column="0" Margin="2">
                            <StackPanel>
                                <WrapPanel Orientation="Horizontal" Margin="{StaticResource ControlMargin}">
                                    <local:StepLamp Style="{StaticResource StepLampStyle}" State="{Binding SequenceServiceVM.WaferCenterMeasure}" Margin="{StaticResource ControlMargin}"/>
                                    <telerik:HighlightTextBlock Style="{StaticResource HighlightTextBlockStyle}" Text="Center Align 측정" FontSize="16" Width="150" Margin="{StaticResource ControlMargin}"/>
                                    <telerik:HighlightTextBlock Style="{StaticResource HighlightTextBlockStyle}" Text="{Binding SequenceServiceVM.StepWaferCenterMoveElapsedTime}" Width="100" Margin="{StaticResource ControlMargin}"/>
                                </WrapPanel>

                                <WrapPanel Orientation="Horizontal" Margin="{StaticResource ControlMargin}">
                                    <local:StepLamp Style="{StaticResource StepLampStyle}" State="{Binding SequenceServiceVM.WaferLeftMeasure}" Margin="{StaticResource ControlMargin}"/>
                                    <telerik:HighlightTextBlock Style="{StaticResource HighlightTextBlockStyle}" Text="Left Align 측정" FontSize="16" Width="150" Margin="{StaticResource ControlMargin}"/>
                                    <telerik:HighlightTextBlock Style="{StaticResource HighlightTextBlockStyle}" Text="{Binding SequenceServiceVM.StepWaferCenterMoveElapsedTime}" Width="100" Margin="{StaticResource ControlMargin}"/>
                                </WrapPanel>
                                <WrapPanel Orientation="Horizontal" Margin="{StaticResource ControlMargin}">
                                    <local:StepLamp Style="{StaticResource StepLampStyle}" State="{Binding SequenceServiceVM.WaferRightMeasure}" Margin="{StaticResource ControlMargin}"/>
                                    <telerik:HighlightTextBlock Style="{StaticResource HighlightTextBlockStyle}" Text="Right Align 측정" FontSize="16" Width="150" Margin="{StaticResource ControlMargin}"/>
                                    <telerik:HighlightTextBlock Style="{StaticResource HighlightTextBlockStyle}" Text="{Binding SequenceServiceVM.StepWaferCenterMoveElapsedTime}" Width="100" Margin="{StaticResource ControlMargin}"/>
                                </WrapPanel>
                                <WrapPanel Orientation="Horizontal" Margin="{StaticResource ControlMargin}">
                                    <local:StepLamp Style="{StaticResource StepLampStyle}" State="{Binding SequenceServiceVM.WaferAlign}" Margin="{StaticResource ControlMargin}"/>
                                    <telerik:HighlightTextBlock Style="{StaticResource HighlightTextBlockStyle}" Text="Wafer Align" FontSize="16" Width="150" Margin="{StaticResource ControlMargin}"/>
                                    <telerik:HighlightTextBlock Style="{StaticResource HighlightTextBlockStyle}" Text="{Binding SequenceServiceVM.StepWaferCenterMoveElapsedTime}" Width="100" Margin="{StaticResource ControlMargin}"/>
                                </WrapPanel>
                            </StackPanel>
                        </telerik:GroupBox>
                        <telerik:GroupBox Style="{StaticResource GroupBoxStyle}" Header="측정 Image" FontSize="18" Grid.Column="1" Margin="2">
                            <Border Width="500" Height="500"></Border>
                        </telerik:GroupBox>
                    </Grid>
                </Grid>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Grid.Row="2" Margin="{StaticResource ControlMargin}">
                    <telerik:RadButton Style="{StaticResource RadButtonStyle}" Width="100" Height="30" Margin="{StaticResource ControlMargin}" Command="{Binding WaferAlignCommand}">
                        <telerik:HighlightTextBlock Text="START"/>
                    </telerik:RadButton>

                    <telerik:RadButton Style="{StaticResource RadButtonStyle}" Width="100" Height="30" Margin="{StaticResource ControlMargin}" Command="{Binding StopCommand}">
                        <telerik:HighlightTextBlock Text="STOP"/>
                    </telerik:RadButton>
                </StackPanel>
            </Grid>
        </telerik:RadTabItem>
        <telerik:RadTabItem Style="{StaticResource RadTabItemStyle}" Header="4. BONDING" Margin="1">
            <Grid local:GridHelper.Rows="Auto, *, Auto"  Margin="20" >
                <StackPanel Grid.Row="0">
                    <TextBlock Text="Bonding" FontSize="28" FontWeight="Bold" Foreground="#4A69BD"/>
                    <Rectangle Height="2" Fill="#3498DB" Margin="0,5,0,0"/>
                    <TextBlock Text="Die Pickup &amp; Wafer Bonding " FontSize="14" Foreground="#7F8C8D" Margin="0,5,0,20"/>
                </StackPanel>

                <Grid HorizontalAlignment="Center" VerticalAlignment="Center" Grid.Row="1" local:GridHelper.Columns="*, *, *">
                    <StackPanel>
                        <Button Content="#1 Pickup" Margin="2"/>
                        <Button Content="#2 Pickup" Margin="2"/>
                        <Button Content="#3 Pickup" Margin="2"/>
                        <Button Content="#4 Pickup" Margin="2"/>
                        <Button Content="#5 Pickup" Margin="2"/>
                        <Button Content="#6 Pickup" Margin="2"/>
                        <Button Content="#7 Pickup" Margin="2"/>
                        <Button Content="#8 Pickup" Margin="2"/>
                        <Button Content="#9 Pickup" Margin="2"/>   
                    </StackPanel>

                    <StackPanel Grid.Column="1">
                        <Button Content="Carrier Align" Margin="2"></Button>
                        <Button Content="Bottom Vision" Margin="2"></Button>
                        <Button Content="Bonding Align" Margin="2"></Button>
                        <Button Content="Bonding" Margin="2"></Button>
                    </StackPanel>
                </Grid>
            </Grid>
        </telerik:RadTabItem>
    </telerik:RadTabControl>

       
</UserControl>
