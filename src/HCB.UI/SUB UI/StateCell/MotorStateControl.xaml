<UserControl x:Class="HCB.UI.MotorStateControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:model="clr-namespace:HCB.UI"
             xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
             xmlns:local="clr-namespace:HCB.UI"
             xmlns:uc="clr-namespace:HCB.UI"
             mc:Ignorable="d">

    <Border Padding="10"
            Background="#1E1E1E"
            BorderBrush="#3A3A3A"
            BorderThickness="1"
            CornerRadius="6">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ===== Header ===== -->
            <Grid 
                        VerticalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition></ColumnDefinition>
                    <ColumnDefinition></ColumnDefinition>
                    <ColumnDefinition></ColumnDefinition>
                    <ColumnDefinition></ColumnDefinition>
                </Grid.ColumnDefinitions>
                <Border BorderBrush="Transparent" BorderThickness="1">
                    <telerik:HighlightTextBlock Style="{StaticResource HighlightTextBlockStyle}" Text="{Binding Name}"
                   FontSize="18"
                   FontWeight="Bold"
                   Foreground="White"
                   Margin="0,0,10,0"/>
                </Border>


                <Button Content="SERVO ON"
                        Grid.Column="1"
                        Command="{Binding ServoOnCommand}"
                        Margin="4,0"/>
                <Button Content="SERVO OFF"
                        Grid.Column="2"
                        Command="{Binding ServoOffCommand}"
                        Margin="4,0"
                        />
                <!-- HOME 버튼: h_z 축은 특수 홈 시퀀스 사용 -->
                <Grid Grid.Column="3" Margin="4,0">
                    <!-- 일반 HOME (h_z 제외) -->
                    <Button Content="HOME" Command="{Binding HomeCommand}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Name}" Value="h_z">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <!-- h_z 전용 HOME (특수 시퀀스) -->
                    <Button Content="HOME"
                            Command="{Binding HzHomeCommand, RelativeSource={RelativeSource AncestorType=local:MotorStateControl}}"
                            ToolTip="① Cylinder L/R 확장 → ② H_Z→0 이동 → ③ h_z Home → ④ Piezo Home → ⑤ Cylinder 복귀">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Name}" Value="h_z">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>
            </Grid>

            <!-- ===== Status Indicators ===== -->
            <UniformGrid Grid.Row="1" Columns="4" Margin="0,10,0,10">

                <local:StateCell Label="ENABLE"     IsOn="{Binding IsEnabled}"/>
                <local:StateCell Label="BUSY"       IsOn="{Binding IsBusy}"/>
                <local:StateCell Label="ERROR"      IsOn="{Binding IsError}"/>
                <local:StateCell Label="INPOS"      IsOn="{Binding InPosition}"/>

                
                <local:StateCell Label="P-LIMIT"     IsOn="{Binding IsPlusLimit}"/>
                <local:StateCell Label="ORIGIN"      IsOn="{Binding IsHome}"/>
                <local:StateCell Label="N-LIMIT"     IsOn="{Binding IsMinusLimit}"/>
                <local:StateCell Label="CAL."       IsOn="{Binding IsHomeDone}"/>

            </UniformGrid>

            <!-- ===== Numeric Values ===== -->
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>
                <Border BorderBrush="Transparent" BorderThickness="1" Margin="2">
                    <StackPanel HorizontalAlignment="Center">
                        <telerik:HighlightTextBlock Style="{StaticResource HighlightTextBlockStyle}" Text="CURRENT-POS"
                               Foreground="Gray"/>
                        <telerik:HighlightTextBlock Style="{StaticResource HighlightTextBlockStyle}" Text="{Binding CurrentPosition, StringFormat=F3}"
                               FontSize="16"
                               TextAlignment="Center"
                               Foreground="White"/>
                    </StackPanel>
                </Border>
                <Border BorderBrush="Transparent" BorderThickness="1" Grid.Column="1" Margin="2">
                    <StackPanel HorizontalAlignment="Center">
                        <telerik:HighlightTextBlock Style="{StaticResource HighlightTextBlockStyle}" Text="TARGET-POS"
                               Foreground="Gray"/>
                        <telerik:HighlightTextBlock Style="{StaticResource HighlightTextBlockStyle}" Text="{Binding CommandPosition, StringFormat=F3}"
                               FontSize="16"
                                   TextAlignment="Center"
                               Foreground="White"/>
                    </StackPanel>
                </Border>

                <Border BorderBrush="Transparent" BorderThickness="1" Grid.Column="2" Margin="2">
                    <StackPanel HorizontalAlignment="Center">
                        <telerik:HighlightTextBlock Style="{StaticResource HighlightTextBlockStyle}" Text="VELOCITY"
                                    Foreground="Gray"/>
                        <telerik:HighlightTextBlock Style="{StaticResource HighlightTextBlockStyle}" Text="{Binding CurrentSpeed, StringFormat=F2}"
                                    FontSize="16"
                                   TextAlignment="Center"
                                    Foreground="White"/>
                    </StackPanel>
                </Border>
                
            </Grid>

        </Grid>
    </Border>

</UserControl>
