<Window x:Class="HCB.UI.RepeatMeasureDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="" WindowStyle="None" AllowsTransparency="True"
        Background="Transparent" ResizeMode="NoResize"
        Width="360" Height="220"
        WindowStartupLocation="CenterOwner">

    <Border Background="#0D1B2A" CornerRadius="12"
            BorderBrush="#2A5A8C" BorderThickness="1">
        <Grid Margin="24,20,24,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="16"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="20"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Grid.Row="0" Orientation="Horizontal">
                <Border Background="#1A3A5C" CornerRadius="4" Padding="10,4" Margin="0,0,10,0">
                    <TextBlock Text="TOP" Foreground="#2ECC71" FontSize="12" FontWeight="Bold"/>
                </Border>
                <TextBlock Text="반복 측정 설정"
                           Foreground="#ECF0F1" FontSize="17" FontWeight="Bold"
                           VerticalAlignment="Center"/>
            </StackPanel>

            <Rectangle Grid.Row="0" Height="1" Fill="#1C3A52"
                       VerticalAlignment="Bottom" Margin="0,40,0,0"/>

            <!-- Input -->
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="120"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="반복 횟수" Foreground="#5E8BAA" FontSize="14"
                           VerticalAlignment="Center"/>
                <Border Grid.Column="2" Background="#0A1628" BorderBrush="#2A5A8C"
                        BorderThickness="1" CornerRadius="6">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="RepeatCountBox"
                                 Text="{Binding RepeatCount, UpdateSourceTrigger=PropertyChanged}"
                                 Background="Transparent" BorderThickness="0"
                                 Foreground="#ECF0F1" FontSize="16" FontFamily="Consolas"
                                 TextAlignment="Right" VerticalAlignment="Center"
                                 Margin="10,6,4,6"/>
                        <TextBlock Grid.Column="1" Text="회" Foreground="#5E8BAA"
                                   FontSize="13" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    </Grid>
                </Border>
            </Grid>

            <!-- Buttons -->
            <Grid Grid.Row="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Height="38" Content="취소"
                        Foreground="#ECF0F1" FontSize="14" FontWeight="SemiBold"
                        Cursor="Hand"
                        Click="OnCancel">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="#1A2A3A" BorderBrush="#2A4A6A"
                                    BorderThickness="1" CornerRadius="6">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <Button Grid.Column="2" Height="38" Content="시작"
                        Foreground="#ECF0F1" FontSize="14" FontWeight="SemiBold"
                        Cursor="Hand"
                        Click="OnConfirm">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd" Background="#1A3A5C" BorderBrush="#2A5A8C"
                                    BorderThickness="1" CornerRadius="6">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#1E4A6A"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Grid>
    </Border>
</Window>