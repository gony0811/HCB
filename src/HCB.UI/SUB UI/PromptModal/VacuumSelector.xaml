<telerik:RadWindow x:Class="HCB.UI.VacuumSelector"
                    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
                    Header="Vacuum 선택"
                    Width="480"
                    Height="520"
                    ResizeMode="NoResize"
                    Style="{StaticResource RadWindowStyle}"
                    CanMove="True"
                    Background="#FF1A1A2E">

    <telerik:RadWindow.Resources>

        <Style x:Key="VacuumButtonStyle" TargetType="telerik:RadButton">
            <Setter Property="Width"           Value="150"/>
            <Setter Property="Height"          Value="70"/>
            <Setter Property="Margin"          Value="6"/>
            <Setter Property="FontSize"        Value="20"/>
            <Setter Property="FontWeight"      Value="Bold"/>
            <Setter Property="FontFamily"      Value="Segoe UI"/>
            <Setter Property="Foreground"      Value="#FFE0E0E0"/>
            <Setter Property="Background"      Value="#FF16213E"/>
            <Setter Property="BorderBrush"     Value="#FF0F3460"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="telerik:RadButton">
                        <Border x:Name="PART_Border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12">
                            <TextBlock x:Name="PART_Text"
                                       Text="{TemplateBinding Content}"
                                       FontSize="{TemplateBinding FontSize}"
                                       FontWeight="{TemplateBinding FontWeight}"
                                       FontFamily="{TemplateBinding FontFamily}"
                                       Foreground="{TemplateBinding Foreground}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="PART_Border" Property="Background"  Value="#FF0F3460"/>
                                <Setter TargetName="PART_Border" Property="BorderBrush" Value="#FF533483"/>
                                <Setter TargetName="PART_Text"   Property="Foreground"  Value="#FFFFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="PART_Border" Property="Background"  Value="#FF533483"/>
                                <Setter TargetName="PART_Border" Property="BorderBrush" Value="#FFE94560"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </telerik:RadWindow.Resources>

    <Grid Margin="20,10,20,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- 헤더 -->
            <RowDefinition Height="*"/>
            <!-- 버튼 그리드 -->
            <RowDefinition Height="Auto"/>
            <!-- 확인/취소 -->
        </Grid.RowDefinitions>

        <!-- ① 컬럼 헤더 -->
        <Grid Grid.Row="0" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Top"
                       FontFamily="Segoe UI" FontSize="15" FontWeight="SemiBold"
                       Foreground="#FF1E88E5"
                       HorizontalAlignment="Center"/>
            <TextBlock Grid.Column="1" Text="BTM"
                       FontFamily="Segoe UI" FontSize="15" FontWeight="SemiBold"
                       Foreground="#FFE94560"
                       HorizontalAlignment="Center"/>
        </Grid>

        <!-- ② 버튼 그리드 — 왼쪽 Top 1~4 / 오른쪽 BTM 1~4 -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Top 열 -->
            <StackPanel Grid.Column="0" HorizontalAlignment="Center" VerticalAlignment="Center">
                <telerik:RadButton x:Name="TopBtn1" Content="1"
                                   Style="{StaticResource VacuumButtonStyle}"
                                   Click="TopButton_Click" Tag="1"/>
                <telerik:RadButton x:Name="TopBtn2" Content="2"
                                   Style="{StaticResource VacuumButtonStyle}"
                                   Click="TopButton_Click" Tag="2"/>
                <telerik:RadButton x:Name="TopBtn3" Content="3"
                                   Style="{StaticResource VacuumButtonStyle}"
                                   Click="TopButton_Click" Tag="3"/>
                <telerik:RadButton x:Name="TopBtn4" Content="4"
                                   Style="{StaticResource VacuumButtonStyle}"
                                   Click="TopButton_Click" Tag="4"/>
            </StackPanel>

            <!-- BTM 열 -->
            <StackPanel Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center">
                <telerik:RadButton x:Name="BotBtn1" Content="1"
                                   Style="{StaticResource VacuumButtonStyle}"
                                   Click="BotButton_Click" Tag="1"/>
                <telerik:RadButton x:Name="BotBtn2" Content="2"
                                   Style="{StaticResource VacuumButtonStyle}"
                                   Click="BotButton_Click" Tag="2"/>
                <telerik:RadButton x:Name="BotBtn3" Content="3"
                                   Style="{StaticResource VacuumButtonStyle}"
                                   Click="BotButton_Click" Tag="3"/>
                <telerik:RadButton x:Name="BotBtn4" Content="4"
                                   Style="{StaticResource VacuumButtonStyle}"
                                   Click="BotButton_Click" Tag="4"/>
            </StackPanel>
        </Grid>

        <!-- ③ 확인 / 취소 -->
        <Grid Grid.Row="2" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <telerik:RadButton Grid.Column="0"
                               Content="취소"
                               Click="CancelButton_Click"
                               Height="40"
                               FontFamily="Segoe UI" FontSize="14"
                               Background="#FF16213E"
                               BorderBrush="#FF334466"
                               Foreground="#FF8899BB"/>

            <telerik:RadButton Grid.Column="2"
                               x:Name="ConfirmButton"
                               Content="확인"
                               Click="ConfirmButton_Click"
                               Height="40"
                               FontFamily="Segoe UI" FontSize="14" FontWeight="SemiBold"
                               Background="#FFE94560"
                               BorderBrush="#FFE94560"
                               Foreground="#FFFFFFFF"
                               IsEnabled="False"/>
        </Grid>
    </Grid>
</telerik:RadWindow>