<UserControl x:Class="HCB.UI.WaferMapControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:HCB.UI"
             mc:Ignorable="d"
             d:DesignHeight="300" d:DesignWidth="300">
    <Grid Background="#1A1A1A">
        <Border x:Name="Viewport" ClipToBounds="True" Background="Transparent"
                MouseWheel="OnMouseWheel" MouseDown="OnMouseDown" 
                MouseMove="OnMouseMove" MouseUp="OnMouseUp">
            <Canvas x:Name="MainCanvas">
                <Canvas.RenderTransform>
                    <MatrixTransform x:Name="MainTransform" />
                </Canvas.RenderTransform>
                <local:WaferVisualHost x:Name="VisualHost" />
            </Canvas>
        </Border>
    </Grid>
</UserControl>
