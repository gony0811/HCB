<Window x:Class="HCB.UI.UMain"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
        xmlns:local="clr-namespace:HCB.UI"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        Title="HCB"
        Background="#06101C"
        Closed="Window_Closed"
        mc:Ignorable="d">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/SYSTEM/COMMON/Styles/UMainStyle.xaml"/>
                <ResourceDictionary>
                    <Thickness x:Key="SubPageMargin">10</Thickness>
                </ResourceDictionary>
            </ResourceDictionary.MergedDictionaries>

            <local:KeyEqualsConverter x:Key="KeyEquals"/>

            <!-- ══ 상태 램프 공통 베이스 ══ -->
            <Style x:Key="BaseLamp" TargetType="ContentControl">
                <Setter Property="Width"  Value="130"/>
                <Setter Property="Height" Value="30"/>
            </Style>

            <!-- Availability -->
            <Style x:Key="AvailabilityRectLampStyle" TargetType="ContentControl"
                   BasedOn="{StaticResource BaseLamp}">
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ContentControl">
                            <Border x:Name="LampBorder" CornerRadius="5"
                                    Background="#1C3A52" BorderBrush="#2A5A8C"
                                    BorderThickness="1" Padding="8,2">
                                <TextBlock x:Name="LampText" Text="UNAVAILABLE"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Foreground="#5E8BAA" FontWeight="Bold" FontSize="12"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <DataTrigger Binding="{Binding SequenceServiceVM.Availability}" Value="Up">
                                    <Setter TargetName="LampBorder" Property="Background"   Value="#0F3D20"/>
                                    <Setter TargetName="LampBorder" Property="BorderBrush"  Value="#2ECC71"/>
                                    <Setter TargetName="LampText"   Property="Text"         Value="UP"/>
                                    <Setter TargetName="LampText"   Property="Foreground"   Value="#2ECC71"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding SequenceServiceVM.Availability}" Value="Down">
                                    <Setter TargetName="LampBorder" Property="Background"   Value="#3D0F0F"/>
                                    <Setter TargetName="LampBorder" Property="BorderBrush"  Value="#E74C3C"/>
                                    <Setter TargetName="LampText"   Property="Text"         Value="DOWN"/>
                                    <Setter TargetName="LampText"   Property="Foreground"   Value="#E74C3C"/>
                                </DataTrigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Run/Stop (Pause 블링킹 유지) -->
            <Style x:Key="RunStopRectLampStyle" TargetType="ContentControl"
                   BasedOn="{StaticResource BaseLamp}">
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ContentControl">
                            <Border x:Name="LampBorder" CornerRadius="5"
                                    Background="#3D0F0F" BorderBrush="#E74C3C"
                                    BorderThickness="1" Padding="8,2" Opacity="1">
                                <TextBlock x:Name="LampText" Text="STOP"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Foreground="#E74C3C" FontWeight="Bold" FontSize="12"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <DataTrigger Binding="{Binding SequenceServiceVM.RunStop}" Value="Ready">
                                    <Setter TargetName="LampBorder" Property="Background"  Value="#0F1F5C"/>
                                    <Setter TargetName="LampBorder" Property="BorderBrush" Value="#3498DB"/>
                                    <Setter TargetName="LampText"   Property="Text"        Value="READY"/>
                                    <Setter TargetName="LampText"   Property="Foreground"  Value="#3498DB"/>
                                    <Setter TargetName="LampBorder" Property="Opacity"     Value="1"/>
                                    <DataTrigger.EnterActions>
                                        <RemoveStoryboard BeginStoryboardName="PauseBlinkStoryboard"/>
                                    </DataTrigger.EnterActions>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding SequenceServiceVM.RunStop}" Value="Run">
                                    <Setter TargetName="LampBorder" Property="Background"  Value="#0F3D20"/>
                                    <Setter TargetName="LampBorder" Property="BorderBrush" Value="#2ECC71"/>
                                    <Setter TargetName="LampText"   Property="Text"        Value="RUN"/>
                                    <Setter TargetName="LampText"   Property="Foreground"  Value="#2ECC71"/>
                                    <Setter TargetName="LampBorder" Property="Opacity"     Value="1"/>
                                    <DataTrigger.EnterActions>
                                        <RemoveStoryboard BeginStoryboardName="PauseBlinkStoryboard"/>
                                    </DataTrigger.EnterActions>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding SequenceServiceVM.RunStop}" Value="Stop">
                                    <Setter TargetName="LampBorder" Property="Background"  Value="#3D0F0F"/>
                                    <Setter TargetName="LampBorder" Property="BorderBrush" Value="#E74C3C"/>
                                    <Setter TargetName="LampText"   Property="Text"        Value="STOP"/>
                                    <Setter TargetName="LampText"   Property="Foreground"  Value="#E74C3C"/>
                                    <Setter TargetName="LampBorder" Property="Opacity"     Value="1"/>
                                    <DataTrigger.EnterActions>
                                        <RemoveStoryboard BeginStoryboardName="PauseBlinkStoryboard"/>
                                    </DataTrigger.EnterActions>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding SequenceServiceVM.RunStop}" Value="Pause">
                                    <Setter TargetName="LampBorder" Property="Background"  Value="#3D2A0F"/>
                                    <Setter TargetName="LampBorder" Property="BorderBrush" Value="#E67E22"/>
                                    <Setter TargetName="LampText"   Property="Text"        Value="PAUSE"/>
                                    <Setter TargetName="LampText"   Property="Foreground"  Value="#E67E22"/>
                                    <DataTrigger.EnterActions>
                                        <BeginStoryboard x:Name="PauseBlinkStoryboard">
                                            <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                                <DoubleAnimation Storyboard.TargetName="LampBorder"
                                                                 Storyboard.TargetProperty="Opacity"
                                                                 From="1" To="0.3"
                                                                 Duration="0:0:0.5"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </DataTrigger.EnterActions>
                                    <DataTrigger.ExitActions>
                                        <RemoveStoryboard BeginStoryboardName="PauseBlinkStoryboard"/>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetName="LampBorder"
                                                                 Storyboard.TargetProperty="Opacity"
                                                                 To="1" Duration="0:0:0"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </DataTrigger.ExitActions>
                                </DataTrigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Alarm -->
            <Style x:Key="AlarmRectLampStyle" TargetType="ContentControl"
                   BasedOn="{StaticResource BaseLamp}">
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ContentControl">
                            <Border x:Name="LampBorder" CornerRadius="5"
                                    Background="#0F3D20" BorderBrush="#2ECC71"
                                    BorderThickness="1" Padding="8,2">
                                <TextBlock x:Name="LampText" Text="NORMAL"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Foreground="#2ECC71" FontWeight="Bold" FontSize="12"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <DataTrigger Binding="{Binding SequenceServiceVM.Alarm}" Value="NORMAL">
                                    <Setter TargetName="LampBorder" Property="Background"  Value="#0F3D20"/>
                                    <Setter TargetName="LampBorder" Property="BorderBrush" Value="#2ECC71"/>
                                    <Setter TargetName="LampText"   Property="Text"        Value="NORMAL"/>
                                    <Setter TargetName="LampText"   Property="Foreground"  Value="#2ECC71"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding SequenceServiceVM.Alarm}" Value="LIGHT">
                                    <Setter TargetName="LampBorder" Property="Background"  Value="#0F2A5C"/>
                                    <Setter TargetName="LampBorder" Property="BorderBrush" Value="#3498DB"/>
                                    <Setter TargetName="LampText"   Property="Text"        Value="WARNING"/>
                                    <Setter TargetName="LampText"   Property="Foreground"  Value="#3498DB"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding SequenceServiceVM.Alarm}" Value="HEAVY">
                                    <Setter TargetName="LampBorder" Property="Background"  Value="#3D0F0F"/>
                                    <Setter TargetName="LampBorder" Property="BorderBrush" Value="#E74C3C"/>
                                    <Setter TargetName="LampText"   Property="Text"        Value="ALERT"/>
                                    <Setter TargetName="LampText"   Property="Foreground"  Value="#E74C3C"/>
                                </DataTrigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- OperationMode -->
            <Style x:Key="OperationModeRectLampStyle" TargetType="ContentControl"
                   BasedOn="{StaticResource BaseLamp}">
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ContentControl">
                            <Border x:Name="LampBorder" CornerRadius="5"
                                    Background="#1C3A52" BorderBrush="#2A5A8C"
                                    BorderThickness="1" Padding="8,2">
                                <TextBlock x:Name="LampText" Text="MANUAL"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Foreground="#5E8BAA" FontWeight="Bold" FontSize="12"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <DataTrigger Binding="{Binding SequenceServiceVM.OperationMode}" Value="Auto">
                                    <Setter TargetName="LampBorder" Property="Background"  Value="#0F3D20"/>
                                    <Setter TargetName="LampBorder" Property="BorderBrush" Value="#2ECC71"/>
                                    <Setter TargetName="LampText"   Property="Text"        Value="AUTO"/>
                                    <Setter TargetName="LampText"   Property="Foreground"  Value="#2ECC71"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding SequenceServiceVM.OperationMode}" Value="Manual">
                                    <Setter TargetName="LampBorder" Property="Background"  Value="#0F3460"/>
                                    <Setter TargetName="LampBorder" Property="BorderBrush" Value="#3498DB"/>
                                    <Setter TargetName="LampText"   Property="Text"        Value="MANUAL"/>
                                    <Setter TargetName="LampText"   Property="Foreground"  Value="#3498DB"/>
                                </DataTrigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Vision -->
            <Style x:Key="VisionLampStyle" TargetType="ContentControl"
                   BasedOn="{StaticResource BaseLamp}">
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ContentControl">
                            <Border x:Name="LampBorder" CornerRadius="5"
                                    Background="#1C3A52" BorderBrush="#2A5A8C"
                                    BorderThickness="1" Padding="8,2">
                                <TextBlock x:Name="LampText" Text="VISION"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Foreground="#5E8BAA" FontWeight="Bold" FontSize="12"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <DataTrigger Binding="{Binding SequenceServiceVM.VisionStatus}" Value="True">
                                    <Setter TargetName="LampBorder" Property="Background"  Value="#0F3D20"/>
                                    <Setter TargetName="LampBorder" Property="BorderBrush" Value="#2ECC71"/>
                                    <Setter TargetName="LampText"   Property="Foreground"  Value="#2ECC71"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding SequenceServiceVM.VisionStatus}" Value="False">
                                    <Setter TargetName="LampBorder" Property="Background"  Value="#1C3A52"/>
                                    <Setter TargetName="LampBorder" Property="BorderBrush" Value="#2A5A8C"/>
                                    <Setter TargetName="LampText"   Property="Foreground"  Value="#5E8BAA"/>
                                </DataTrigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ══ 네비 메뉴 버튼 ══ -->
            <Style x:Key="NavToggleButton" TargetType="ToggleButton">
                <Setter Property="Width"  Value="90"/>
                <Setter Property="Height" Value="80"/>
                <Setter Property="Margin" Value="2,0"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Foreground" Value="#5E8BAA"/>
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ToggleButton">
                            <Border x:Name="Bd"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="Transparent"
                                    BorderThickness="0,0,0,3"
                                    CornerRadius="0">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background"   Value="#0A1628"/>
                                    <Setter TargetName="Bd" Property="BorderBrush"  Value="#2A5A8C"/>
                                    <Setter Property="Foreground" Value="#ECF0F1"/>
                                </Trigger>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter TargetName="Bd" Property="Background"   Value="#0D1B2A"/>
                                    <Setter TargetName="Bd" Property="BorderBrush"  Value="#3498DB"/>
                                    <Setter Property="Foreground" Value="#ECF0F1"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Foreground" Value="#2A3A4A"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- HCB 타이틀 버튼 -->
            <Style x:Key="TitleButton" TargetType="Button">
                <Setter Property="Width"  Value="150"/>
                <Setter Property="Height" Value="60"/>
                <Setter Property="Margin" Value="5"/>
                <Setter Property="Foreground" Value="#ECF0F1"/>
                <Setter Property="FontSize" Value="22"/>
                <Setter Property="FontWeight" Value="Bold"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd"
                                    Background="#0F3460"
                                    BorderBrush="#2A5A8C"
                                    BorderThickness="1"
                                    CornerRadius="8">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background"  Value="#1A4A7A"/>
                                    <Setter TargetName="Bd" Property="BorderBrush" Value="#3498DB"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- 종료 버튼 -->
            <Style x:Key="ExitButton" TargetType="Button">
                <Setter Property="MinHeight" Value="80"/>
                <Setter Property="MinWidth"  Value="100"/>
                <Setter Property="Margin"    Value="5"/>
                <Setter Property="Foreground" Value="#ECF0F1"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd"
                                    Background="#3D0F0F"
                                    BorderBrush="#E74C3C"
                                    BorderThickness="1"
                                    CornerRadius="8">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background"  Value="#5A1818"/>
                                    <Setter TargetName="Bd" Property="BorderBrush" Value="#FF6B6B"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#200808"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ══ Row 0: 상단 헤더 바 ══ -->
        <Border Grid.Row="0"
                Background="#0D1B2A"
                BorderBrush="#1C3A52"
                BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- HCB 타이틀 버튼 -->
                <Button Grid.Column="0" Content="HCB" Style="{StaticResource TitleButton}"/>

                <!-- 상태 램프 5개 -->
                <UniformGrid Grid.Column="1" Rows="1" Columns="5"
                             HorizontalAlignment="Center" VerticalAlignment="Center"
                             Margin="10,8">
                    <StackPanel Orientation="Vertical" Margin="10,0" HorizontalAlignment="Center">
                        <TextBlock Text="Availability" Foreground="#5E8BAA"
                                   FontSize="11" FontWeight="SemiBold"
                                   HorizontalAlignment="Center" Margin="0,0,0,4"/>
                        <ContentControl Style="{StaticResource AvailabilityRectLampStyle}"/>
                    </StackPanel>
                    <StackPanel Orientation="Vertical" Margin="10,0" HorizontalAlignment="Center">
                        <TextBlock Text="Run / Stop" Foreground="#5E8BAA"
                                   FontSize="11" FontWeight="SemiBold"
                                   HorizontalAlignment="Center" Margin="0,0,0,4"/>
                        <ContentControl Style="{StaticResource RunStopRectLampStyle}"/>
                    </StackPanel>
                    <StackPanel Orientation="Vertical" Margin="10,0" HorizontalAlignment="Center">
                        <TextBlock Text="Alarm" Foreground="#5E8BAA"
                                   FontSize="11" FontWeight="SemiBold"
                                   HorizontalAlignment="Center" Margin="0,0,0,4"/>
                        <ContentControl Style="{StaticResource AlarmRectLampStyle}"/>
                    </StackPanel>
                    <StackPanel Orientation="Vertical" Margin="10,0" HorizontalAlignment="Center">
                        <TextBlock Text="Operation Mode" Foreground="#5E8BAA"
                                   FontSize="11" FontWeight="SemiBold"
                                   HorizontalAlignment="Center" Margin="0,0,0,4"/>
                        <ContentControl Style="{StaticResource OperationModeRectLampStyle}"/>
                    </StackPanel>
                    <StackPanel Orientation="Vertical" Margin="10,0" HorizontalAlignment="Center">
                        <TextBlock Text="Vision" Foreground="#5E8BAA"
                                   FontSize="11" FontWeight="SemiBold"
                                   HorizontalAlignment="Center" Margin="0,0,0,4"/>
                        <ContentControl Style="{StaticResource VisionLampStyle}"/>
                    </StackPanel>
                </UniformGrid>

                <!-- 우측 정보 영역 -->
                <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="12,8">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="TIME : "
                                   Foreground="#5E8BAA" FontSize="12" FontWeight="SemiBold"/>
                        <TextBlock x:Name="tbTime"
                                   Text="{Binding TimeText}"
                                   Foreground="#ECF0F1" FontSize="12" FontWeight="SemiBold"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                        <TextBlock Text="LOG IN : "
                                   Foreground="#5E8BAA" FontSize="12" FontWeight="SemiBold"/>
                        <TextBlock x:Name="tbUser"
                                   Text="{Binding UserService.CurrentAuthority.Name, TargetNullValue=--, FallbackValue=--}"
                                   Foreground="#ECF0F1" FontSize="12" FontWeight="SemiBold"/>
                    </StackPanel>
                    <TextBlock x:Name="tbBuild"
                               Text="{Binding BuildText}"
                               Foreground="#3A5A7A" FontSize="11"
                               TextAlignment="Right" Margin="0,3,0,0"/>
                    <TextBlock x:Name="tbDeveloper"
                               Text="{Binding DeveloperText}"
                               Foreground="#3A5A7A" FontSize="11"
                               TextAlignment="Right"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ══ Row 1: 메인 콘텐츠 프레임 ══ -->
        <Frame Grid.Row="1"
               x:Name="MainFrame"
               NavigationUIVisibility="Hidden"
               JournalOwnership="OwnsJournal"
               Content="{Binding CurrentPage}"
               Margin="{StaticResource SubPageMargin}"/>

        <!-- ══ Row 2: 하단 네비게이션 바 ══ -->
        <Border Grid.Row="2"
                Background="#0D1B2A"
                BorderBrush="#1C3A52"
                BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- 메뉴 버튼들 -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="4,0">

                    <!-- 메인 -->
                    <ToggleButton Style="{StaticResource NavToggleButton}"
                                  Tag="MAIN"
                                  Command="{Binding NavigateCommand}"
                                  CommandParameter="{Binding RelativeSource={RelativeSource Self}, Path=Tag}"
                                  IsChecked="{Binding SelectedPageKey, Converter={StaticResource KeyEquals}, ConverterParameter=MAIN}"
                                  IsEnabled="{Binding NavVM.MainEnabled}">
                        <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                            <telerik:RadGlyph Glyph="&#xe690;" Width="22" Height="22"
                                              HorizontalAlignment="Center" Margin="0,0,0,5"
                                              Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}"/>
                            <TextBlock Text="메인" TextAlignment="Center" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}"/>
                        </StackPanel>
                    </ToggleButton>

                    <!-- 레시피 -->
                    <ToggleButton Style="{StaticResource NavToggleButton}"
                                  Tag="RECIPE"
                                  Command="{Binding NavigateCommand}"
                                  CommandParameter="{Binding RelativeSource={RelativeSource Self}, Path=Tag}"
                                  IsChecked="{Binding SelectedPageKey, Converter={StaticResource KeyEquals}, ConverterParameter=RECIPE}"
                                  IsEnabled="{Binding NavVM.RecipeEnabled}">
                        <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                            <telerik:RadGlyph Glyph="&#xe13a;" Width="22" Height="22"
                                              HorizontalAlignment="Center" Margin="0,0,0,5"
                                              Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}"/>
                            <TextBlock Text="레시피" TextAlignment="Center" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}"/>
                        </StackPanel>
                    </ToggleButton>

                    <!-- 파라미터 -->
                    <ToggleButton Style="{StaticResource NavToggleButton}"
                                  Tag="PARAMETER"
                                  Command="{Binding NavigateCommand}"
                                  CommandParameter="{Binding RelativeSource={RelativeSource Self}, Path=Tag}"
                                  IsChecked="{Binding SelectedPageKey, Converter={StaticResource KeyEquals}, ConverterParameter=PARAMETER}"
                                  IsEnabled="{Binding NavVM.ParameterEnabled}">
                        <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                            <telerik:RadGlyph Glyph="&#xe401;" Width="22" Height="22"
                                              HorizontalAlignment="Center" Margin="0,0,0,5"
                                              Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}"/>
                            <TextBlock Text="파라미터" TextAlignment="Center" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}"/>
                        </StackPanel>
                    </ToggleButton>

                    <!-- 사용자 -->
                    <ToggleButton Style="{StaticResource NavToggleButton}"
                                  Tag="USER"
                                  Command="{Binding NavigateCommand}"
                                  CommandParameter="{Binding RelativeSource={RelativeSource Self}, Path=Tag}"
                                  IsChecked="{Binding SelectedPageKey, Converter={StaticResource KeyEquals}, ConverterParameter=USER}"
                                  IsEnabled="{Binding NavVM.UserEnabled}">
                        <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                            <telerik:RadGlyph Glyph="&#xe801;" Width="22" Height="22"
                                              HorizontalAlignment="Center" Margin="0,0,0,5"
                                              Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}"/>
                            <TextBlock Text="사용자" TextAlignment="Center" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}"/>
                        </StackPanel>
                    </ToggleButton>

                    <!-- 로그 -->
                    <ToggleButton Style="{StaticResource NavToggleButton}"
                                  Tag="LOG"
                                  Command="{Binding NavigateCommand}"
                                  CommandParameter="{Binding RelativeSource={RelativeSource Self}, Path=Tag}"
                                  IsChecked="{Binding SelectedPageKey, Converter={StaticResource KeyEquals}, ConverterParameter=LOG}"
                                  IsEnabled="{Binding NavVM.LogEnabled}">
                        <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                            <telerik:RadGlyph Glyph="&#xe924;" Width="22" Height="22"
                                              HorizontalAlignment="Center" Margin="0,0,0,5"
                                              Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}"/>
                            <TextBlock Text="로그" TextAlignment="Center" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}"/>
                        </StackPanel>
                    </ToggleButton>

                    <!-- 알람 정의 -->
                    <ToggleButton Style="{StaticResource NavToggleButton}"
                                  Tag="ALARM"
                                  Command="{Binding NavigateCommand}"
                                  CommandParameter="{Binding RelativeSource={RelativeSource Self}, Path=Tag}"
                                  IsChecked="{Binding SelectedPageKey, Converter={StaticResource KeyEquals}, ConverterParameter=ALARM}"
                                  IsEnabled="{Binding NavVM.AlarmEnabled}">
                        <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                            <telerik:RadGlyph Glyph="&#xe400;" Width="22" Height="22"
                                              HorizontalAlignment="Center" Margin="0,0,0,5"
                                              Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}"/>
                            <TextBlock Text="알람 정의" TextAlignment="Center" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}"/>
                        </StackPanel>
                    </ToggleButton>

                    <!-- 모션 -->
                    <ToggleButton Style="{StaticResource NavToggleButton}"
                                  Tag="MOTION"
                                  Command="{Binding NavigateCommand}"
                                  CommandParameter="{Binding RelativeSource={RelativeSource Self}, Path=Tag}"
                                  IsChecked="{Binding SelectedPageKey, Converter={StaticResource KeyEquals}, ConverterParameter=MOTION}"
                                  IsEnabled="{Binding NavVM.MotionEnabled}">
                        <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                            <telerik:RadGlyph Glyph="&#xea17;" Width="22" Height="22"
                                              HorizontalAlignment="Center" Margin="0,0,0,5"
                                              Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}"/>
                            <TextBlock Text="모션" TextAlignment="Center" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}"/>
                        </StackPanel>
                    </ToggleButton>

                    <!-- I/O -->
                    <ToggleButton Style="{StaticResource NavToggleButton}"
                                  Tag="IO"
                                  Command="{Binding NavigateCommand}"
                                  CommandParameter="{Binding RelativeSource={RelativeSource Self}, Path=Tag}"
                                  IsChecked="{Binding SelectedPageKey, Converter={StaticResource KeyEquals}, ConverterParameter=IO}"
                                  IsEnabled="{Binding NavVM.IOEnabled}">
                        <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                            <telerik:RadGlyph Glyph="&#xe934;" Width="22" Height="22"
                                              HorizontalAlignment="Center" Margin="0,0,0,5"
                                              Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}"/>
                            <TextBlock Text="I/O" TextAlignment="Center" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}"/>
                        </StackPanel>
                    </ToggleButton>

                    <!-- Device -->
                    <ToggleButton Style="{StaticResource NavToggleButton}"
                                  Tag="DEVICE"
                                  Command="{Binding NavigateCommand}"
                                  CommandParameter="{Binding RelativeSource={RelativeSource Self}, Path=Tag}"
                                  IsChecked="{Binding SelectedPageKey, Converter={StaticResource KeyEquals}, ConverterParameter=DEVICE}"
                                  Visibility="{Binding NavVM.DeviceEnabled}">
                        <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                            <telerik:RadGlyph Glyph="&#xe13c;" Width="22" Height="22"
                                              HorizontalAlignment="Center" Margin="0,0,0,5"
                                              Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}"/>
                            <TextBlock Text="Device" TextAlignment="Center" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}"/>
                        </StackPanel>
                    </ToggleButton>

                </StackPanel>

                <!-- 종료 버튼 -->
                <Button Grid.Column="1"
                        Style="{StaticResource ExitButton}"
                        Command="{Binding ProgramExitCommand}">
                    <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                        <telerik:RadGlyph Glyph="&#xe11c;" Width="22" Height="22"
                                          HorizontalAlignment="Center" Margin="0,0,0,5"
                                          Foreground="#ECF0F1"/>
                        <TextBlock Text="종료" TextAlignment="Center"
                                   FontSize="13" FontWeight="SemiBold"
                                   Foreground="#ECF0F1"/>
                    </StackPanel>
                </Button>

            </Grid>
        </Border>

    </Grid>
</Window>
