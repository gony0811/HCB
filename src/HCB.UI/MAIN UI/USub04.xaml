<Page x:Class="HCB.UI.USub04"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
      xmlns:local="clr-namespace:HCB.UI"
      mc:Ignorable="d"
      Title="USub04">

    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/SYSTEM/Common/Styles/DefaultResource.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- DataGrid 공통 -->
            <Style x:Key="LogDataGrid" TargetType="DataGrid">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="RowBackground" Value="Transparent"/>
                <Setter Property="AlternatingRowBackground" Value="#0A1628"/>
                <Setter Property="Foreground" Value="#ECF0F1"/>
                <Setter Property="FontSize" Value="15"/>
                <Setter Property="AutoGenerateColumns" Value="False"/>
                <Setter Property="IsReadOnly" Value="True"/>
                <Setter Property="CanUserAddRows" Value="False"/>
                <Setter Property="CanUserResizeRows" Value="False"/>
                <Setter Property="SelectionMode" Value="Single"/>
                <Setter Property="GridLinesVisibility" Value="Horizontal"/>
                <Setter Property="HorizontalGridLinesBrush" Value="#1C3A52"/>
                <Setter Property="RowHeaderWidth" Value="0"/>
                <Setter Property="VirtualizingPanel.IsVirtualizing" Value="True"/>
                <Setter Property="VirtualizingPanel.VirtualizationMode" Value="Recycling"/>
                <Setter Property="ScrollViewer.CanContentScroll" Value="True"/>
            </Style>

            <Style x:Key="LogColumnHeader" TargetType="DataGridColumnHeader"
                   BasedOn="{StaticResource {x:Type DataGridColumnHeader}}">
                <Setter Property="Background" Value="#0A1628"/>
                <Setter Property="Foreground" Value="#5E8BAA"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="BorderBrush" Value="#1C3A52"/>
                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                <Setter Property="Padding" Value="10,7"/>
            </Style>

            <Style x:Key="LogCell" TargetType="DataGridCell"
                   BasedOn="{StaticResource {x:Type DataGridCell}}">
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Padding" Value="10,0"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
            </Style>

            <!-- 검색 버튼 -->
            <Style x:Key="SearchButton" TargetType="Button">
                <Setter Property="Height" Value="34"/>
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Foreground" Value="#ECF0F1"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd"
                                    Background="#0F3460"
                                    BorderBrush="#2A5A8C"
                                    BorderThickness="1"
                                    CornerRadius="6">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#1A4A7A"/>
                                    <Setter TargetName="Bd" Property="BorderBrush" Value="#3498DB"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#0A2040"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

        </ResourceDictionary>
    </Page.Resources>

    <Grid Margin="6">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="0.85*"/>
            <ColumnDefinition Width="0.15*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="200"/>
        </Grid.RowDefinitions>

        <!-- 타이틀 -->
        <TextBlock Text="에러 로그"
                   FontSize="24" FontWeight="SemiBold" Foreground="#ECF0F1"
                   Grid.Column="0" Grid.Row="0"
                   Margin="6,10,6,10" VerticalAlignment="Center"/>

        <!-- ── 메인 알람 히스토리 그리드 ── -->
        <Border Grid.Column="0" Grid.Row="1"
                Background="#0D1B2A" BorderBrush="#1C3A52" BorderThickness="1"
                CornerRadius="8" Margin="6">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <local:HeaderBar Grid.Row="0" Margin="12,10,12,0" Title="알람 히스토리"/>
                <Rectangle Grid.Row="0" Height="1" Fill="#1C3A52"
                           VerticalAlignment="Bottom" Margin="12,32,12,0"/>

                <DataGrid Grid.Row="1"
                          Style="{StaticResource LogDataGrid}"
                          ColumnHeaderStyle="{StaticResource LogColumnHeader}"
                          CellStyle="{StaticResource LogCell}"
                          ItemsSource="{Binding AlarmHistoryList}"
                          SelectedItem="{Binding SelectedHistory, Mode=TwoWay}"
                          Margin="8,6,8,4">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="에러 번호" Binding="{Binding Code}"                                      Width="*"/>
                        <DataGridTextColumn Header="에러 내용" Binding="{Binding Name}"                                      Width="4*"/>
                        <DataGridTextColumn Header="레벨"     Binding="{Binding Level}"                                     Width="*"/>
                        <DataGridTextColumn Header="상태"     Binding="{Binding Status}"                                    Width="*"/>
                        <DataGridTextColumn Header="발생 날짜" Binding="{Binding CreateDate, StringFormat='{}{0:yyyy-MM-dd}'}" Width="*"/>
                        <DataGridTextColumn Header="발생 시각" Binding="{Binding CreateTime}"                                 Width="*"/>
                        <DataGridTextColumn Header="해제 시각" Binding="{Binding ResetTime}"                                  Width="*"/>
                        <DataGridTextColumn Header="조치 시간" Binding="{Binding AcknowledgeTime}"                            Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- 페이저 -->
                <telerik:RadDataPager Grid.Row="2"
                                      Margin="8,0,8,8"
                                      DisplayMode="FirstLastPreviousNextNumeric"
                                      IsTotalItemCountFixed="False"
                                      PageSize="{Binding PageSize}"
                                      ItemCount="{Binding TotalCount}"
                                      PageIndex="{Binding CurrentPageIndex, Mode=TwoWay}"/>
            </Grid>
        </Border>

        <!-- ── 우측 검색 패널 ── -->
        <Border Grid.Column="1" Grid.Row="1"
                Background="#0D1B2A" BorderBrush="#1C3A52" BorderThickness="1"
                CornerRadius="8" Margin="0,6,6,6">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <local:HeaderBar Grid.Row="0" Margin="12,10,12,0" Title="검색"/>
                <Rectangle Grid.Row="0" Height="1" Fill="#1C3A52"
                           VerticalAlignment="Bottom" Margin="12,32,12,0"/>

                <StackPanel Grid.Row="1" Margin="12,10,12,12">
                    <TextBlock Text="Begin" Foreground="#5E8BAA" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,4"/>
                    <telerik:RadDatePicker
                        SelectedValue="{Binding StartSearchDate, Mode=TwoWay}"
                        InputMode="DatePicker"
                        Margin="0,0,0,8"/>

                    <TextBlock Text="End" Foreground="#5E8BAA" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,4"/>
                    <telerik:RadDatePicker
                        SelectedDate="{Binding EndSearchDate, Mode=TwoWay}"
                        InputMode="DatePicker"
                        Margin="0,0,0,12"/>

                    <Button Content="검색"
                            Style="{StaticResource SearchButton}"
                            Command="{Binding SearchCommand}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ── 하단 시스템 로그 ── -->
        <Border Grid.Row="2" Grid.ColumnSpan="2"
                Background="#0D1B2A" BorderBrush="#1C3A52" BorderThickness="1"
                CornerRadius="8" Margin="6,0,6,6">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <local:HeaderBar Grid.Row="0" Margin="12,10,12,0" Title="시스템 로그"/>
                <Rectangle Grid.Row="0" Height="1" Fill="#1C3A52"
                           VerticalAlignment="Bottom" Margin="12,32,12,0"/>

                <DataGrid Grid.Row="1"
                          Style="{StaticResource LogDataGrid}"
                          ColumnHeaderStyle="{StaticResource LogColumnHeader}"
                          CellStyle="{StaticResource LogCell}"
                          ItemsSource="{Binding Logs}"
                          Margin="8,6,8,8">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Time"       Binding="{Binding Timestamp}"     Width="200"/>
                        <DataGridTextColumn Header="ThreadId"   Binding="{Binding ThreadId}"      Width="150"/>
                        <DataGridTextColumn Header="LogSource"  Binding="{Binding SourceContext}"  Width="250"/>
                        <DataGridTemplateColumn Header="Level" Width="100">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Level}" FontWeight="Bold" VerticalAlignment="Center" Margin="10,0">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="#ECF0F1"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Level}" Value="Error">
                                                        <Setter Property="Foreground" Value="#E74C3C"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Level}" Value="Warning">
                                                        <Setter Property="Foreground" Value="#E67E22"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Level}" Value="Information">
                                                        <Setter Property="Foreground" Value="#2ECC71"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="Message" Binding="{Binding Message}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
    </Grid>
</Page>
