<Page x:Class="HCB.UI.USub07"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:HCB.UI"
      xmlns:uc="clr-namespace:HCB.UI"
      xmlns:vm="clr-namespace:HCB.UI"
      mc:Ignorable="d"
      Title="USub07">

    <Page.Resources>

        <!-- ListView 행 스타일 -->
        <Style x:Key="IoListItem" TargetType="ListViewItem">
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="#1C3A52"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Stretch"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#0A1628"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1C3A52"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- IO 항목 DataTemplate (입출력 공용) -->
        <DataTemplate x:Key="IoItemTemplate" DataType="{x:Type vm:SensorIoItemViewModel}">
            <Grid ToolTip="{Binding Description}"
                  Background="Transparent"
                  ToolTipService.InitialShowDelay="100"
                  ToolTipService.BetweenShowDelay="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="{Binding Name}"
                           Foreground="#ECF0F1"
                           FontSize="15"
                           VerticalAlignment="Center"/>

                <uc:IoPillToggle Grid.Column="1"
                                 Margin="8,0,0,0"
                                 IsChecked="{Binding IsChecked, Mode=TwoWay}"
                                 IsReadOnly="{Binding IsReadOnly}"
                                 Command="{Binding ToggleCommand}"
                                 CommandParameter="{Binding}"/>

                <TextBlock Grid.Column="2"
                           Text="{Binding IoName}"
                           Foreground="#5E8BAA"
                           FontSize="14"
                           Margin="10,0,0,0"
                           VerticalAlignment="Center"/>
            </Grid>
        </DataTemplate>

    </Page.Resources>

    <Grid Margin="6">
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 타이틀 -->
        <TextBlock Text="센서 제어"
                   FontSize="24" FontWeight="SemiBold" Foreground="#ECF0F1"
                   Grid.Column="0" Grid.ColumnSpan="2" Grid.Row="0"
                   Margin="6,10,6,10" VerticalAlignment="Center"/>

        <!-- 입력 신호 -->
        <Border Grid.Column="0" Grid.Row="1"
                Background="#0D1B2A" BorderBrush="#1C3A52" BorderThickness="1"
                CornerRadius="8" Margin="6,0,3,6">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <local:HeaderBar Grid.Row="0" Margin="12,10,12,0" Title="입력 신호 (디지털)"/>
                <Rectangle Grid.Row="0" Height="1" Fill="#1C3A52"
                           VerticalAlignment="Bottom" Margin="12,32,12,0"/>
                <ListView Grid.Row="1"
                          ItemsSource="{Binding DigitalInput}"
                          ItemContainerStyle="{StaticResource IoListItem}"
                          ItemTemplate="{StaticResource IoItemTemplate}"
                          Background="Transparent" BorderThickness="0" Margin="4"
                          ScrollViewer.VerticalScrollBarVisibility="Auto"
                          VirtualizingPanel.IsVirtualizing="True"
                          VirtualizingPanel.VirtualizationMode="Recycling"/>
            </Grid>
        </Border>

        <!-- 출력 신호 -->
        <Border Grid.Column="1" Grid.Row="1"
                Background="#0D1B2A" BorderBrush="#1C3A52" BorderThickness="1"
                CornerRadius="8" Margin="3,0,6,6">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <local:HeaderBar Grid.Row="0" Margin="12,10,12,0" Title="출력 신호 (디지털)"/>
                <Rectangle Grid.Row="0" Height="1" Fill="#1C3A52"
                           VerticalAlignment="Bottom" Margin="12,32,12,0"/>
                <ListView Grid.Row="1"
                          ItemsSource="{Binding DigitalOutput}"
                          ItemContainerStyle="{StaticResource IoListItem}"
                          ItemTemplate="{StaticResource IoItemTemplate}"
                          Background="Transparent" BorderThickness="0" Margin="4"
                          ScrollViewer.VerticalScrollBarVisibility="Auto"
                          VirtualizingPanel.IsVirtualizing="True"
                          VirtualizingPanel.VirtualizationMode="Recycling"/>
            </Grid>
        </Border>
    </Grid>
</Page>
