<Page x:Class="HCB.UI.USub02"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
      xmlns:local="clr-namespace:HCB.UI"
      xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
      mc:Ignorable="d">

    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/SYSTEM/Common/Styles/DefaultResource.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <BooleanToVisibilityConverter x:Key="BoolToVis"/>

            <!-- ── 액션 버튼 (생성/수정/복사/삭제 등) ── -->
            <Style x:Key="ActionButton" TargetType="Button">
                <Setter Property="Height" Value="34"/>
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Foreground" Value="#ECF0F1"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd"
                                    Background="#0F3460"
                                    BorderBrush="#2A5A8C"
                                    BorderThickness="1"
                                    CornerRadius="6">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#1A4A7A"/>
                                    <Setter TargetName="Bd" Property="BorderBrush" Value="#3498DB"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#0A2040"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="Bd" Property="Background" Value="#0A1628"/>
                                    <Setter TargetName="Bd" Property="BorderBrush" Value="#1C3A52"/>
                                    <Setter Property="Foreground" Value="#3A5A7A"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ── DataGrid 공통 ── -->
            <Style x:Key="RecipeDataGrid" TargetType="DataGrid">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="RowBackground" Value="Transparent"/>
                <Setter Property="AlternatingRowBackground" Value="#0A1628"/>
                <Setter Property="Foreground" Value="#ECF0F1"/>
                <Setter Property="FontSize" Value="16"/>
                <Setter Property="AutoGenerateColumns" Value="False"/>
                <Setter Property="IsReadOnly" Value="True"/>
                <Setter Property="CanUserAddRows" Value="False"/>
                <Setter Property="CanUserResizeRows" Value="False"/>
                <Setter Property="SelectionMode" Value="Single"/>
                <Setter Property="GridLinesVisibility" Value="Horizontal"/>
                <Setter Property="HorizontalGridLinesBrush" Value="#1C3A52"/>
                <Setter Property="RowHeaderWidth" Value="0"/>
            </Style>

            <Style x:Key="RecipeColumnHeader" TargetType="DataGridColumnHeader"
                   BasedOn="{StaticResource {x:Type DataGridColumnHeader}}">
                <Setter Property="Background" Value="#0A1628"/>
                <Setter Property="Foreground" Value="#5E8BAA"/>
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="BorderBrush" Value="#1C3A52"/>
                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                <Setter Property="Padding" Value="10,8"/>
            </Style>

            <Style x:Key="RecipeCell" TargetType="DataGridCell"
                   BasedOn="{StaticResource {x:Type DataGridCell}}">
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Padding" Value="10,0"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
            </Style>

        </ResourceDictionary>
    </Page.Resources>

    <Grid Margin="6">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="0.4*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ── 타이틀 ── -->
        <TextBlock Text="레시피 설정"
                   FontSize="24"
                   FontWeight="SemiBold"
                   Foreground="#ECF0F1"
                   Grid.Column="0" Grid.Row="0"
                   Margin="6,10,6,10"
                   VerticalAlignment="Center"/>

        <!-- ══ 좌측: 디바이스 카드 ══ -->
        <Border Grid.Column="0" Grid.Row="1"
                Background="#0D1B2A" BorderBrush="#1C3A52" BorderThickness="1"
                CornerRadius="8" Margin="6">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- HeaderBar -->
                <local:HeaderBar Grid.Row="0" Margin="12,10,12,0" Title="디바이스"/>
                <Rectangle Grid.Row="0" Height="1" Fill="#1C3A52"
                           VerticalAlignment="Bottom" Margin="12,32,12,0"/>

                <!-- 현재 레시피 표시 -->
                <Grid Grid.Row="1" Margin="16,12,16,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="현재 레시피"
                               Foreground="#5E8BAA"
                               FontSize="14"
                               VerticalAlignment="Center"
                               Margin="0,0,16,0"/>
                    <TextBlock Grid.Column="1"
                               Text="{Binding SelectedRecipe.Name}"
                               Foreground="#ECF0F1"
                               FontSize="14"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                </Grid>

                <Rectangle Grid.Row="2" Height="1" Fill="#1C3A52" Margin="12,0"/>

                <!-- 버튼 바 -->
                <StackPanel Grid.Row="3" Orientation="Horizontal"
                            HorizontalAlignment="Right" Margin="12,10,12,4">
                    <Button Content="생성" Style="{StaticResource ActionButton}"
                            Command="{Binding CreateRecipeCommand}" Width="60" Margin="0,0,6,0"/>
                    <Button Content="수정" Style="{StaticResource ActionButton}"
                            Command="{Binding UpdateRecipeCommand}" Width="60" Margin="0,0,6,0"/>
                    <Button Content="복사" Style="{StaticResource ActionButton}"
                            Command="{Binding CopyRecipeCommand}"   Width="60" Margin="0,0,6,0"/>
                    <Button Content="삭제" Style="{StaticResource ActionButton}"
                            Command="{Binding DeleteRecipeCommand}" Width="60"/>
                </StackPanel>

                <!-- RECIPE LIST 소제목 -->
                <TextBlock Grid.Row="4"
                           Text="RECIPE LIST"
                           Foreground="#5E8BAA"
                           FontSize="12"
                           FontWeight="SemiBold"
                           Margin="16,4,16,4"/>

                <!-- 레시피 그리드 -->
                <DataGrid x:Name="RecipeGrid"
                          Grid.Row="5"
                          Style="{StaticResource RecipeDataGrid}"
                          ColumnHeaderStyle="{StaticResource RecipeColumnHeader}"
                          CellStyle="{StaticResource RecipeCell}"
                          ItemsSource="{Binding Recipes}"
                          SelectedItem="{Binding SelectedRecipe, Mode=TwoWay}"
                          Margin="8,0,8,8">
                    <DataGrid.InputBindings>
                        <MouseBinding MouseAction="LeftDoubleClick"
                                      Command="{Binding UseChangeCommand}"/>
                    </DataGrid.InputBindings>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="#"
                                            Binding="{Binding Id}"
                                            Width="80">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="FontSize" Value="16"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTemplateColumn Header="이름" Width="*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Grid Margin="4,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding Name}"
                                                   FontSize="16"
                                                   Foreground="#ECF0F1"
                                                   VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <Border Grid.Column="1"
                                                CornerRadius="4" Padding="6,2"
                                                Margin="8,0,0,0"
                                                Background="#14452A"
                                                BorderBrush="#2ECC71"
                                                BorderThickness="1"
                                                VerticalAlignment="Center"
                                                Visibility="{Binding IsActive, Converter={StaticResource BoolToVis}}">
                                            <TextBlock Text="사용중"
                                                       FontSize="11"
                                                       FontWeight="Bold"
                                                       Foreground="#2ECC71"/>
                                        </Border>
                                    </Grid>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <!-- ══ 우측: RECIPE DATA LIST + BONDING STEP ══ -->
        <Grid Grid.Column="1" Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- RECIPE DATA LIST -->
            <Border Grid.Row="0"
                    Background="#0D1B2A" BorderBrush="#1C3A52" BorderThickness="1"
                    CornerRadius="8" Margin="6,6,6,3">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <local:HeaderBar Grid.Row="0" Margin="12,10,12,0" Title="RECIPE DATA LIST"/>
                    <Rectangle Grid.Row="0" Height="1" Fill="#1C3A52"
                               VerticalAlignment="Bottom" Margin="12,32,12,0"/>

                    <DataGrid x:Name="ParamGrid"
                              Grid.Row="1"
                              Style="{StaticResource RecipeDataGrid}"
                              ColumnHeaderStyle="{StaticResource RecipeColumnHeader}"
                              CellStyle="{StaticResource RecipeCell}"
                              ItemsSource="{Binding SelectedRecipe.ParamList}"
                              SelectedItem="{Binding SelectedParam, Mode=TwoWay}"
                              Margin="8,6,8,4">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Name"  Binding="{Binding Name}"     Width="2*"/>
                            <DataGridTextColumn Header="Value" Binding="{Binding Value}"     Width="2*"/>
                            <DataGridTextColumn Header="Unit"  Binding="{Binding UnitType}"  Width="100"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- 하단 버튼 -->
                    <StackPanel Grid.Row="2" Orientation="Horizontal"
                                HorizontalAlignment="Right" Margin="12,6,12,10">
                        <Button Content="생성" Style="{StaticResource ActionButton}"
                                Command="{Binding CreateParamCommand}" Width="80" Margin="0,0,6,0"/>
                        <Button Content="수정" Style="{StaticResource ActionButton}"
                                Command="{Binding UpdateParamCommand}" Width="80" Margin="0,0,6,0"/>
                        <Button Content="삭제" Style="{StaticResource ActionButton}"
                                Command="{Binding DeleteParamCommand}" Width="80"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- BONDING STEP -->
            <Border Grid.Row="1"
                    Background="#0D1B2A" BorderBrush="#1C3A52" BorderThickness="1"
                    CornerRadius="8" Margin="6,3,6,6">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <local:HeaderBar Grid.Row="0" Margin="12,10,12,0" Title="BONDING STEP"/>
                    <Rectangle Grid.Row="0" Height="1" Fill="#1C3A52"
                               VerticalAlignment="Bottom" Margin="12,32,12,0"/>

                    <DataGrid x:Name="StepGrid"
                              Grid.Row="1"
                              Style="{StaticResource RecipeDataGrid}"
                              ColumnHeaderStyle="{StaticResource RecipeColumnHeader}"
                              CellStyle="{StaticResource RecipeCell}"
                              ItemsSource="{Binding SelectedRecipe.StepList}"
                              SelectedItem="{Binding SelectedStep, Mode=TwoWay}"
                              Margin="8,6,8,4">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Step #"      Binding="{Binding StepNumber}"   Width="80"/>
                            <DataGridTextColumn Header="Force (N)"   Binding="{Binding Force}"        Width="*"/>
                            <DataGridTextColumn Header="Time (sec)"  Binding="{Binding DurationTime}" Width="*"/>
                            <DataGridTextColumn Header="Description" Binding="{Binding Description}"  Width="2*"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- 하단 버튼 -->
                    <StackPanel Grid.Row="2" Orientation="Horizontal"
                                HorizontalAlignment="Right" Margin="12,6,12,10">
                        <Button Content="STEP 추가" Style="{StaticResource ActionButton}"
                                Command="{Binding AddStepCommand}"    Width="100" Margin="0,0,6,0"/>
                        <Button Content="수정" Style="{StaticResource ActionButton}"
                                Command="{Binding UpdateStepCommand}" Width="80"  Margin="0,0,6,0"/>
                        <Button Content="삭제" Style="{StaticResource ActionButton}"
                                Command="{Binding DeleteStepCommand}" Width="80"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>
