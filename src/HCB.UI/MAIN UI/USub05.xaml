<Page x:Class="HCB.UI.USub05"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:HCB;assembly=HCB"
      xmlns:dbType="clr-namespace:HCB.Data.Entity.Type;assembly=HCB"
      xmlns:uc="clr-namespace:HCB.UI"
      xmlns:sys="clr-namespace:System;assembly=mscorlib"
      xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
      mc:Ignorable="d"
      Title="에러 목록">

    <Page.Resources>
        <ResourceDictionary>
            <CollectionViewSource x:Key="AlarmsSource"
                                  Source="{Binding DataContext.AlarmList,
                                           RelativeSource={RelativeSource AncestorType=Page}}"/>
            <CompositeCollection x:Key="AlarmsWithAdder">
                <CollectionContainer Collection="{Binding Source={StaticResource AlarmsSource}}"/>
                <sys:String>__ADD__</sys:String>
            </CompositeCollection>
            <ObjectDataProvider x:Key="AlarmLevelValues"
                                ObjectType="{x:Type sys:Enum}"
                                MethodName="GetValues">
                <ObjectDataProvider.MethodParameters>
                    <x:Type TypeName="dbType:AlarmLevel"/>
                </ObjectDataProvider.MethodParameters>
            </ObjectDataProvider>

            <!-- DataGrid -->
            <Style x:Key="AlarmDataGrid" TargetType="DataGrid">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="RowBackground" Value="Transparent"/>
                <Setter Property="AlternatingRowBackground" Value="#0A1628"/>
                <Setter Property="Foreground" Value="#ECF0F1"/>
                <Setter Property="FontSize" Value="16"/>
                <Setter Property="AutoGenerateColumns" Value="False"/>
                <Setter Property="IsReadOnly" Value="True"/>
                <Setter Property="CanUserAddRows" Value="False"/>
                <Setter Property="CanUserResizeRows" Value="False"/>
                <Setter Property="SelectionMode" Value="Single"/>
                <Setter Property="GridLinesVisibility" Value="Horizontal"/>
                <Setter Property="HorizontalGridLinesBrush" Value="#1C3A52"/>
                <Setter Property="RowHeaderWidth" Value="0"/>
                <Setter Property="VirtualizingPanel.IsVirtualizing" Value="True"/>
                <Setter Property="VirtualizingPanel.VirtualizationMode" Value="Recycling"/>
                <Setter Property="ScrollViewer.CanContentScroll" Value="True"/>
            </Style>

            <Style x:Key="AlarmColumnHeader" TargetType="DataGridColumnHeader"
                   BasedOn="{StaticResource {x:Type DataGridColumnHeader}}">
                <Setter Property="Background" Value="#0A1628"/>
                <Setter Property="Foreground" Value="#5E8BAA"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="BorderBrush" Value="#1C3A52"/>
                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                <Setter Property="Padding" Value="10,7"/>
            </Style>

            <Style x:Key="AlarmCell" TargetType="DataGridCell"
                   BasedOn="{StaticResource {x:Type DataGridCell}}">
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Padding" Value="10,0"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
            </Style>

            <!-- 액션 버튼 -->
            <Style x:Key="ActionButton" TargetType="Button">
                <Setter Property="Height" Value="34"/>
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Foreground" Value="#ECF0F1"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd"
                                    Background="#0F3460"
                                    BorderBrush="#2A5A8C"
                                    BorderThickness="1"
                                    CornerRadius="6">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#1A4A7A"/>
                                    <Setter TargetName="Bd" Property="BorderBrush" Value="#3498DB"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#0A2040"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="Bd" Property="Background" Value="#0A1628"/>
                                    <Setter TargetName="Bd" Property="BorderBrush" Value="#1C3A52"/>
                                    <Setter Property="Foreground" Value="#3A5A7A"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- 알람 생성 버튼 (강조) -->
            <Style x:Key="CreateAlarmButton" TargetType="Button">
                <Setter Property="Height" Value="44"/>
                <Setter Property="FontSize" Value="15"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Foreground" Value="#ECF0F1"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd"
                                    Background="#0F3D20"
                                    BorderBrush="#27AE60"
                                    BorderThickness="1"
                                    CornerRadius="6">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#1A5A30"/>
                                    <Setter TargetName="Bd" Property="BorderBrush" Value="#2ECC71"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#082010"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- 입력 필드 레이블 -->
            <Style x:Key="FieldLabel" TargetType="TextBlock">
                <Setter Property="Foreground" Value="#5E8BAA"/>
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Margin" Value="0,0,0,4"/>
            </Style>

            <!-- 텍스트 입력 박스 -->
            <Style x:Key="InputBox" TargetType="TextBox">
                <Setter Property="Background" Value="#0A1628"/>
                <Setter Property="Foreground" Value="#ECF0F1"/>
                <Setter Property="BorderBrush" Value="#2A5A8C"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Padding" Value="8,6"/>
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="CaretBrush" Value="#ECF0F1"/>
            </Style>

        </ResourceDictionary>
    </Page.Resources>

    <Grid Margin="6">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="0.65*"/>
            <ColumnDefinition Width="0.35*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 타이틀 -->
        <TextBlock Text="알람 정의"
                   FontSize="24" FontWeight="SemiBold" Foreground="#ECF0F1"
                   Grid.Column="0" Grid.Row="0"
                   Margin="6,10,6,10" VerticalAlignment="Center"/>

        <!-- ── 좌측: 알람 목록 ── -->
        <Grid Grid.Column="0" Grid.Row="1" Margin="6">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="#0D1B2A" BorderBrush="#1C3A52" BorderThickness="1"
                    CornerRadius="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <uc:HeaderBar Grid.Row="0" Margin="12,10,12,0" Title="알람 목록"/>
                    <Rectangle Grid.Row="0" Height="1" Fill="#1C3A52"
                               VerticalAlignment="Bottom" Margin="12,32,12,0"/>

                    <DataGrid x:Name="AlarmGrid"
                              Grid.Row="1"
                              Style="{StaticResource AlarmDataGrid}"
                              ColumnHeaderStyle="{StaticResource AlarmColumnHeader}"
                              CellStyle="{StaticResource AlarmCell}"
                              ItemsSource="{Binding AlarmList}"
                              SelectedItem="{Binding SelectedAlarm, Mode=TwoWay}"
                              CanUserSortColumns="False"
                              Margin="8,6,8,4">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="코드"      Binding="{Binding Code}" Width="100"/>
                            <DataGridTextColumn Header="알람 내용" Binding="{Binding Name}" Width="2*"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <Button Grid.Row="2"
                            Content="+ 알람 생성"
                            Style="{StaticResource CreateAlarmButton}"
                            Command="{Binding CreateAlarmCommand}"
                            Margin="8,4,8,8"/>
                </Grid>
            </Border>

            <!-- 하단 액션 버튼 -->
            <StackPanel Grid.Row="1" Orientation="Horizontal"
                        HorizontalAlignment="Right" Margin="0,8,0,0">
                <Button Content="되돌리기" Style="{StaticResource ActionButton}"
                        Command="{Binding DiscardCommand}" Width="90" Margin="0,0,6,0"/>
                <Button Content="저장" Style="{StaticResource ActionButton}"
                        Command="{Binding SaveAlarmCommand}" Width="80" Margin="0,0,6,0"/>
                <Button Content="SET ALARM" Style="{StaticResource ActionButton}"
                        Command="{Binding SetAlarmCommand}" Width="100"/>
            </StackPanel>
        </Grid>

        <!-- ── 우측: 상세 정보 편집 ── -->
        <Border Grid.Column="1" Grid.Row="1"
                Background="#0D1B2A" BorderBrush="#1C3A52" BorderThickness="1"
                CornerRadius="8" Margin="0,6,6,6">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <uc:HeaderBar Grid.Row="0" Margin="12,10,12,0" Title="상세 정보"/>
                <Rectangle Grid.Row="0" Height="1" Fill="#1C3A52"
                           VerticalAlignment="Bottom" Margin="12,32,12,0"/>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="16,12,16,16"
                                DataContext="{Binding SelectedAlarm}">

                        <!-- Code / 알람 내용 / 레벨 -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="0.35*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Style="{StaticResource FieldLabel}" Text="Code"/>
                                <telerik:RadWatermarkTextBox
                                    Style="{StaticResource RadWatermarkTextBoxStyle}"
                                    Text="{Binding Code, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Style="{StaticResource FieldLabel}" Text="알람 내용"/>
                                <telerik:RadWatermarkTextBox
                                    Style="{StaticResource RadWatermarkTextBoxStyle}"
                                    Text="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                        </Grid>

                        <!-- 레벨 -->
                        <StackPanel Margin="0,12,0,0">
                            <TextBlock Style="{StaticResource FieldLabel}" Text="레벨"/>
                            <telerik:RadComboBox
                                Style="{StaticResource RadComboBoxStyle}"
                                ItemsSource="{Binding Source={StaticResource AlarmLevelValues}}"
                                SelectedItem="{Binding Level, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                Height="32"/>
                        </StackPanel>

                        <!-- 원인 -->
                        <StackPanel Margin="0,12,0,0">
                            <TextBlock Style="{StaticResource FieldLabel}" Text="원인"/>
                            <telerik:RadWatermarkTextBox
                                Style="{StaticResource RadWatermarkTextBoxStyle}"
                                Text="{Binding Description, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                AcceptsReturn="True"
                                TextWrapping="Wrap"
                                VerticalScrollBarVisibility="Auto"
                                Height="120"/>
                        </StackPanel>

                        <!-- 해결 방법 -->
                        <StackPanel Margin="0,12,0,0">
                            <TextBlock Style="{StaticResource FieldLabel}" Text="해결 방법"/>
                            <telerik:RadWatermarkTextBox
                                Style="{StaticResource RadWatermarkTextBoxStyle}"
                                Text="{Binding Action, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                AcceptsReturn="True"
                                TextWrapping="Wrap"
                                VerticalScrollBarVisibility="Auto"
                                Height="160"/>
                        </StackPanel>

                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</Page>
