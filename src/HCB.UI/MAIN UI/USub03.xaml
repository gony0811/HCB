<Page x:Class="HCB.UI.USub03"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:HCB.UI"
      mc:Ignorable="d">

    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/SYSTEM/Common/Styles/DefaultResource.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <local:BoolToTextConverter  x:Key="BoolToText"/>
            <local:BoolToBrushConverter x:Key="BoolToBrush"/>
            <local:NotConverter         x:Key="Not"/>

            <!-- 로그인 버튼 -->
            <Style x:Key="LoginButton" TargetType="Button">
                <Setter Property="Height" Value="44"/>
                <Setter Property="FontSize" Value="16"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Foreground" Value="#ECF0F1"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Margin" Value="0,4"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd"
                                    Background="#0F3460"
                                    BorderBrush="#2A5A8C"
                                    BorderThickness="1"
                                    CornerRadius="6">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#1A4A7A"/>
                                    <Setter TargetName="Bd" Property="BorderBrush" Value="#3498DB"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#0A2040"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- 저장 버튼 -->
            <Style x:Key="SaveButton" TargetType="Button">
                <Setter Property="Height" Value="34"/>
                <Setter Property="Width" Value="100"/>
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Foreground" Value="#ECF0F1"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="HorizontalAlignment" Value="Right"/>
                <Setter Property="Margin" Value="0,8,0,0"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd"
                                    Background="#0F3D20"
                                    BorderBrush="#27AE60"
                                    BorderThickness="1"
                                    CornerRadius="6">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#1A5A30"/>
                                    <Setter TargetName="Bd" Property="BorderBrush" Value="#2ECC71"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#082010"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- DataGrid 공통 -->
            <Style x:Key="AuthDataGrid" TargetType="DataGrid">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="RowBackground" Value="Transparent"/>
                <Setter Property="AlternatingRowBackground" Value="#0A1628"/>
                <Setter Property="Foreground" Value="#ECF0F1"/>
                <Setter Property="FontSize" Value="15"/>
                <Setter Property="AutoGenerateColumns" Value="False"/>
                <Setter Property="CanUserAddRows" Value="False"/>
                <Setter Property="CanUserResizeRows" Value="False"/>
                <Setter Property="SelectionMode" Value="Single"/>
                <Setter Property="GridLinesVisibility" Value="Horizontal"/>
                <Setter Property="HorizontalGridLinesBrush" Value="#1C3A52"/>
                <Setter Property="RowHeaderWidth" Value="0"/>
            </Style>

            <Style x:Key="AuthColumnHeader" TargetType="DataGridColumnHeader"
                   BasedOn="{StaticResource {x:Type DataGridColumnHeader}}">
                <Setter Property="Background" Value="#0A1628"/>
                <Setter Property="Foreground" Value="#5E8BAA"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="BorderBrush" Value="#1C3A52"/>
                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                <Setter Property="Padding" Value="10,7"/>
            </Style>

            <Style x:Key="AuthCell" TargetType="DataGridCell"
                   BasedOn="{StaticResource {x:Type DataGridCell}}">
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Padding" Value="10,0"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
            </Style>

        </ResourceDictionary>
    </Page.Resources>

    <Grid Margin="6">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 타이틀 -->
        <TextBlock Text="사용자 설정"
                   FontSize="24" FontWeight="SemiBold" Foreground="#ECF0F1"
                   Grid.Column="0" Grid.Row="0"
                   Margin="6,10,6,10" VerticalAlignment="Center"/>

        <!-- ── 좌측: 사용자 선택 카드 ── -->
        <Border Grid.Column="0" Grid.Row="1"
                Background="#0D1B2A" BorderBrush="#1C3A52" BorderThickness="1"
                CornerRadius="8" Margin="6" Width="260">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <local:HeaderBar Grid.Row="0" Margin="12,10,12,0" Title="사용자 선택"/>
                <Rectangle Grid.Row="0" Height="1" Fill="#1C3A52"
                           VerticalAlignment="Bottom" Margin="12,32,12,0"/>

                <StackPanel Grid.Row="1" Margin="16,12,16,16">
                    <Button Content="작업자"
                            Style="{StaticResource LoginButton}"
                            Command="{Binding LoginCommand}"
                            CommandParameter="OPERATOR"/>
                    <Button Content="엔지니어"
                            Style="{StaticResource LoginButton}"
                            Command="{Binding LoginCommand}"
                            CommandParameter="ENGINEER"/>
                    <Button Content="서비스 엔지니어"
                            Style="{StaticResource LoginButton}"
                            Command="{Binding LoginCommand}"
                            CommandParameter="SERVICE_ENGINEER"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ── 우측: 접근 권한 카드들 ── -->
        <StackPanel Grid.Column="1" Grid.Row="1" Orientation="Horizontal" Margin="0,6,6,6">

            <!-- 접근 권한 (작업자) -->
            <Border Visibility="{Binding OperatorGrant}"
                    Background="#0D1B2A" BorderBrush="#1C3A52" BorderThickness="1"
                    CornerRadius="8" Margin="0,0,6,0" Width="340">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <local:HeaderBar Grid.Row="0" Margin="12,10,12,0" Title="접근 권한 · 작업자"/>
                    <Rectangle Grid.Row="0" Height="1" Fill="#1C3A52"
                               VerticalAlignment="Bottom" Margin="12,32,12,0"/>

                    <DataGrid Grid.Row="1"
                              Style="{StaticResource AuthDataGrid}"
                              ColumnHeaderStyle="{StaticResource AuthColumnHeader}"
                              CellStyle="{StaticResource AuthCell}"
                              ItemsSource="{Binding OperatorScreens}"
                              Margin="8,6,8,4"/>

                    <Button Grid.Row="2"
                            Content="저장"
                            Style="{StaticResource SaveButton}"
                            Command="{Binding SaveOpScreenCommand}"
                            Margin="0,6,12,12"/>
                </Grid>
            </Border>

            <!-- 접근 권한 (엔지니어) -->
            <Border Visibility="{Binding EngineerGrant}"
                    Background="#0D1B2A" BorderBrush="#1C3A52" BorderThickness="1"
                    CornerRadius="8" Width="340">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <local:HeaderBar Grid.Row="0" Margin="12,10,12,0" Title="접근 권한 · 엔지니어"/>
                    <Rectangle Grid.Row="0" Height="1" Fill="#1C3A52"
                               VerticalAlignment="Bottom" Margin="12,32,12,0"/>

                    <DataGrid Grid.Row="1"
                              Style="{StaticResource AuthDataGrid}"
                              ColumnHeaderStyle="{StaticResource AuthColumnHeader}"
                              CellStyle="{StaticResource AuthCell}"
                              ItemsSource="{Binding EngineerScreens}"
                              Margin="8,6,8,4"/>

                    <Button Grid.Row="2"
                            Content="저장"
                            Style="{StaticResource SaveButton}"
                            Command="{Binding SaveENGScreenCommand}"
                            Margin="0,6,12,12"/>
                </Grid>
            </Border>

        </StackPanel>
    </Grid>
</Page>
